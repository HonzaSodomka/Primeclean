<div id="cookie-banner" class="fixed bottom-0 inset-x-0 z-[200] p-4 md:p-6 hidden">
  <div class="max-w-[1200px] mx-auto">
    <div class="bg-zinc-100 border border-zinc-200 rounded-2xl p-5 md:p-7 flex flex-col md:flex-row items-start md:items-center gap-5 shadow-2xl">

      <div class="flex-shrink-0 w-10 h-10 rounded-xl border border-[#81b344]/25 overflow-hidden">
        <img src="/cookies.jpg" alt="Cookies" class="w-full h-full object-cover" />
      </div>

      <div class="flex-1 min-w-0">
        <p class="text-[15px] font-bold text-zinc-900 mb-1">Tento web používá cookies</p>
        <p class="text-[13px] text-zinc-600 font-medium leading-relaxed">
          Cookies používáme pro zajištění správné funkčnosti webu. Přijetím souhlasíte s jejich použitím.
        </p>
      </div>

      <div class="flex items-center gap-3 flex-shrink-0 w-full md:w-auto">
        <button
          id="cookie-decline"
          class="flex-1 md:flex-none px-6 py-2.5 text-[13.5px] font-bold text-zinc-700 bg-zinc-200 hover:bg-zinc-300 rounded-xl transition-colors duration-200 whitespace-nowrap"
        >
          Odmítnout
        </button>
        <button
          id="cookie-accept"
          class="flex-1 md:flex-none px-6 py-2.5 text-[13.5px] font-bold text-zinc-700 bg-zinc-200 hover:bg-zinc-300 rounded-xl transition-colors duration-200 whitespace-nowrap"
        >
          Přijmout vše
        </button>
      </div>

    </div>
  </div>
</div>

<script>
  declare global {
    interface Window {
      openCookieBanner: () => void;
    }
  }

  const banner = document.getElementById('cookie-banner');
  const acceptBtn = document.getElementById('cookie-accept');
  const declineBtn = document.getElementById('cookie-decline');

  if (banner) {
    try {
      if (!localStorage.getItem('cookie-consent')) {
        banner.classList.remove('hidden');
      }
    } catch (e) {
      banner.classList.remove('hidden');
    }

    acceptBtn?.addEventListener('click', () => {
      try { localStorage.setItem('cookie-consent', 'accepted'); } catch (e) {}
      banner.classList.add('hidden');
    });

    declineBtn?.addEventListener('click', () => {
      try { localStorage.setItem('cookie-consent', 'declined'); } catch (e) {}
      banner.classList.add('hidden');
    });

    window.openCookieBanner = function () {
      try { localStorage.removeItem('cookie-consent'); } catch (e) {}
      banner.classList.remove('hidden');
      setTimeout(() => {
        banner.scrollIntoView({ behavior: 'smooth', block: 'end' });
      }, 100);
    };
  }
</script>