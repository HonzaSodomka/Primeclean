---
// src/components/Footer.astro
const currentYear = new Date().getFullYear();
---

<footer class="bg-zinc-950 text-zinc-400 border-t border-zinc-900 pt-20 pb-10 relative overflow-hidden">
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-[800px] h-[1px] bg-gradient-to-r from-transparent via-[#81b344]/30 to-transparent"></div>
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] bg-[#81b344]/5 blur-[100px] pointer-events-none rounded-full"></div>

  <div class="max-w-[1200px] mx-auto px-5 md:px-8 lg:px-12 relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 lg:gap-8 mb-16">

      <div class="md:col-span-12 lg:col-span-4">
        <a href="/" class="inline-block text-2xl font-extrabold text-white tracking-tighter mb-6 group">
          Prime<span class="text-[#81b344]">Clean</span><span class="text-zinc-600 transition-colors group-hover:text-white">.</span>
        </a>
        <p class="text-[14.5px] leading-relaxed text-zinc-400 max-w-sm mb-8">
          Zajišťujeme profesionální úklid společných prostor, kanceláří a Airbnb v Brně a okolí. Pravidelnost, nekompromisní kvalita a absolutní přehled díky aplikaci.
        </p>
        <div class="flex items-center gap-4">
          <a href="#" class="w-10 h-10 rounded-full border border-zinc-800 flex items-center justify-center text-zinc-400 hover:bg-[#81b344] hover:border-[#81b344] hover:text-white transition-all duration-300" aria-label="Facebook">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" /></svg>
          </a>
          <a href="#" class="w-10 h-10 rounded-full border border-zinc-800 flex items-center justify-center text-zinc-400 hover:bg-[#81b344] hover:border-[#81b344] hover:text-white transition-all duration-300" aria-label="Instagram">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.46 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z" clip-rule="evenodd" /></svg>
          </a>
        </div>
      </div>

      <div class="md:col-span-4 lg:col-span-3 lg:col-start-6">
        <h4 class="text-[12px] font-bold text-white uppercase tracking-[0.2em] mb-6">Navigace</h4>
        <ul class="space-y-3.5">
          <li><a href="/" class="text-[14.5px] hover:text-white transition-colors">Domů</a></li>
          <li><a href="/sluzby" class="text-[14.5px] hover:text-white transition-colors">Služby</a></li>
          <li><a href="/cenik" class="text-[14.5px] hover:text-white transition-colors">Ceník</a></li>
          <li><a href="/aplikace" class="text-[14.5px] hover:text-white transition-colors">Aplikace</a></li>
          <li><a href="/reference" class="text-[14.5px] hover:text-white transition-colors">Reference</a></li>
          <li><a href="/kontakt" class="text-[14.5px] hover:text-white transition-colors">Kontakt</a></li>
        </ul>
      </div>

      <div class="md:col-span-8 lg:col-span-4">
        <h4 class="text-[12px] font-bold text-white uppercase tracking-[0.2em] mb-6">Spojte se s námi</h4>
        <ul class="space-y-4">
          <li>
            <a href="tel:+420773102770" class="flex items-center gap-3 group">
              <div class="w-10 h-10 rounded-full border border-zinc-800 flex items-center justify-center text-zinc-400 group-hover:border-[#81b344] group-hover:text-[#81b344] transition-all duration-300">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
              </div>
              <div>
                <p class="text-[11px] font-bold uppercase tracking-wider text-zinc-600 mb-0.5">Zavolejte nám</p>
                <p class="text-[15px] text-white font-medium group-hover:text-[#81b344] transition-colors">773 102 770</p>
              </div>
            </a>
          </li>
          <li>
            <a href="mailto:info@primeclean.cz" class="flex items-center gap-3 group">
              <div class="w-10 h-10 rounded-full border border-zinc-800 flex items-center justify-center text-zinc-400 group-hover:border-[#81b344] group-hover:text-[#81b344] transition-all duration-300">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
              </div>
              <div>
                <p class="text-[11px] font-bold uppercase tracking-wider text-zinc-600 mb-0.5">Napište nám</p>
                <p class="text-[15px] text-white font-medium group-hover:text-[#81b344] transition-colors">info@primeclean.cz</p>
              </div>
            </a>
          </li>
          <li class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full border border-zinc-800 flex items-center justify-center text-zinc-500">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            </div>
            <div>
              <p class="text-[11px] font-bold uppercase tracking-wider text-zinc-600 mb-0.5">Pracovní doba</p>
              <p class="text-[15px] text-white font-medium">Po-Pá: 08:00 - 20:00</p>
            </div>
          </li>
        </ul>
      </div>

    </div>

    <div class="pt-8 border-t border-zinc-800/80 flex flex-col md:flex-row items-center justify-between gap-6">
      <p class="text-[13px] text-zinc-500 font-medium">
        © {currentYear} PrimeClean. Všechna práva vyhrazena.
      </p>

      <button id="scrollToTop" class="inline-flex items-center gap-2 text-[12px] font-bold uppercase tracking-wider text-zinc-400 hover:text-white transition-colors group">
        Zpět nahoru
        <div class="w-8 h-8 rounded-full bg-zinc-900 flex items-center justify-center border border-zinc-800 group-hover:bg-[#81b344] group-hover:border-[#81b344] transition-all duration-300">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7" /></svg>
        </div>
      </button>
    </div>
  </div>
</footer>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const scrollBtn = document.getElementById('scrollToTop');
    if (scrollBtn) {
      scrollBtn.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    }
  });
</script>