---
---

<footer class="bg-zinc-950 text-zinc-400 border-t border-zinc-900 pt-20 pb-10 relative overflow-hidden">
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-[800px] h-[1px] bg-gradient-to-r from-transparent via-[#81b344]/30 to-transparent"></div>
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] bg-[#81b344]/5 blur-[100px] pointer-events-none rounded-full"></div>

  <div class="max-w-[1200px] mx-auto px-5 md:px-8 lg:px-12 relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 lg:gap-8 mb-16">

      <!-- Brand -->
      <div class="md:col-span-12 lg:col-span-4">
        <a href="/" class="inline-block text-2xl font-extrabold text-white tracking-tighter mb-6 group">
          Prime<span class="text-[#81b344]">Clean</span><span class="text-zinc-600 transition-colors group-hover:text-white">.</span>
        </a>
        <p class="text-[14.5px] leading-relaxed text-zinc-400 max-w-sm">
          Zajišťujeme profesionální úklid společných prostor, kanceláří a Airbnb v Brně a okolí. Pravidelnost, nekompromisní kvalita a absolutní přehled díky aplikaci.
        </p>
      </div>

      <!-- Navigace -->
      <div class="md:col-span-4 lg:col-span-3 lg:col-start-6">
        <h4 class="text-[12px] font-bold text-white uppercase tracking-[0.2em] mb-6">Navigace</h4>
        <ul class="space-y-3.5">
          <li><a href="/" class="text-[14.5px] hover:text-white transition-colors">Domů</a></li>
          <li><a href="/sluzby" class="text-[14.5px] hover:text-white transition-colors">Služby</a></li>
          <li><a href="/cenik" class="text-[14.5px] hover:text-white transition-colors">Ceník</a></li>
          <li><a href="/aplikace" class="text-[14.5px] hover:text-white transition-colors">Aplikace</a></li>
          <li><a href="/reference" class="text-[14.5px] hover:text-white transition-colors">Reference</a></li>
          <li><a href="/kontakt" class="text-[14.5px] hover:text-white transition-colors">Kontakt</a></li>
        </ul>
      </div>

      <!-- Kontakt -->
      <div class="md:col-span-8 lg:col-span-4">
        <h4 class="text-[12px] font-bold text-white uppercase tracking-[0.2em] mb-6">Spojte se s námi</h4>
        <ul class="space-y-4">
          <li>
            <a href="tel:+420773102770" class="flex items-center gap-3 group">
              <div class="w-10 h-10 rounded-full border border-zinc-800 flex items-center justify-center text-zinc-400 group-hover:border-[#81b344] group-hover:text-[#81b344] transition-all duration-300">
                <i data-lucide="phone" class="w-4 h-4"></i>
              </div>
              <div>
                <p class="text-[11px] font-bold uppercase tracking-wider text-zinc-600 mb-0.5">Zavolejte nám</p>
                <p class="text-[15px] text-white font-medium group-hover:text-[#81b344] transition-colors">773 102 770</p>
              </div>
            </a>
          </li>
          <li>
            <a href="mailto:info@primeclean.cz" class="flex items-center gap-3 group">
              <div class="w-10 h-10 rounded-full border border-zinc-800 flex items-center justify-center text-zinc-400 group-hover:border-[#81b344] group-hover:text-[#81b344] transition-all duration-300">
                <i data-lucide="mail" class="w-4 h-4"></i>
              </div>
              <div>
                <p class="text-[11px] font-bold uppercase tracking-wider text-zinc-600 mb-0.5">Napište nám</p>
                <p class="text-[15px] text-white font-medium group-hover:text-[#81b344] transition-colors">info@primeclean.cz</p>
              </div>
            </a>
          </li>
          <li class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full border border-zinc-800 flex items-center justify-center text-zinc-500">
              <i data-lucide="clock" class="w-4 h-4"></i>
            </div>
            <div>
              <p class="text-[11px] font-bold uppercase tracking-wider text-zinc-600 mb-0.5">Pracovní doba</p>
              <p class="text-[15px] text-white font-medium">Po-Pá: 08:00 - 20:00</p>
            </div>
          </li>
        </ul>
      </div>

    </div>

    <div class="pt-8 border-t border-zinc-800/80 flex flex-col md:flex-row items-center justify-between gap-6">
      <p class="text-[13px] text-zinc-500 font-medium">
        &copy; <span id="footer-year">2026</span> PrimeClean. Všechna práva vyhrazena.
      </p>

      <div class="flex items-center gap-6">
        <button
          id="open-cookie-banner"
          class="text-[13px] text-zinc-500 hover:text-zinc-300 font-medium transition-colors duration-200 underline underline-offset-4 decoration-zinc-700 hover:decoration-zinc-400"
        >
          Nastavení cookies
        </button>

        <button id="scrollToTop" class="inline-flex items-center gap-2 text-[12px] font-bold uppercase tracking-wider text-zinc-400 hover:text-white transition-colors group">
          Zpět nahoru
          <div class="w-8 h-8 rounded-full bg-zinc-900 flex items-center justify-center border border-zinc-800 group-hover:bg-[#81b344] group-hover:border-[#81b344] transition-all duration-300">
            <i data-lucide="chevron-up" class="w-4 h-4"></i>
          </div>
        </button>
      </div>
    </div>
  </div>
</footer>

<script is:inline>
  // Rok se promíne za běhu v prohlížeči, ne v čase buildu
  document.getElementById('footer-year').textContent = new Date().getFullYear();
</script>

<script>
  declare global {
    interface Window {
      openCookieBanner: () => void;
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    document.getElementById('scrollToTop')?.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });

    document.getElementById('open-cookie-banner')?.addEventListener('click', () => {
      if (typeof window.openCookieBanner === 'function') window.openCookieBanner();
    });
  });
</script>
