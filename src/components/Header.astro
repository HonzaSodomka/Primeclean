---
const navLinks = [
  { name: 'Domů',      href: '/' },
  { name: 'Služby',    href: '/sluzby' },
  { name: 'Ceník',     href: '/cenik' },
  { name: 'Aplikace',  href: '/aplikace' },
  { name: 'Reference', href: '/reference' },
  { name: 'Kontakt',   href: '/kontakt' },
];

const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 inset-x-0 z-[100] bg-white/95 border-b border-zinc-200/50 shadow-[0_4px_30px_rgba(0,0,0,0.04)]" id="main-nav" aria-label="Hlavní navigace">
  <div class="max-w-[1200px] mx-auto px-5 md:px-8 lg:px-12 h-20 md:h-24 flex items-center justify-between">

    <a href="/" class="flex items-center gap-2 group flex-shrink-0 transition-transform duration-300 hover:scale-105 active:scale-95">
      <img
  src="/logo.webp"
  alt="PrimeClean"
  width="2965"
  height="787"
  class="h-9 w-auto drop-shadow-sm"
  onerror="this.style.display='none';this.nextElementSibling.style.display='block';"
/>
      <span style="display:none;" class="text-2xl font-extrabold text-zinc-950 tracking-tighter">Prime<span class="text-[#81b344]">Clean</span></span>
    </a>

    <nav class="hidden md:flex items-center gap-6 lg:gap-8">
      <ul class="flex items-center gap-6 lg:gap-8">
        {navLinks.map(link => {
          const isActive = currentPath === link.href || (currentPath.startsWith(link.href + '/') && link.href !== '/');
          return (
            <li>
              <a href={link.href} class={`text-[14.5px] font-bold transition-colors relative group py-2 ${isActive ? 'text-zinc-950' : 'text-zinc-500 hover:text-zinc-950'}`} {...(isActive ? { 'aria-current': 'page' } : {})}>
                {link.name}
                <span class={`absolute inset-x-0 bottom-0 h-[2px] bg-[#81b344] transition-transform duration-300 origin-left ${isActive ? 'scale-x-100' : 'scale-x-0 group-hover:scale-x-100'}`}></span>
              </a>
            </li>
          );
        })}
      </ul>

      <div class="w-px h-5 bg-zinc-200 mx-1"></div>

      <a href="/kontakt" class="inline-flex items-center justify-center px-6 py-2.5 text-[14px] font-bold text-white transition-all duration-300 bg-[#81b344] rounded-xl shadow-[0_4px_10px_rgba(129,179,68,0.15)] hover:bg-[#6a9438] hover:shadow-[0_8px_20px_rgba(129,179,68,0.3)] hover:-translate-y-0.5 active:scale-95">
        Poptat úklid
      </a>
    </nav>

    <button
      id="mobile-menu-btn"
      class="md:hidden relative w-10 h-10 flex flex-col items-center justify-center gap-[5px] text-zinc-600 hover:text-zinc-950 transition-colors z-50"
      aria-label="Otevřít menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="w-5 h-[2px] bg-current rounded-full transition-all duration-300 origin-center"></span>
      <span class="w-5 h-[2px] bg-current rounded-full transition-all duration-300 origin-center"></span>
      <span class="w-5 h-[2px] bg-current rounded-full transition-all duration-300 origin-center"></span>
    </button>
  </div>

  <div id="mobile-menu" class="absolute top-[100%] left-0 w-full bg-white border-b border-zinc-200/50 shadow-2xl transition-all duration-300 ease-in-out opacity-0 invisible -translate-y-4 md:hidden" inert>
    <div class="px-5 py-6 flex flex-col gap-2">
      {navLinks.map(link => {
        const isActive = currentPath === link.href || (currentPath.startsWith(link.href + '/') && link.href !== '/');
        return (
          <a href={link.href} class={`text-[17px] font-bold py-3 px-4 rounded-xl transition-colors ${isActive ? 'bg-[#81b344]/10 text-[#6a9438]' : 'text-zinc-800 hover:bg-zinc-50 hover:text-[#81b344]'}`} {...(isActive ? { 'aria-current': 'page' } : {})}>
            {link.name}
          </a>
        );
      })}
      <div class="h-px bg-zinc-100 my-3 mx-4"></div>
      <a href="/kontakt" class="mt-2 mx-4 inline-flex items-center justify-center px-6 py-4 text-[16px] font-bold text-white bg-[#81b344] rounded-xl shadow-md active:scale-95 transition-transform hover:bg-[#6a9438]">
        Poptat úklid
      </a>
    </div>
  </div>
</header>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const btn = document.getElementById('mobile-menu-btn') as HTMLButtonElement | null;
    const menu = document.getElementById('mobile-menu') as HTMLElement | null;
    const spans = btn?.querySelectorAll('span');
    let isOpen = false;

    const closeMenu = () => {
      isOpen = false;
      btn?.setAttribute('aria-expanded', 'false');
      btn?.setAttribute('aria-label', 'Otevřít menu');
      menu?.classList.add('opacity-0', 'invisible', '-translate-y-4');
      menu?.setAttribute('inert', '');
      if (spans?.length === 3) {
        (spans[0] as HTMLElement).style.transform = 'none';
        (spans[1] as HTMLElement).style.opacity = '1';
        (spans[2] as HTMLElement).style.transform = 'none';
      }
    };

    const openMenu = () => {
      isOpen = true;
      btn?.setAttribute('aria-expanded', 'true');
      btn?.setAttribute('aria-label', 'Zavřít menu');
      menu?.classList.remove('opacity-0', 'invisible', '-translate-y-4');
      menu?.removeAttribute('inert');
      if (spans?.length === 3) {
        (spans[0] as HTMLElement).style.transform = 'translateY(7px) rotate(45deg)';
        (spans[1] as HTMLElement).style.opacity = '0';
        (spans[2] as HTMLElement).style.transform = 'translateY(-7px) rotate(-45deg)';
      }
    };

    btn?.addEventListener('click', () => {
      isOpen ? closeMenu() : openMenu();
    });

    menu?.querySelectorAll('a').forEach(a => {
      a.addEventListener('click', () => closeMenu());
    });
  });
</script>