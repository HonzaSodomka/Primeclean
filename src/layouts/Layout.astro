---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Profesionální úklid Brno a okolí | PrimeClean',
  ogImage = '/og-image.png',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://primeclean.cz');
const ogImageURL = new URL(ogImage, Astro.site ?? 'https://primeclean.cz').href;

const emailjsPublicKey = import.meta.env.PUBLIC_EMAILJS_PUBLIC_KEY;

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": ["LocalBusiness", "CleaningService"],
  "@id": "https://primeclean.cz/#organization",
  "name": "PrimeClean",
  "description": "Profesionální úklidová firma Brno a okolí. Zajišťujeme pravidelný úklid kanceláří, SVJ, bytových domů a Airbnb apartmánů. Pojištění 5 mil. Kč, prověřený personál, fotoreport po každém úklidu.",
  "url": "https://primeclean.cz",
  "telephone": "+420773102770",
  "email": "info@primeclean.cz",
  "address": {
    "@type": "PostalAddress",
    "postalCode": "602 00",
    "addressLocality": "Brno",
    "addressRegion": "Jihomoravský kraj",
    "addressCountry": "CZ"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 49.1951,
    "longitude": 16.6068
  },
  "areaServed": [
    { "@type": "City", "name": "Brno" },
    { "@type": "AdministrativeArea", "name": "Jihomoravský kraj" }
  ],
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      "opens": "08:00",
      "closes": "20:00"
    }
  ],
  "priceRange": "$$",
  "image": ogImageURL,
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "5.0",
    "reviewCount": "4",
    "bestRating": "5",
    "worstRating": "1"
  },
  "review": [
    {
      "@type": "Review",
      "author": { "@type": "Person", "name": "Anatolij Ramaldan" },
      "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
      "reviewBody": "Jako hostitel na Airbnb potřebuju mít jistotu, že je apartmán vždy perfektně připravený a v naprostém pořádku. PrimeClean to zvládá spolehlivě i na poslední chvíli. Díky fotkám v aplikaci mám klid, i když zrovna nejsem v Brně."
    },
    {
      "@type": "Review",
      "author": { "@type": "Organization", "name": "Autoškola TiGO s.r.o." },
      "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
      "reviewBody": "S touto úklidovou firmou máme velmi dobrou zkušenost. Už přibližně 3 měsíce se starají o čistotu naší kanceláře i učebny a vždy odvedou skvělou práci. Velké plus je komunikace — domluva je vždy rychlá a bez problémů."
    },
    {
      "@type": "Review",
      "author": { "@type": "Person", "name": "Magdalena Kopecká" },
      "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
      "reviewBody": "Konečně úklidovka, co u práce i přemýšlí. Nejen že je všude čisto, ale hlavně nám v jejich appce přistávají fotky a hlášení, když je v baráku něco špatně. Máme o všem přehled dřív, než si začnou lidi stěžovat."
    },
    {
      "@type": "Review",
      "author": { "@type": "Person", "name": "Petr Zeman" },
      "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
      "reviewBody": "Po špatné zkušenosti s nespolehlivou firmou jsem konečně narazil na úklidovou firmu, na kterou je opravdu spoleh. Vše je vždy perfektně uklizené, termíny dodržují a komunikace je bezproblémová."
    }
  ],
  "sameAs": [
    "https://www.instagram.com/primeclean_brno/",
    "https://share.google/T9IQZWtAqGfdk9Iy2",
    "https://www.facebook.com/people/Primeclean/61577959901784/"
  ]
};
---

<!doctype html>
<html lang="cs" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />

    <meta name="robots" content="index, follow" />

    <link rel="canonical" href={canonicalURL} />

    <!-- Preload LCP hero image -->
    <link rel="preload" as="image" href="/hero-image.webp" fetchpriority="high" />

    <!-- Favicony -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- PWA manifest + theme color -->
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#81b344" />

    <title>{title}</title>

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="cs_CZ" />
    <meta property="og:site_name" content="PrimeClean" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- LocalBusiness JSON-LD -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify(localBusinessSchema)}
    />

    <!-- Slot pro stránkově specifické JSON-LD (Service schema z index.astro apod.) -->
    <slot name="head" />

    <!-- Google Fonts — non-blocking load -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
      />
    </noscript>

    <!-- Low-end/reduced-motion detekce — musí být před renderem -->
    <script is:inline>
      (function () {
        var cores = navigator.hardwareConcurrency || 4;
        var ram = navigator.deviceMemory || 4;
        var rm = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (cores <= 2 || ram <= 2 || rm) {
          document.documentElement.classList.add('low-end');
        }
      })();
    </script>

    <!-- EmailJS SDK -->
    <script
      src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js"
      defer
    ></script>

    <!-- env proměnná předaná z frontmatter do inline scriptu -->
    <script is:inline define:vars={{ emailjsPublicKey }}>
      document.addEventListener('DOMContentLoaded', function () {
        if (typeof emailjs !== 'undefined' && emailjsPublicKey) {
          emailjs.init({ publicKey: emailjsPublicKey });
        }
      });
    </script>
  </head>

  <body class="bg-zinc-50 text-zinc-900 antialiased selection:bg-[#81b344]/20 selection:text-[#5a7a2e]">
    <Header />
    <slot />
    <Footer />

    <script
      src="https://unpkg.com/lucide@0.488.0/dist/umd/lucide.min.js"
      defer
    ></script>
    <script is:inline>
      document.addEventListener('DOMContentLoaded', function () {
        if (typeof lucide !== 'undefined') lucide.createIcons();
      });
    </script>
  </body>
</html>