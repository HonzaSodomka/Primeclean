---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Profesionální úklid Brno a okolí | PrimeClean',
  ogImage = '/og-image.jpg',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://www.primeclean.cz');
const ogImageURL   = new URL(ogImage, Astro.site ?? 'https://www.primeclean.cz').href;

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "PrimeClean",
  "description": "Profesionální úklid Brno a okolí — kanceláře, SVJ a Airbnb apartmány.",
  "url": "https://www.primeclean.cz",
  "telephone": "+420773102770",
  "email": "info@primeclean.cz",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Brno",
    "addressRegion": "Jihomoravský kraj",
    "addressCountry": "CZ"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 49.1951,
    "longitude": 16.6068
  },
  "areaServed": [
    { "@type": "City", "name": "Brno" },
    { "@type": "AdministrativeArea", "name": "Jihomoravský kraj" }
  ],
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
      "opens": "08:00",
      "closes": "20:00"
    }
  ],
  "priceRange": "$$",
  "image": ogImageURL,
  "sameAs": []
};
---

<!doctype html>
<html lang="cs" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />

    <meta name="robots" content="index, follow" />

    <link rel="canonical" href={canonicalURL} />

    <!-- Favicony -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- PWA manifest + theme color -->
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#81b344" />

    <title>{title}</title>

    <!-- Open Graph -->
    <meta property="og:type"         content="website" />
    <meta property="og:url"          content={canonicalURL} />
    <meta property="og:title"        content={title} />
    <meta property="og:description"  content={description} />
    <meta property="og:image"        content={ogImageURL} />
    <meta property="og:image:width"  content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale"       content="cs_CZ" />
    <meta property="og:site_name"    content="PrimeClean" />

    <!-- Twitter Card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={ogImageURL} />

    <!-- LocalBusiness JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />

    <!-- Google Fonts — non-blocking load -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" />
    </noscript>

    <!-- Low-end/reduced-motion detekce — musí být před renderem -->
    <script is:inline>
      (function () {
        var cores = navigator.hardwareConcurrency || 4;
        var ram   = navigator.deviceMemory || 4;
        var rm    = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (cores <= 2 || ram <= 2 || rm) {
          document.documentElement.classList.add('low-end');
        }
      })();
    </script>
  </head>

  <body class="bg-zinc-50 text-zinc-900 antialiased selection:bg-[#81b344]/20 selection:text-[#5a7a2e]">
    <Header />
    <slot />
    <Footer />
    <CookieBanner />

    <script
      src="https://unpkg.com/lucide@0.488.0/dist/umd/lucide.min.js"
      defer
    ></script>
    <script is:inline>
      document.addEventListener('DOMContentLoaded', function () {
        if (typeof lucide !== 'undefined') lucide.createIcons();
      });
    </script>
  </body>
</html>