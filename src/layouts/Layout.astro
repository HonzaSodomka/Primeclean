---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="cs" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Profesionální úklid Brno a okolí" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" /></noscript>

    <title>{title}</title>

    <!-- Low-end device detection — synchronně před renderem těla -->
    <script is:inline>
      (function () {
        const cores = navigator.hardwareConcurrency || 4;
        const ram = navigator.deviceMemory || 4;
        const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (cores <= 2 || ram <= 2 || reducedMotion) {
          document.documentElement.classList.add('low-end');
        }
      })();
    </script>
  </head>
  <body class="bg-zinc-50 text-zinc-900 antialiased selection:bg-[#81b344]/20 selection:text-[#5a7a2e]">
    <Header />
    <slot />
    <Footer />
    <CookieBanner />
    <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js" defer></script>
    <script is:inline>
      document.addEventListener('DOMContentLoaded', function () {
        if (typeof lucide !== 'undefined') lucide.createIcons();
      });
    </script>
  </body>
</html>