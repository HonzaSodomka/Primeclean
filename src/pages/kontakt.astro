---
import Layout from '../layouts/Layout.astro';

const contactItems = [
  { label: 'Telefon',         value: '+420 773 102 770',   href: 'tel:+420773102770',         icon: 'phone'   },
  { label: 'E-mail',          value: 'info@primeclean.cz', href: 'mailto:info@primeclean.cz', icon: 'mail'    },
  { label: 'Pracovní doba',   value: 'Po–Pá, 8:00–20:00', href: null,                        icon: 'clock'   },
  { label: 'Oblast působení', value: 'Brno a okolí',       href: null,                        icon: 'map-pin' },
];

const services = [
  { value: 'kancelare', label: 'Kanceláře a firmy'  },
  { value: 'svj',       label: 'SVJ a bytové domy'  },
  { value: 'airbnb',    label: 'Airbnb a apartmány' },
  { value: 'jine',      label: 'Jiné / Nevím ještě' },
];

const sidebarPerks = [
  { title: 'Odpověď do 1 pracovního dne',  desc: 'Ozveme se s konkrétním návrhem, ne obecnou nabídkou.' },
  { title: 'Prohlídka objektu zdarma',     desc: 'Přijedeme na místo a připravíme nacenění na míru.'    },
  { title: 'Jasná smlouva bez překvapení', desc: 'Rozsah, cena i podmínky — vše domluvné předem.'       },
];

const trustBadges = [
  { label: 'Pojištění 5 mil. Kč',    icon: 'shield-check' },
  { label: 'Prověřený personál',     icon: 'user-check'   },
  { label: 'Fotoreport po úklidu',   icon: 'camera'       },
  { label: 'Pravidelný harmonogram', icon: 'clock'        },
];
---

<Layout
  title="Kontakt — Nezávazná poptávka úklidu Brno | PrimeClean"
  description="Poptejte úklid kanceláří, SVJ nebo Airbnb v Brně. Odpovíme do 1 pracovního dne, prohlídka a nacenění zdarma. Bez DPH, bez překvapení."
>
  <main class="bg-white selection:bg-[#81b344]/30 selection:text-zinc-900">

    <section class="pt-28 md:pt-36 pb-16 md:pb-20 lg:pb-28 bg-white">
      <div class="max-w-[1100px] mx-auto px-5 md:px-8 lg:px-12">
        <div class="grid lg:grid-cols-[1fr_380px] gap-9 xl:gap-14 items-start">

          <!-- FORM -->
          <div class="scroll-animate opacity-0">
            <div class="mb-8">
              <p class="text-[12px] font-bold text-[#81b344] tracking-[0.2em] uppercase mb-3">Kontaktní formulář</p>
              <h1 class="fluid-h1 font-extrabold text-zinc-950 tracking-tighter leading-[1.1] mb-3">
                Napište nám.<br /><span class="text-[#6a9438]">Ozveme se brzy.</span>
              </h1>
              <p class="text-[14px] md:text-[15px] text-zinc-600 font-medium leading-relaxed max-w-xl">
                Vyplňte formulář a dostanete konkrétní nabídku na míru. Bez závazků, bez skrytých poplatků.
              </p>
            </div>

            <form id="contact-form" novalidate class="flex flex-col gap-5">

              <div class="grid sm:grid-cols-2 gap-5">
                <div class="flex flex-col gap-1.5">
                  <label for="name" class="field-label">Jméno a příjmení <span class="text-[#81b344]" aria-hidden="true">*</span></label>
                  <input type="text" id="name" name="name" placeholder="Tomáš Novák" required class="field-input" autocomplete="name" />
                </div>
                <div class="flex flex-col gap-1.5">
                  <label for="company" class="field-label">Firma / Organizace</label>
                  <input type="text" id="company" name="company" placeholder="Např. SVJ Mánesova 12" class="field-input" autocomplete="organization" />
                </div>
              </div>

              <div class="grid sm:grid-cols-2 gap-5">
                <div class="flex flex-col gap-1.5">
                  <label for="email" class="field-label">E-mail <span class="text-[#81b344]" aria-hidden="true">*</span></label>
                  <input type="email" id="email" name="email" placeholder="vas@email.cz" required class="field-input" autocomplete="email" />
                </div>
                <div class="flex flex-col gap-1.5">
                  <label for="phone" class="field-label">Telefon <span class="text-[#81b344]" aria-hidden="true">*</span></label>
                  <input type="tel" id="phone" name="phone" placeholder="+420 777 123 456" required class="field-input" autocomplete="tel" />
                </div>
              </div>

              <div class="flex flex-col gap-1.5">
                <label for="service" class="field-label">Typ služby <span class="text-[#81b344]" aria-hidden="true">*</span></label>
                <div class="relative">
                  <select id="service" name="service" required class="field-input w-full appearance-none cursor-pointer pr-12">
                    <option value="" disabled selected>Vyberte typ služby</option>
                    {services.map(s => <option value={s.value}>{s.label}</option>)}
                  </select>
                  <i data-lucide="chevron-down" class="pointer-events-none absolute right-4 top-1/2 -translate-y-1/2 w-4 h-4 text-zinc-400" style="stroke-width:2.5" aria-hidden="true"></i>
                </div>
              </div>

              <div class="flex flex-col gap-1.5">
                <label for="message" class="field-label">Popis objektu / Zpráva</label>
                <textarea id="message" name="message" rows="4" placeholder="Popište nám váš objekt — např. bytový dům, 24 bytů, úklid 2× týdně, Brno-Královo Pole…" class="field-input resize-none"></textarea>
              </div>

              <div class="flex flex-col sm:flex-row sm:items-center gap-3 pt-1">
                <button type="submit" id="submit-btn" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-8 py-3.5 text-[15px] font-bold text-white bg-[#81b344] rounded-xl hover:bg-[#6a9438] hover:-translate-y-1 shadow-md shadow-[#81b344]/20 transition-all duration-300 ease-out disabled:opacity-60 disabled:cursor-not-allowed disabled:translate-y-0">
                  <span id="btn-text">Odeslat poptávku</span>
                  <i id="btn-icon" data-lucide="arrow-right" class="w-4 h-4" aria-hidden="true"></i>
                  <i id="btn-spinner" data-lucide="loader-circle" class="hidden w-4 h-4 animate-spin" aria-hidden="true"></i>
                </button>
                <p class="text-[12px] text-zinc-400 font-medium leading-relaxed">
                  Odeslaním souhlasíte se <a href="/gdpr" class="underline hover:text-zinc-600 transition-colors">zpracováním<br class="hidden sm:block" /> osobních údajů</a> za účelem odpovědi.
                </p>
              </div>

            </form>

            <div id="form-success" class="hidden">
              <div class="flex flex-col items-center text-center py-14 gap-5">
                <div class="w-16 h-16 rounded-full bg-[#81b344]/10 border border-[#81b344]/20 flex items-center justify-center">
                  <i data-lucide="check" class="w-8 h-8 text-[#81b344]" style="stroke-width:2.5" aria-hidden="true"></i>
                </div>
                <div>
                  <p class="text-[22px] font-extrabold text-zinc-950 tracking-tight mb-1.5">Odesláno, díky!</p>
                  <p class="text-[15px] text-zinc-500 font-medium">Ozveme se vám do jednoho pracovního dne.</p>
                </div>
                <a href="/" class="inline-flex items-center gap-2 px-7 py-3.5 text-[14px] font-bold text-zinc-700 bg-white border-2 border-zinc-200 rounded-xl hover:border-zinc-300 hover:bg-zinc-50 hover:-translate-y-1 transition-all duration-300 ease-out">
                  Zpět na hlavní stránku
                  <i data-lucide="arrow-right" class="w-4 h-4" aria-hidden="true"></i>
                </a>
              </div>
            </div>
          </div>

          <!-- SIDEBAR -->
          <aside class="flex flex-col gap-5 lg:sticky lg:top-28">

            <div class="scroll-animate opacity-0 bg-zinc-100 rounded-[1.75rem] p-6 border border-zinc-200" style="animation-delay:150ms">
              <div class="flex items-center gap-3.5 mb-5">
                <div class="relative flex-shrink-0 w-12 h-12 rounded-full overflow-hidden border-2 border-[#81b344]/30 bg-zinc-300">
                  <img src="/tomas-kytka.webp" alt="Tomáš Kytka, zakladatel PrimeClean Brno" width="48" height="48" class="w-full h-full object-cover object-top" loading="lazy" decoding="async" />
                </div>
                <div>
                  <p class="text-[15px] font-extrabold text-zinc-900 leading-tight">Tomáš Kytka</p>
                  <p class="text-[11px] font-bold text-zinc-500 uppercase tracking-[0.08em] mt-0.5">Zakladatel PrimeClean</p>
                </div>
              </div>
              <p class="text-[14px] text-zinc-600 font-medium leading-relaxed">
                „Rád se s vámi sejdu osobně a probereme potřeby přímo na místě. Bez závazků, bez zbytečného papírování."
              </p>
            </div>

            <div class="scroll-animate opacity-0" style="animation-delay:250ms">
              <div class="bg-zinc-50 rounded-[1.75rem] p-6 border border-zinc-100">
                <p class="text-[11px] font-bold text-[#81b344] tracking-[0.2em] uppercase mb-5">Co vás čeká</p>
                <ul class="flex flex-col gap-4" role="list">
                  {sidebarPerks.map(item => (
                    <li class="flex gap-3.5">
                      <span class="flex-shrink-0 mt-0.5 w-5 h-5 rounded-full bg-[#81b344] flex items-center justify-center text-zinc-950" aria-hidden="true">
                        <i data-lucide="check" class="w-3 h-3" style="stroke-width:3.5"></i>
                      </span>
                      <div>
                        <p class="text-[14px] font-bold text-zinc-950 tracking-tight leading-snug mb-0.5">{item.title}</p>
                        <p class="text-[12.5px] font-medium text-zinc-500 leading-relaxed">{item.desc}</p>
                      </div>
                    </li>
                  ))}
                </ul>
              </div>
            </div>

            <div class="scroll-animate opacity-0 grid grid-cols-2 gap-2.5" style="animation-delay:350ms">
              {trustBadges.map(badge => (
                <div class="flex flex-col items-start gap-2.5 p-4 bg-zinc-50 rounded-2xl border border-zinc-100 hover:border-[#81b344]/20 hover:bg-white hover:shadow-sm transition-all duration-200">
                  <i data-lucide={badge.icon} class="w-4 h-4 text-[#81b344]" aria-hidden="true"></i>
                  <span class="text-[12.5px] font-bold text-zinc-800 leading-snug">{badge.label}</span>
                </div>
              ))}
            </div>

          </aside>
        </div>
      </div>
    </section>

    <!-- KONTAKTNÍ PRUH -->
    <section class="bg-[#81b344] py-10 md:py-12">
      <div class="max-w-[1100px] mx-auto px-5 md:px-8 lg:px-12">
        <div class="scroll-animate opacity-0 grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-0 md:divide-x md:divide-white/20">
          {contactItems.map(item => (
            <div class="flex flex-col gap-1.5 md:px-7 first:pl-0 last:pr-0">
              <span class="text-[10px] font-bold text-white/60 uppercase tracking-[0.12em]">{item.label}</span>
              {item.href ? (
                <a href={item.href} class="text-[15px] font-bold text-white underline decoration-white/30 underline-offset-2 hover:decoration-white transition-colors">{item.value}</a>
              ) : (
                <span class="text-[15px] font-bold text-white/70">{item.value}</span>
              )}
            </div>
          ))}
        </div>
      </div>
    </section>

  </main>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // ── EmailJS init ──────────────────────────────────────────────

    const isLowEnd = document.documentElement.classList.contains('low-end');

    if (isLowEnd) {
      document.querySelectorAll<HTMLElement>('.opacity-0').forEach(el => {
        el.style.opacity = '1';
        el.style.transform = 'none';
        el.style.animation = 'none';
        el.classList.remove('opacity-0');
      });
    } else {
      const observer = new IntersectionObserver(
        entries => entries.forEach(entry => {
          if (!entry.isIntersecting) return;
          entry.target.classList.add('animate-fade-in-up');
          entry.target.classList.remove('opacity-0');
          observer.unobserve(entry.target);
        }),
        { threshold: 0, rootMargin: '0px 0px -5% 0px' },
      );
      document.querySelectorAll('.scroll-animate').forEach(el => observer.observe(el));
    }

    const form       = document.getElementById('contact-form')  as HTMLFormElement | null;
    const success    = document.getElementById('form-success')  as HTMLElement | null;
    const submitBtn  = document.getElementById('submit-btn')    as HTMLButtonElement | null;
    const btnText    = document.getElementById('btn-text')      as HTMLElement | null;
    const btnIcon    = document.getElementById('btn-icon')      as HTMLElement | null;
    const btnSpinner = document.getElementById('btn-spinner')   as HTMLElement | null;

    if (!form || !success || !submitBtn || !btnText) return;

    form.querySelectorAll<HTMLElement>('input, select, textarea').forEach(field => {
      field.addEventListener('input', () => field.classList.remove('field-error'));
    });

    form.addEventListener('submit', async e => {
      e.preventDefault();

      let valid = true;
      form.querySelectorAll<HTMLInputElement | HTMLSelectElement>('[required]').forEach(field => {
        field.classList.remove('field-error');
        if (!field.value.trim() || (field.tagName === 'SELECT' && field.value === '')) {
          field.classList.add('field-error');
          valid = false;
        }
      });
      if (!valid) return;

      submitBtn.disabled = true;
      btnText.textContent = 'Odesílám…';
      btnIcon?.classList.add('hidden');
      btnSpinner?.classList.remove('hidden');

      try {
        await (window as any).emailjs.send(
          import.meta.env.PUBLIC_EMAILJS_SERVICE_ID,
          import.meta.env.PUBLIC_EMAILJS_TEMPLATE_ID,
          {
            from_name:    (document.getElementById('name')    as HTMLInputElement).value,
            company:      (document.getElementById('company') as HTMLInputElement).value,
            from_email:   (document.getElementById('email')   as HTMLInputElement).value,
            phone:        (document.getElementById('phone')   as HTMLInputElement).value,
            service_type: (document.getElementById('service') as HTMLSelectElement).value,
            message:      (document.getElementById('message') as HTMLTextAreaElement).value,
          }
        );

        form.classList.add('hidden');
        success.classList.remove('hidden');

      } catch (err) {
        console.error('EmailJS error:', err);
        btnText.textContent = 'Odeslání selhalo, zkuste znovu';
        btnIcon?.classList.remove('hidden');
        btnSpinner?.classList.add('hidden');
        submitBtn.disabled = false;
      }
    });
  });
</script>

<style>
  .fluid-h1 { font-size: clamp(2rem, 4.5vw, 4.5rem); }

  @keyframes softFadeUp {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in-up {
    animation: softFadeUp 0.75s cubic-bezier(0.25, 1, 0.4, 1) both;
  }
  @keyframes spin {
    to { transform: rotate(360deg); }
  }
  .animate-spin {
    animation: spin 0.8s linear infinite;
  }

  .field-label {
    font-size: 12px;
    font-weight: 700;
    color: rgb(63 63 70);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .field-input {
    width: 100%;
    padding: 0.875rem 1.125rem;
    border-radius: 0.875rem;
    border: 1px solid rgb(228 228 231);
    background-color: rgb(250 250 250);
    font-size: 14px;
    font-weight: 500;
    color: rgb(9 9 11);
    outline: none;
    transition: background-color 200ms, border-color 200ms, box-shadow 200ms;
  }
  .field-input::placeholder { color: rgb(161 161 170); }
  .field-input:focus {
    background-color: #fff;
    border-color: #81b344;
    box-shadow: 0 0 0 4px rgb(129 179 68 / 0.1);
  }
  .field-error {
    border-color: rgb(248 113 113) !important;
    box-shadow: 0 0 0 4px rgb(248 113 113 / 0.1) !important;
    background-color: rgb(254 242 242) !important;
  }

  @media (prefers-reduced-motion: reduce) {
    .animate-fade-in-up,
    .scroll-animate {
      animation: none !important;
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
    .animate-pulse,
    .animate-spin { animation: none !important; }
  }

  :global(.low-end) .animate-fade-in-up,
  :global(.low-end) .scroll-animate,
  :global(.low-end) .opacity-0 {
    animation: none !important;
    opacity: 1 !important;
    transform: none !important;
  }
  :global(.low-end) .animate-pulse,
  :global(.low-end) .animate-spin { animation: none !important; }
  :global(.low-end) img            { transition: none !important; }
</style>