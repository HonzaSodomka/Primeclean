---
import Layout from '../layouts/Layout.astro';

const trustPoints = [
  'Odpovíme do 1 pracovního dne',
  'Nezávazná prohlídka objektu zdarma',
  'Nabídka na míru bez skrytých poplatků',
];

const contactItems = [
  { label: 'Telefon',         value: '+420 773 102 770',   href: 'tel:+420773102770',         icon: 'phone'    },
  { label: 'E-mail',          value: 'info@primeclean.cz', href: 'mailto:info@primeclean.cz', icon: 'mail'     },
  { label: 'Pracovní doba',   value: 'Po–Pá, 8:00–20:00', href: null,                        icon: 'clock'    },
  { label: 'Oblast působení', value: 'Brno a okolí',      href: null,                        icon: 'map-pin'  },
];

const services = [
  { value: 'kancelare', label: 'Kanceláře a firmy'    },
  { value: 'svj',       label: 'SVJ a bytové domy'    },
  { value: 'airbnb',    label: 'Airbnb a apartmány'   },
  { value: 'jine',      label: 'Jiné / Nevím ještě'   },
];

const sidebarPerks = [
  { title: 'Odpověď do 24 hodin',          desc: 'Ozveme se s konkrétním návrhem, ne obecnou nabídkou.' },
  { title: 'Prohlídka objektu zdarma',     desc: 'Přijedeme na místo a připravíme nacenění na míru.'    },
  { title: 'Jasná smlouva bez překvapení', desc: 'Rozsah, cena i podmínky — vše domluvné předem.'     },
];

const trustBadges = [
  { label: 'Pojištění 5 mil. Kč',    icon: 'shield-check' },
  { label: 'Prověřený personál',     icon: 'user-check'   },
  { label: 'Fotoreport po úklidu',   icon: 'camera'       },
  { label: 'Pravidelný harmonogram', icon: 'clock'        },
];
---

<Layout title="Kontakt | PrimeClean">
  <main class="bg-white selection:bg-[#81b344]/30 selection:text-zinc-900">

    <!-- ─── FORM + SIDEBAR ─────────────────────────────────────────────────────── -->
    <section class="pt-36 md:pt-44 pb-20 md:pb-32 bg-white">
      <div class="max-w-[1200px] mx-auto px-5 md:px-8 lg:px-12">
        <div class="grid lg:grid-cols-[1fr_400px] gap-10 xl:gap-16 items-start">

          <!-- FORM -->
          <div class="scroll-animate opacity-0">
            <div class="mb-10">
              <p class="text-[13px] font-bold text-[#81b344] tracking-[0.2em] uppercase mb-4">Kontaktní formulář</p>
              <h2 class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-zinc-950 tracking-tighter leading-[1.1] mb-4">
                Napište nám.<br /><span class="text-[#6a9438]">Ozveme se brzy.</span>
              </h2>
              <p class="text-lg text-zinc-600 font-medium leading-relaxed max-w-xl">
                Vyplňte formulář a dostanete konkrétní nabídku na míru. Bez závazků, bez skrytých poplatků.
              </p>
            </div>

            <form id="contact-form" novalidate class="flex flex-col gap-6">

              <div class="grid sm:grid-cols-2 gap-6">
                <div class="flex flex-col gap-2">
                  <label for="name" class="field-label">Jméno a příjmení <span class="text-[#81b344]" aria-hidden="true">*</span></label>
                  <input type="text" id="name" name="name" placeholder="Tomáš Novák" required class="field-input" autocomplete="name" />
                </div>
                <div class="flex flex-col gap-2">
                  <label for="company" class="field-label">Firma / Organizace</label>
                  <input type="text" id="company" name="company" placeholder="Např. SVJ Mánesova 12" class="field-input" autocomplete="organization" />
                </div>
              </div>

              <div class="grid sm:grid-cols-2 gap-6">
                <div class="flex flex-col gap-2">
                  <label for="email" class="field-label">E-mail <span class="text-[#81b344]" aria-hidden="true">*</span></label>
                  <input type="email" id="email" name="email" placeholder="vas@email.cz" required class="field-input" autocomplete="email" />
                </div>
                <div class="flex flex-col gap-2">
                  <label for="phone" class="field-label">Telefon <span class="text-[#81b344]" aria-hidden="true">*</span></label>
                  <input type="tel" id="phone" name="phone" placeholder="+420 777 123 456" required class="field-input" autocomplete="tel" />
                </div>
              </div>

              <div class="flex flex-col gap-2">
                <label for="service" class="field-label">Typ služby <span class="text-[#81b344]" aria-hidden="true">*</span></label>
                <div class="relative">
                  <select id="service" name="service" required class="field-input w-full appearance-none cursor-pointer">
                    <option value="" disabled selected>Vyberte typ služby</option>
                    {services.map(s => <option value={s.value}>{s.label}</option>)}
                  </select>
                  <i data-lucide="chevron-down" class="pointer-events-none absolute right-5 top-1/2 -translate-y-1/2 w-[18px] h-[18px] text-zinc-400" style="stroke-width:2.5" aria-hidden="true"></i>
                </div>
              </div>

              <div class="flex flex-col gap-2">
                <label for="message" class="field-label">Popis objektu / Zpráva</label>
                <textarea id="message" name="message" rows="4" placeholder="Popište nám váš objekt — např. bytový dům, 24 bytů, úklid 2× týdně, Brno-Královo Pole…" class="field-input resize-none"></textarea>
              </div>

              <div class="flex flex-col sm:flex-row sm:items-center gap-4 pt-2">
                <button type="submit" id="submit-btn" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-10 py-4 text-[16px] font-bold text-white bg-[#81b344] rounded-xl hover:bg-[#729f3c] hover:-translate-y-1 shadow-md shadow-[#81b344]/20 transition-all duration-300 ease-out disabled:opacity-60 disabled:cursor-not-allowed disabled:translate-y-0">
                  <span id="btn-text">Odeslat poptávku</span>
                  <i id="btn-icon" data-lucide="arrow-right" class="w-4 h-4" aria-hidden="true"></i>
                  <i id="btn-spinner" data-lucide="loader-circle" class="hidden w-4 h-4 animate-spin" aria-hidden="true"></i>
                </button>
                <p class="text-[12.5px] text-zinc-400 font-medium leading-relaxed">
                  Odeslaním souhlasíte se zpracováním<br class="hidden sm:block" /> osobních údajů za účelem odpovědi.
                </p>
              </div>

            </form>

            <div id="form-success" class="hidden">
              <div class="flex flex-col items-center text-center py-16 gap-6">
                <div class="w-20 h-20 rounded-full bg-[#81b344]/10 border border-[#81b344]/20 flex items-center justify-center">
                  <i data-lucide="check" class="w-9 h-9 text-[#81b344]" style="stroke-width:2.5" aria-hidden="true"></i>
                </div>
                <div>
                  <p class="text-[24px] font-extrabold text-zinc-950 tracking-tight mb-2">Odesláno, díky!</p>
                  <p class="text-[16px] text-zinc-500 font-medium">Ozveme se vám do jednoho pracovního dne.</p>
                </div>
                <a href="/" class="inline-flex items-center gap-2 px-8 py-3.5 text-[15px] font-bold text-zinc-700 bg-white border-2 border-zinc-200 rounded-xl hover:border-zinc-300 hover:bg-zinc-50 hover:-translate-y-1 transition-all duration-300 ease-out">
                  Zpět na hlavní stránku
                  <i data-lucide="arrow-right" class="w-4 h-4" aria-hidden="true"></i>
                </a>
              </div>
            </div>
          </div>

          <!-- SIDEBAR -->
          <aside class="flex flex-col gap-6 lg:sticky lg:top-28">

            <!-- Karta zakladatele -->
            <div class="scroll-animate opacity-0 bg-zinc-100 rounded-[2rem] p-8 border border-zinc-200" style="animation-delay:150ms">
              <div class="flex items-center gap-4 mb-6">
                <div class="relative flex-shrink-0 w-14 h-14 rounded-full overflow-hidden border-2 border-[#81b344]/30 bg-zinc-300">
                  <img src="/tomas-kytka.jpg" alt="Tomáš Kytka, zakladatel PrimeClean" width="56" height="56" class="w-full h-full object-cover object-top" loading="lazy" decoding="async" />
                </div>
                <div>
                  <p class="text-[16px] font-extrabold text-zinc-900 leading-tight">Tomáš Kytka</p>
                  <p class="text-[12px] font-bold text-zinc-500 uppercase tracking-[0.08em] mt-0.5">Zakladatel PrimeClean</p>
                </div>
              </div>
              <p class="text-[15px] text-zinc-600 font-medium leading-relaxed mb-6">
                „Rád se s vámi sejdu osobně a probereme potřeby přímo na místě. Bez závazků, bez zbytečného papírování“
              </p>
              <div class="flex items-center gap-2.5 pt-6 border-t border-zinc-200">
                <span class="w-1.5 h-1.5 rounded-full bg-[#81b344] flex-shrink-0"></span>
                <span class="text-[13px] font-semibold text-zinc-500">Průměrná odpověď do <span class="text-[#81b344] font-bold">4 hodin</span></span>
              </div>
            </div>

            <!-- Co vás čeká -->
            <div class="scroll-animate opacity-0" style="animation-delay:250ms">
              <div class="bg-zinc-50 rounded-[2rem] p-8 border border-zinc-100">
                <p class="text-[13px] font-bold text-[#81b344] tracking-[0.2em] uppercase mb-6">Co vás čeká</p>
                <ul class="flex flex-col gap-5" role="list">
                  {sidebarPerks.map(item => (
                    <li class="flex gap-4">
                      <span class="flex-shrink-0 mt-0.5 w-6 h-6 rounded-full bg-[#81b344] flex items-center justify-center text-zinc-950" aria-hidden="true">
                        <i data-lucide="check" class="w-3 h-3" style="stroke-width:3.5"></i>
                      </span>
                      <div>
                        <p class="text-[15px] font-bold text-zinc-950 tracking-tight leading-snug mb-1">{item.title}</p>
                        <p class="text-[13.5px] font-medium text-zinc-500 leading-relaxed">{item.desc}</p>
                      </div>
                    </li>
                  ))}
                </ul>
              </div>
            </div>

            <!-- Trust badges -->
            <div class="scroll-animate opacity-0 grid grid-cols-2 gap-3" style="animation-delay:350ms">
              {trustBadges.map(badge => (
                <div class="flex flex-col items-start gap-3 p-5 bg-zinc-50 rounded-2xl border border-zinc-100 hover:border-[#81b344]/20 hover:bg-white hover:shadow-sm transition-all duration-200">
                  <i data-lucide={badge.icon} class="w-5 h-5 text-[#81b344]" aria-hidden="true"></i>
                  <span class="text-[13.5px] font-bold text-zinc-800 leading-snug">{badge.label}</span>
                </div>
              ))}
            </div>

          </aside>
        </div>
      </div>
    </section>

    <section class="bg-[#81b344] py-12 md:py-14">
  <div class="max-w-[1200px] mx-auto px-5 md:px-8 lg:px-12">
    <div class="scroll-animate opacity-0 grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-0 md:divide-x md:divide-white/20">
      {contactItems.map(item => (
        <div class="flex flex-col gap-2 md:px-8 first:pl-0 last:pr-0">
          <span class="text-[11px] font-bold text-white/60 uppercase tracking-[0.12em]">{item.label}</span>
          {item.href ? (
            <a href={item.href} class="text-[16px] font-bold text-white underline decoration-white/30 underline-offset-2 hover:decoration-white transition-colors">{item.value}</a>
          ) : (
            <span class="text-[16px] font-bold text-white">{item.value}</span>
          )}
        </div>
      ))}
    </div>
  </div>
</section>

  </main>
</Layout>

<script>
  // low-end detection is already handled in Layout.astro — no duplicate needed here

  document.addEventListener('DOMContentLoaded', () => {
    const isLowEnd = document.documentElement.classList.contains('low-end');

    if (isLowEnd) {
      document.querySelectorAll<HTMLElement>('.opacity-0').forEach(el => {
        el.style.opacity = '1';
        el.style.transform = 'none';
        el.style.animation = 'none';
        el.classList.remove('opacity-0');
      });
    } else {
      const observer = new IntersectionObserver(
        entries => entries.forEach(entry => {
          if (!entry.isIntersecting) return;
          entry.target.classList.add('animate-fade-in-up');
          entry.target.classList.remove('opacity-0');
          observer.unobserve(entry.target);
        }),
        { threshold: 0, rootMargin: '0px 0px -5% 0px' },
      );
      document.querySelectorAll('.scroll-animate').forEach(el => observer.observe(el));
    }

    const form       = document.getElementById('contact-form')  as HTMLFormElement | null;
    const success    = document.getElementById('form-success')  as HTMLElement | null;
    const submitBtn  = document.getElementById('submit-btn')    as HTMLButtonElement | null;
    const btnText    = document.getElementById('btn-text')      as HTMLElement | null;
    const btnIcon    = document.getElementById('btn-icon')      as HTMLElement | null;
    const btnSpinner = document.getElementById('btn-spinner')   as HTMLElement | null;

    if (!form || !success || !submitBtn || !btnText) return;

    form.querySelectorAll<HTMLElement>('input, select, textarea').forEach(field => {
      field.addEventListener('input', () => field.classList.remove('field-error'));
    });

    form.addEventListener('submit', async e => {
      e.preventDefault();

      let valid = true;
      form.querySelectorAll<HTMLInputElement | HTMLSelectElement>('[required]').forEach(field => {
        field.classList.remove('field-error');
        if (!field.value.trim() || (field.tagName === 'SELECT' && field.value === '')) {
          field.classList.add('field-error');
          valid = false;
        }
      });
      if (!valid) return;

      submitBtn.disabled = true;
      btnText.textContent = 'Odesílám…';
      btnIcon?.classList.add('hidden');
      btnSpinner?.classList.remove('hidden');

      // TODO: nahrad skutečným fetch() na backend / Formspree / Netlify Forms
      await new Promise(resolve => setTimeout(resolve, 900));

      form.classList.add('hidden');
      success.classList.remove('hidden');
    });
  });
</script>

<style>
  /* ── Animations ───────────────────────────────────────────────────── */
  @keyframes softFadeUp {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in-up {
    animation: softFadeUp 0.75s cubic-bezier(0.25, 1, 0.4, 1) both;
  }
  @keyframes spin {
    to { transform: rotate(360deg); }
  }
  .animate-spin {
    animation: spin 0.8s linear infinite;
  }

  /* ── Field component styles ───────────────────────────────────────── */
  .field-label {
    font-size: 13px;
    font-weight: 700;
    color: rgb(63 63 70);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .field-input {
    width: 100%;
    padding: 1rem 1.25rem;
    border-radius: 1rem;
    border: 1px solid rgb(228 228 231);
    background-color: rgb(250 250 250);
    font-size: 15px;
    font-weight: 500;
    color: rgb(9 9 11);
    outline: none;
    transition: background-color 200ms, border-color 200ms, box-shadow 200ms;
  }
  .field-input::placeholder { color: rgb(161 161 170); }
  .field-input:focus {
    background-color: #fff;
    border-color: #81b344;
    box-shadow: 0 0 0 4px rgb(129 179 68 / 0.1);
  }
  .field-error {
    border-color: rgb(248 113 113) !important;
    box-shadow: 0 0 0 4px rgb(248 113 113 / 0.1) !important;
    background-color: rgb(254 242 242) !important;
  }

  /* ── Reduced motion ─────────────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .animate-fade-in-up, .scroll-animate {
      animation: none !important;
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
    .animate-pulse, .animate-spin { animation: none !important; }
  }

  /* ── Low-end device overrides ────────────────────────────────────── */
  :global(.low-end) .animate-fade-in-up,
  :global(.low-end) .scroll-animate,
  :global(.low-end) .opacity-0 {
    animation: none !important;
    opacity: 1 !important;
    transform: none !important;
  }
  :global(.low-end) .animate-pulse,
  :global(.low-end) .animate-spin { animation: none !important; }
  :global(.low-end) img            { transition: none !important; }
</style>
