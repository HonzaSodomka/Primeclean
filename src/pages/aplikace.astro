---
import Layout from '../layouts/Layout.astro';

const arrowRight = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>';
const arrowRightLg = '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>';
const checkIcon = '<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';

const icons: Record<string, string> = {
  'calendar-clock': '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 7.5V6a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h3.5"/><path d="M16 2v4"/><path d="M8 2v4"/><path d="M3 10h5"/><path d="M17.5 17.5 16 16.3V14"/><circle cx="16" cy="16" r="6"/></svg>',
  'list-checks':    '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 17 2 2 4-4"/><path d="m3 7 2 2 4-4"/><path d="M13 6h8"/><path d="M13 12h8"/><path d="M13 18h8"/></svg>',
  'receipt':        '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 2v20l2-1 2 1 2-1 2 1 2-1 2 1 2-1 2 1V2l-2 1-2-1-2 1-2-1-2 1-2-1-2 1Z"/><path d="M14 8H8"/><path d="M16 12H8"/><path d="M13 16H8"/></svg>',
  'camera':         '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/><circle cx="12" cy="13" r="3"/></svg>',
  'layout-dashboard':'<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="7" height="9" x="3" y="3" rx="1"/><rect width="7" height="5" x="14" y="3" rx="1"/><rect width="7" height="9" x="14" y="12" rx="1"/><rect width="7" height="5" x="3" y="16" rx="1"/></svg>',
  'key-round':      '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 18v3c0 .6.4 1 1 1h4v-3h3v-3h2l1.4-1.4a6.5 6.5 0 1 0-4-4Z"/><circle cx="16.5" cy="7.5" r=".5" fill="currentColor"/></svg>',
  'file-text':      '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>',
  'alert-circle':   '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" x2="12" y1="8" y2="12"/><line x1="12" x2="12.01" y1="16" y2="16"/></svg>',
  'bell':           '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/></svg>',
  'building-2':     '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"/><path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"/><path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"/><path d="M10 6h4"/><path d="M10 10h4"/><path d="M10 14h4"/><path d="M10 18h4"/></svg>',
};

const featureBlocks = [
  {
    id: 'rezervace',
    tag: 'Správa a rezervace',
    headline: 'Objednat úklid?\nPár kliknutí.',
    sub: 'Vytvořte požadavek na úklid pro konkrétní objekt s preferovaným datem, časem a vlastním popisem. Všechny nadcházející i proběhlé úklidy máte přehledně na jednom místě.',
    icon: 'calendar-clock',
    dark: false,
    items: [
      { icon: 'calendar-clock', title: 'Jednoduché objednání',  desc: 'Nový požadavek na úklid pro konkrétní objekt — vyberete datum, čas a přidáte vlastní popis. Žádné telefonáty.' },
      { icon: 'list-checks',    title: 'Přehled termínů',        desc: 'Vidíte seznam nadcházejících úklidů a jejich aktuální stav — např. „Probíhá“ nebo „Dokončeno“.' },
      { icon: 'file-text',      title: 'Historie služeb',          desc: 'Kompletní archiv všech proběhlých úklidů filtrovatelný podle měsíců. Vždy přehled zpětně i dopředu.' },
    ],
  },
  {
    id: 'zakazy',
    tag: 'Detailní zakázky',
    headline: 'Pracovníci vědí přesně,\nco a jak.',
    sub: 'Vložte instrukce pro personál, bezpečně sdílejte přístupové kódy a sledujte jaké konkrétní práce byly při každém úklidu provedeny. Žádné dohady, jen jasná fakta.',
    icon: 'list-checks',
    dark: true,
    items: [
      { icon: 'key-round',      title: 'Instrukce a přístup',      desc: 'Přesné instrukce pro personál a bezpečné sdílení přístupových údajů — kódy k zámkům, umístění klíčů.' },
      { icon: 'list-checks',    title: 'Checklist úkolů',          desc: 'Transparentní přehled provedených prací: vysávání, utírání prachu, výměna prádla, doplnění hygienických potřeb.' },
      { icon: 'alert-circle',   title: 'Speciální požadavky',      desc: 'Přidejte poznámku s extra úkoly pro konkrétní návštěvu — kontrola žárovek, zalití květin nebo cokoliv navíc.' },
    ],
  },
  {
    id: 'finance',
    tag: 'Finance a administrativa',
    headline: 'Faktury a vypřítování\npřehledně na jednom místě.',
    sub: 'Detailní rozpis ceny za každou zakázku, přístup ke všem fakturám a daňovým dokladům. Přepínání mezi soukromým a firemním profilem jedním kliknutím.',
    icon: 'receipt',
    dark: false,
    items: [
      { icon: 'receipt',        title: 'Detailní vyúčtování',      desc: 'Rozpis ceny za úklid, použitý materiál i případné vícepráce. Více za co přesně platíte.' },
      { icon: 'file-text',      title: 'Správa faktur',             desc: 'Samostatná sekce pro přístup ke všem fakturám a daňovým dokladům. Kdykoliv, z mobilu i počítače.' },
      { icon: 'list-checks',    title: 'Odpis materiálu',           desc: 'Přehled o spotřebovaném zboží s množstvím a cenou — toaletní papír, útovací prostředky a další.' },
      { icon: 'building-2',     title: 'Fakturační údaje',           desc: 'Snadno přepínáte mezi soukromým profilem a fakturací na firmu nebo OSVČ.' },
    ],
  },
  {
    id: 'kvalita',
    tag: 'Kontrola kvality',
    headline: 'Fotky, dokumenty\na reklamace na dosah.',
    sub: 'Fotodokumentace stavu před a po úklidu, úložiště pro důležité dokumenty a integrovaný reklamační systém. Plná kontrola bez osobní přítomnosti na místě.',
    icon: 'camera',
    dark: true,
    items: [
      { icon: 'camera',         title: 'Fotodokumentace',          desc: 'Fotografie objektu před a po úklidu. Vždy víte, jak to u vás vypadá — bez osobní kontroly na místě.' },
      { icon: 'file-text',      title: 'Správa dokumentů',        desc: 'Úložiště pro důležité soubory spojené s objektem. Smlouvy, plány, cokoliv důležitého na jednom místě.' },
      { icon: 'alert-circle',   title: 'Reklamace',                desc: 'Integrovaný systém pro hlášení reklamací přímo v detailu úklidu. Bez e-mailů a telefonátů.' },
    ],
  },
  {
    id: 'dashboard',
    tag: 'Dashboard',
    headline: 'Vše důležité\nna jedné obrazovce.',
    sub: 'Rychlý přehled: počet objektů, nadcházející úklidy a celková suma za aktuální měsíc. Rozlišení jednorázových akcí a měsíčních paušálů.',
    icon: 'layout-dashboard',
    dark: false,
    items: [
      { icon: 'building-2',     title: 'Přehled objektů',          desc: 'Okamžitý přehled o počtu vašich objektů a jejich aktuálním stavu. Správa více nemovitostí bez chaosu.' },
      { icon: 'calendar-clock', title: 'Nadcházející úklidy',       desc: 'Přehled nejbližších plánovaných úklidů přes všechny objekty. Nic vám neunikne.' },
      { icon: 'receipt',        title: 'Měsíční souhrn',            desc: 'Celková částka za úklidy v aktuálním měsíci — s rozlišením jednorázových akcí a měsíčních paušálů.' },
    ],
  },
];
---

<Layout title="Klientská aplikace | PrimeClean">
  <main class="bg-white selection:bg-[#81b344]/30 selection:text-zinc-900">

    <!-- HERO -->
    <section class="relative pt-28 pb-20 md:pt-36 md:pb-28 lg:pt-44 lg:pb-36 bg-zinc-950">
      <div class="relative z-10 max-w-[1100px] mx-auto px-5 md:px-8 lg:px-12 text-center">

        <div class="inline-flex items-center gap-2.5 px-5 py-2 rounded-full bg-white/10 border border-white/15 mb-6 md:mb-8 opacity-0 animate-fade-in-up" style="animation-delay: 0ms;">
          <span class="w-1.5 h-1.5 rounded-full bg-[#81b344] animate-pulse flex-shrink-0"></span>
          <span class="text-[11px] sm:text-xs font-bold text-zinc-300 tracking-[0.15em] uppercase">Klientská aplikace PrimeClean</span>
        </div>

        <h1 class="text-[2.75rem] sm:text-[3.75rem] md:text-6xl lg:text-[6rem] font-extrabold text-white tracking-tighter leading-[1.05] md:leading-[0.95] mb-6 opacity-0 animate-fade-in-up" style="animation-delay: 150ms;">
          Váš úklid.<br class="hidden sm:block" />
          <span class="text-[#81b344]">Plně pod kontrolou.</span>
        </h1>

        <p class="text-base sm:text-lg md:text-[19px] lg:text-[21px] text-zinc-400 max-w-xl lg:max-w-2xl mx-auto leading-relaxed font-medium mb-10 md:mb-12 opacity-0 animate-fade-in-up" style="animation-delay: 300ms;">
          Objednejte úklid, sledujte fotoreporty, spravujte faktury a komunikujte s týmem — vše na jednom místě, z mobilu i počítače.
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 opacity-0 animate-fade-in-up" style="animation-delay: 420ms;">
          <a href="/kontakt" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-8 py-4 text-[16px] font-bold text-zinc-950 transition-all duration-300 ease-out bg-[#81b344] rounded-xl hover:bg-[#729f3c] hover:-translate-y-1 shadow-md shadow-[#81b344]/20">
            Chci přístup k aplikaci
            <span class="w-4 h-4" set:html={arrowRight} />
          </a>
          <a href="#funkce" class="w-full sm:w-auto inline-flex items-center justify-center px-8 py-4 text-[16px] font-bold text-zinc-300 transition-all duration-300 ease-out border border-white/20 rounded-xl hover:bg-white/8 hover:-translate-y-1">
            Prohlédnout funkce
          </a>
        </div>

      </div>
    </section>

    <!-- Placeholder pro screenshot — bude nahrazen obrázkem -->
    <div id="funkce" class="scroll-mt-24 bg-zinc-100 border-y border-zinc-200">
      <div class="max-w-5xl mx-auto px-5 md:px-8">
        <div class="w-full aspect-[16/9] flex items-center justify-center">
          <p class="text-zinc-400 text-[14px] font-semibold">Screenshot aplikace bude doplněn</p>
        </div>
      </div>
    </div>

    <!-- 5 FEATURE BLOKŮ -->
    {featureBlocks.map((block, i) => (
      <section class={`py-20 md:py-32 ${ block.dark ? 'bg-zinc-950' : i % 2 === 0 ? 'bg-white' : 'bg-zinc-50' }`}>
        <div class="max-w-[1200px] mx-auto px-5 md:px-8 lg:px-12">

          <!-- Nadpis bloku -->
          <div class="scroll-animate opacity-0 text-center max-w-3xl mx-auto mb-16 lg:mb-20">
            <div class="mb-4">
              <span class={`text-[13px] font-bold tracking-[0.2em] uppercase ${ block.dark ? 'text-[#81b344]' : 'text-[#81b344]' }`}>
                {block.tag}
              </span>
            </div>
            <h2 class={`text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tighter leading-[1.1] mb-6 whitespace-pre-line ${ block.dark ? 'text-white' : 'text-zinc-950' }`}>
              {block.headline}
            </h2>
            <p class={`text-lg md:text-[20px] font-medium leading-relaxed max-w-2xl mx-auto ${ block.dark ? 'text-zinc-400' : 'text-zinc-600' }`}>
              {block.sub}
            </p>
          </div>

          <!-- Feature karty -->
          <div class={`grid sm:grid-cols-2 ${ block.items.length === 4 ? 'lg:grid-cols-4' : 'lg:grid-cols-3' } gap-6 lg:gap-8`}>
            {block.items.map((item, j) => (
              <div
                class={`scroll-animate opacity-0 relative rounded-[1.5rem] p-8 lg:p-10 border transition-all duration-300 ease-out hover:-translate-y-1 overflow-hidden group
                  ${ block.dark
                    ? 'bg-zinc-900 border-zinc-800 hover:border-[#81b344]/30 hover:shadow-md'
                    : 'bg-white border-zinc-100 hover:shadow-lg hover:border-[#81b344]/20'
                  }`}
                style={`animation-delay: ${j * 100}ms`}
              >
                <span class="absolute top-5 right-7 text-[4rem] font-extrabold text-[#81b344]/8 leading-none select-none pointer-events-none">
                  {String(j + 1).padStart(2, '0')}
                </span>
                <div class={`w-14 h-14 rounded-2xl flex items-center justify-center mb-8 border transition-colors duration-300
                  ${ block.dark
                    ? 'bg-zinc-800 border-zinc-700 text-[#81b344] group-hover:border-[#81b344]/40'
                    : 'bg-white border-zinc-200 text-[#6a9438] group-hover:border-[#81b344]/30 group-hover:bg-[#81b344]/5'
                  }`}
                >
                  <span class="w-6 h-6" set:html={icons[item.icon]} />
                </div>
                <h3 class={`text-[19px] lg:text-[20px] font-bold tracking-tight leading-snug mb-3 ${ block.dark ? 'text-white' : 'text-zinc-950' }`}>
                  {item.title}
                </h3>
                <p class={`text-[15px] font-medium leading-relaxed ${ block.dark ? 'text-zinc-400' : 'text-zinc-600' }`}>
                  {item.desc}
                </p>
              </div>
            ))}
          </div>

        </div>
      </section>
    ))}

    <!-- CTA SEKCE -->
    <section class="py-20 md:py-32 bg-zinc-950">
      <div class="max-w-[1200px] mx-auto px-5 md:px-8 lg:px-12">
        <div class="scroll-animate opacity-0 flex flex-col lg:flex-row items-center gap-12 lg:gap-20 bg-zinc-900 rounded-[2rem] lg:rounded-[3rem] p-8 sm:p-12 md:p-16 border border-zinc-800">

          <div class="w-full lg:w-[55%]">
            <div class="inline-block px-3 py-1.5 rounded-md bg-white/10 mb-6">
              <span class="text-[12px] font-bold text-zinc-300 tracking-[0.1em] uppercase">Součást každé spolupráce</span>
            </div>
            <h2 class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-white leading-[1.1] mb-6 tracking-tighter">
              Aplikace je v ceně.<br /><span class="text-[#81b344]">Bez příplatku.</span>
            </h2>
            <p class="text-base md:text-[18px] text-zinc-400 font-medium leading-relaxed mb-8 max-w-lg">
              Klientská aplikace je standardní součástí každé naší zakázky. Přístupy nastavíme při onboardingu — za pár minut máte přehled o všem.
            </p>
            <a href="/kontakt" class="inline-flex items-center justify-center gap-2 px-8 py-4 text-[15px] font-bold text-zinc-950 transition-all duration-300 ease-out bg-[#81b344] rounded-xl hover:bg-white hover:-translate-y-1">
              Chci nezávaznou nabídku
              <span class="w-5 h-5" set:html={arrowRightLg} />
            </a>
          </div>

          <div class="w-full sm:max-w-sm md:max-w-md mx-auto lg:w-[45%]">
            <ul class="flex flex-col gap-4">
              {[
                'Fotoreporty po každém úklidu',
                'Přehled faktur a plateb',
                'Historie a plán úklidů',
                'Checklist provedených prací',
                'Bezpečné sdílení přístupu k objektu',
                'Reklamace přímo v aplikaci',
                'Správa více objektů najednou',
                'Přístup 24/7 bez instalace',
              ].map(item => (
                <li class="flex items-center gap-4 text-[16px] text-zinc-200 font-semibold tracking-tight">
                  <div class="flex-shrink-0 w-6 h-6 rounded-full bg-[#81b344] flex items-center justify-center text-zinc-950">
                    <span set:html={checkIcon} />
                  </div>
                  {item}
                </li>
              ))}
            </ul>
          </div>

        </div>
      </div>
    </section>

  </main>
</Layout>

<script is:inline>
  (function () {
    const cores = navigator.hardwareConcurrency || 4;
    const ram = navigator.deviceMemory || 4;
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (cores <= 2 || ram <= 2 || reducedMotion) {
      document.documentElement.classList.add('low-end');
    }
  })();

  document.addEventListener('DOMContentLoaded', () => {
    const isLowEnd = document.documentElement.classList.contains('low-end');
    const scrollAnimateEls = document.querySelectorAll('.scroll-animate');

    if (isLowEnd) {
      scrollAnimateEls.forEach(el => { el.classList.remove('opacity-0'); });
    } else {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('animate-fade-in-up');
            entry.target.classList.remove('opacity-0');
            observer.unobserve(entry.target);
          }
        });
      }, { root: null, threshold: 0, rootMargin: '0px 0px -10% 0px' });
      scrollAnimateEls.forEach(el => observer.observe(el));
    }

    if (isLowEnd) {
      document.querySelectorAll('.animate-fade-in-up').forEach(el => {
        el.style.opacity = '1';
        el.style.transform = 'none';
        el.style.animation = 'none';
      });
    }
  });
</script>

<style is:global>
  @keyframes softFadeUp {
    0%   { opacity: 0; transform: translateY(22px); }
    100% { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in-up {
    animation-name: softFadeUp;
    animation-duration: 0.9s;
    animation-timing-function: cubic-bezier(0.25, 1, 0.4, 1);
    animation-fill-mode: both;
  }
  @media (prefers-reduced-motion: reduce) {
    .animate-fade-in-up, .scroll-animate {
      animation: none !important;
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
    .animate-pulse { animation: none !important; }
  }
  .low-end .animate-fade-in-up,
  .low-end .scroll-animate {
    animation: none !important;
    opacity: 1 !important;
    transform: none !important;
  }
  .low-end .animate-pulse { animation: none !important; }
  .low-end img { transition: none !important; }
</style>
