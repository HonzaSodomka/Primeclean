---
import Layout from '../layouts/Layout.astro';

const featureSections = [
  {
    id: 'dashboard',
    tag: 'Dashboard',
    headline: ['Vše přehledně', 'na jedné obrazovce.'],
    desc: 'Při otevření aplikace vidíte okamžitě počet svých objektů, nadcházející úklidy a celkovou částku za aktuální měsíc — paušál i jednorázové akce zvlášť. Bez proklikávání, bez hledání.',
    image: '/dashboard.webp',
    imageAlt: 'Dashboard klientské aplikace PrimeClean — přehled objektů a úklidů',
    points: [
      { title: 'Počet objektů',       desc: 'Přehled všech vašich nemovitostí a provozoven na jednom místě.' },
      { title: 'Nadcházející úklidy', desc: 'Vidíte přesně, kdy a kde probíhá příští úklid. Žádné překvapení.' },
      { title: 'Útrata a notifikace', desc: 'Aktuální výdaje za měsíc a upozornění na důležité události v reálném čase.' },
    ],
  },
  {
    id: 'objednavky',
    tag: 'Správa a rezervace',
    headline: ['Objednávky a termíny', 'pod palcem.'],
    desc: 'Nový požadavek na úklid vytvoříte za 30 sekund — vyberete objekt, datum, čas a přidáte vlastní popis. Nadcházející termíny i celá historie na jednom místě.',
    image: '/objednavka.webp',
    imageAlt: 'Správa objednávek úklidu v aplikaci PrimeClean',
    points: [
      { title: 'Jednoduché objednání', desc: 'Vyberte objekt, datum, čas a přidejte vlastní popis. Bez telefonátů.' },
      { title: 'Přehled termínů',      desc: 'Vidíte seznam nadcházejících úklidů a aktuální stav každého z nich (např. „Probíhá").' },
      { title: 'Historie služeb',      desc: 'Kompletní archiv všech proběhlých úklidů filtrovatelný podle měsíců.' },
    ],
  },
  {
    id: 'checklist',
    tag: 'Detail zakázky',
    headline: ['Instrukce, checklist', 'a přístupové kódy.'],
    desc: 'Vše, co personál potřebuje ke každému úklidu, a vše, co jako klient chcete vidět — pracovní instrukce, checklist provedených prací, speciální požadavky.',
    image: '/checklist.webp',
    imageAlt: 'Checklist a instrukce pro úklid v aplikaci PrimeClean',
    points: [
      { title: 'Instrukce a přístupy', desc: 'Vložte přesné instrukce pro personál a bezpečně sdílejte kódy k zámkům nebo umístění klíčů.' },
      { title: 'Checklist úkolů',      desc: 'Transparentní přehled provedených prací: vysávání, utírání prachu, výměna prádla a hygieny.' },
      { title: 'Speciální požadavky',  desc: 'Přidejte poznámku s extra úkoly — zalití květin, kontrola žárovek, cokoliv specifického.' },
    ],
  },
  {
    id: 'finance',
    tag: 'Finance a administrativa',
    headline: ['Faktury a vyúčtování', 'bez e-mailů.'],
    desc: 'Detailní rozpis ceny za každý úklid, materiál i vícepráce. Všechny faktury a daňové doklady dostupné kdykoliv, bez hledání v e-mailech.',
    image: '/faktura.webp',
    imageAlt: 'Faktury a vyúčtování úklidových služeb v aplikaci PrimeClean',
    points: [
      { title: 'Detailní vyúčtování',       desc: 'Rozpis za úklid, spotřebovaný materiál a vícepráce. Víte přesně, za co platíte.' },
      { title: 'Správa faktur a dokladů',   desc: 'Všechny faktury na jednom místě, dostupné z mobilu i počítače kdykoliv.' },
      { title: 'Odpis materiálu a profily', desc: 'Přehled spotřebovaného zboží a snadné přepínání mezi soukromým a firemním profilem.' },
    ],
  },
  {
    id: 'kontrola-kvality',
    tag: 'Kontrola kvality',
    headline: ['Fotky po každém', 'úklidu. Bez výmluv.'],
    desc: 'Fotodokumentace stavu před a po úklidu, úložiště dokumentů a integrovaný systém reklamací. Máte důkazy, ne jen přísliby.',
    image: '/reklamace.webp',
    imageAlt: 'Fotodokumentace a reklamace úklidu v aplikaci PrimeClean',
    points: [
      { title: 'Fotodokumentace',            desc: 'Stav objektu před a po každém úklidu. Maximální kontrola kvality bez vaší osobní přítomnosti.' },
      { title: 'Správa dokumentů',           desc: 'Smlouvy, protokoly a soubory spojené s objektem — pohromadě a dohledatelné.' },
      { title: 'Reklamace přímo v aplikaci', desc: 'Hlášení a správa reklamací v detailu úklidu. Žádné e-maily, žádné výmluvy.' },
    ],
  },
];
---

<Layout
  title="Klientská aplikace PrimeClean — Přehled úklidů, faktury, fotoreporty"
  description="Webová aplikace PrimeClean: objednávky úklidu, fotodokumentace, faktury a reklamace na jednom místě. Přihlaste se z prohlížeče — žádné stahování."
>
  <main class="bg-white selection:bg-[#81b344]/30 selection:text-zinc-900">

    <!-- ═══════════════════════════════════════════
         HERO
    ═══════════════════════════════════════════ -->
    <section class="relative pt-24 pb-16 md:pt-32 md:pb-20 lg:pt-40 lg:pb-28 overflow-hidden bg-zinc-50">
      <div class="hidden md:block pointer-events-none absolute -top-32 -right-32 w-[600px] h-[600px] rounded-full bg-[#81b344]/5 blur-[80px]"></div>
      <div class="hidden md:block pointer-events-none absolute top-40 -left-20 w-[400px] h-[400px] rounded-full bg-[#81b344]/4 blur-[60px]"></div>

      <div class="relative z-10 max-w-[1100px] mx-auto px-5 md:px-8 lg:px-12 text-center">

        <div class="inline-flex items-center gap-2.5 px-5 py-2 rounded-full bg-white border border-zinc-200 shadow-sm mb-5 md:mb-7 opacity-0 animate-fade-in-up" style="animation-delay:0ms">
          <span class="w-1.5 h-1.5 rounded-full bg-[#81b344] flex-shrink-0"></span>
          <span class="text-xs font-bold text-[#6a9438] tracking-[0.15em] uppercase">Webová aplikace</span>
          <span class="w-px h-3 bg-zinc-300 flex-shrink-0"></span>
          <span class="text-xs font-bold text-zinc-500 tracking-[0.15em] uppercase">Klientský portál PrimeClean</span>
        </div>

        <h1 class="fluid-h1 font-extrabold text-zinc-950 tracking-tighter leading-[1.05] mb-5 opacity-0 animate-fade-in-up" style="animation-delay:150ms">
          Aplikace, která vám dá<br class="hidden sm:block" />
          <span class="text-[#6a9438]">klid v duši.</span>
        </h1>

        <p class="text-[15px] sm:text-[16px] md:text-[17px] text-zinc-600 max-w-xl lg:max-w-2xl mx-auto leading-relaxed font-medium mb-9 opacity-0 animate-fade-in-up" style="animation-delay:300ms">
          Objednávky, fotoreporty, faktury i reklamace — vše v jedné webové aplikaci. Víte, co se děje ve vašem objektu, i když tam zrovna nejste.
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-3 opacity-0 animate-fade-in-up" style="animation-delay:450ms">
          <a href="/kontakt" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-7 py-3.5 text-[15px] font-bold text-white bg-[#81b344] rounded-xl hover:bg-[#6a9438] hover:-translate-y-1 transition-all duration-300 shadow-md shadow-[#81b344]/20">
            Chci přístup do aplikace
            <i data-lucide="arrow-right" class="w-4 h-4" aria-hidden="true"></i>
          </a>
          <a href="#funkce" class="w-full sm:w-auto inline-flex items-center justify-center px-7 py-3.5 text-[15px] font-bold text-zinc-700 bg-white border-2 border-zinc-200 rounded-xl hover:border-zinc-300 hover:bg-zinc-50 hover:-translate-y-1 transition-all duration-300">
            Prozkoumat funkce
          </a>
        </div>

      </div>
    </section>

    <!-- ═══════════════════════════════════════════
         FEATURE SECTIONS
    ═══════════════════════════════════════════ -->
    <div id="funkce">
      {featureSections.map((sec, i) => (
        <section id={sec.id} class={`py-16 md:py-20 lg:py-28 ${i % 2 === 0 ? 'bg-white' : 'bg-zinc-50'}`}>
          <div class="max-w-[1100px] mx-auto px-5 md:px-8 lg:px-12">
            <div class={`flex flex-col gap-10 lg:gap-16 items-center ${i % 2 === 1 ? 'lg:flex-row-reverse' : 'lg:flex-row'}`}>

              <!-- Text -->
              <div class="w-full lg:w-1/2">
                <div class="scroll-animate opacity-0 mb-4">
                  <span class="inline-block px-3 py-1.5 rounded-md bg-[#81b344]/10">
                    <span class="text-[11px] font-bold text-[#6a9438] tracking-[0.1em] uppercase">{sec.tag}</span>
                  </span>
                </div>
                <h2 class="scroll-animate opacity-0 fluid-h2 font-extrabold text-zinc-950 tracking-tighter leading-[1.15] mb-4" style="animation-delay:80ms">
                  {sec.headline[0]}<br class="hidden sm:block" />{sec.headline[1]}
                </h2>
                <p class="scroll-animate opacity-0 text-[14px] md:text-[15px] text-zinc-600 font-medium leading-relaxed mb-8" style="animation-delay:160ms">
                  {sec.desc}
                </p>
                <ul class="flex flex-col gap-5">
                  {sec.points.map((point, pi) => (
                    <li class="scroll-animate opacity-0 flex gap-3.5" style={`animation-delay:${240 + pi * 80}ms`}>
                      <div class="flex-shrink-0 mt-0.5 w-5 h-5 rounded-full bg-[#81b344] flex items-center justify-center text-white">
                        <i data-lucide="check" class="w-3 h-3" aria-hidden="true"></i>
                      </div>
                      <div>
                        <p class="text-[14px] font-bold text-zinc-900 mb-0.5">{point.title}</p>
                        <p class="text-[13px] font-medium text-zinc-500 leading-relaxed">{point.desc}</p>
                      </div>
                    </li>
                  ))}
                </ul>
              </div>

              <!-- Fotka -->
              <div class="scroll-animate opacity-0 w-full lg:w-1/2" style="animation-delay:200ms">
                <div class="relative aspect-square rounded-[1.75rem] overflow-hidden border border-zinc-200 shadow-xl group">
                  <img
                    src={sec.image}
                    alt={sec.imageAlt}
                    width="800"
                    height="800"
                    class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.03]"
                    loading={i === 0 ? 'eager' : 'lazy'}
                    decoding="async"
                  />
                </div>
              </div>

            </div>
          </div>
        </section>
      ))}
    </div>

    <!-- ═══════════════════════════════════════════
         JAK ZAČÍT
    ═══════════════════════════════════════════ -->
    <section class="py-16 md:py-20 lg:py-24 bg-[#81b344] relative overflow-hidden">
      <div class="hidden md:block pointer-events-none absolute -top-20 -left-20 w-[500px] h-[500px] rounded-full bg-white/10 blur-[120px]"></div>
      <div class="hidden md:block pointer-events-none absolute -bottom-20 -right-20 w-[500px] h-[500px] rounded-full bg-[#4a7a28]/50 blur-[80px]"></div>

      <div class="max-w-[1100px] mx-auto px-5 md:px-8 lg:px-12 relative z-10">

        <div class="scroll-animate opacity-0 flex flex-col lg:flex-row lg:items-end lg:justify-between gap-5 mb-10 md:mb-12">
          <div>
            <div class="mb-2.5">
              <span class="inline-flex items-center gap-1.5 text-[11px] font-black text-white/60 tracking-[0.25em] uppercase">
                <span class="w-4 h-px bg-white/40"></span>
                Jak začít
              </span>
            </div>
            <h2 class="fluid-h2 font-extrabold text-white tracking-tighter leading-[1.1]">
              Přístup do aplikace<br />za pár minut.
            </h2>
          </div>
          <p class="lg:max-w-[300px] text-[14px] text-white/70 font-medium leading-relaxed lg:text-right lg:pb-1">
            Čistě webová aplikace — žádné stahování,<br class="hidden lg:block" /> žádná instalace. Přihlásíte se z prohlížeče a máte okamžitý přehled.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-10">
          {[
            { step: '01', title: 'Poptáváte nás',      desc: 'Zavolejte nebo vyplňte formulář. Probereme vaše potřeby a navrhneme plán.',   delay: 0 },
            { step: '02', title: 'Podpis smlouvy',     desc: 'Domluvíme rozsah, frekvenci a podmínky. Vše jasné a přehledné.',              delay: 80 },
            { step: '03', title: 'Dostanete přístupy', desc: 'Zašleme vám přihlašovací údaje do klientské aplikace ihned po startu.',       delay: 160 },
            { step: '04', title: 'Plný přehled',       desc: 'Od prvního úklidu vidíte vše online — fotky, stav, faktury, historii.', highlight: true, delay: 240 },
          ].map(({ step, title, desc, highlight, delay }) => (
            <div
              class={`scroll-animate opacity-0 relative flex flex-col p-6 rounded-2xl overflow-hidden shadow-md ${highlight ? 'bg-[#f0f7e8]' : 'bg-white'}`}
              style={`animation-delay:${delay}ms`}
            >
              <span
                class="absolute -bottom-4 -right-1 text-[5.5rem] font-black leading-none select-none pointer-events-none tabular-nums"
                style={highlight ? 'color: rgb(129 179 68 / 0.15)' : 'color: rgb(9 9 11 / 0.05)'}
              >
                {step}
              </span>

              <div class="flex items-center gap-2 mb-4">
                <span class={`w-6 h-6 rounded-full flex items-center justify-center text-[10px] font-black ${
                  highlight ? 'bg-[#81b344] text-white' : 'bg-zinc-100 text-zinc-500'
                }`}>{step}</span>
                {highlight && (
                  <span class="text-[10px] font-bold text-[#6a9438] tracking-[0.12em] uppercase">Hotovo ✔</span>
                )}
              </div>

              <h3 class={`text-[15px] font-extrabold tracking-tight leading-snug mb-2 ${
                highlight ? 'text-[#3d6b1a]' : 'text-zinc-950'
              }`}>{title}</h3>
              <p class="text-[13px] font-medium leading-relaxed text-zinc-500">{desc}</p>
            </div>
          ))}
        </div>

        <div class="scroll-animate opacity-0 flex flex-col sm:flex-row items-center gap-4" style="animation-delay:320ms">
          <a href="/kontakt" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-7 py-3.5 text-[15px] font-bold text-[#3d6b1a] bg-white rounded-xl hover:bg-zinc-50 hover:-translate-y-1 transition-all duration-300 shadow-lg shadow-black/10">
            Chci nezávaznou nabídku
            <i data-lucide="arrow-right" class="w-4 h-4" aria-hidden="true"></i>
          </a>
          <p class="text-[13px] text-white/65 font-medium">Aplikace je součástí každé spolupráce. Přístupy dostanete automaticky.</p>
        </div>

      </div>
    </section>

  </main>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const isLowEnd = document.documentElement.classList.contains('low-end');

    if (isLowEnd) {
      document.querySelectorAll<HTMLElement>('.opacity-0').forEach(el => {
        el.classList.remove('opacity-0');
        el.style.opacity = '1';
        el.style.transform = 'none';
        el.style.animation = 'none';
      });
    } else {
      const observer = new IntersectionObserver(entries => {
        entries.forEach(entry => {
          if (!entry.isIntersecting) return;
          entry.target.classList.add('animate-fade-in-up');
          entry.target.classList.remove('opacity-0');
          observer.unobserve(entry.target);
        });
      }, { threshold: 0, rootMargin: '0px 0px -5% 0px' });
      document.querySelectorAll('.scroll-animate').forEach(el => observer.observe(el));
    }
  });
</script>

<style>
  /*
    FLUID TYPOGRAPHY — stejný systém jako ostatní stránky
    fluid-h1: clamp(2rem, 4.5vw, 4.5rem)
    fluid-h2: clamp(1.625rem, 3vw, 2.75rem)
  */
  .fluid-h1 { font-size: clamp(2rem,    4.5vw, 4.5rem); }
  .fluid-h2 { font-size: clamp(1.625rem, 3vw,  2.75rem); }

  @keyframes softFadeUp {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in-up {
    animation: softFadeUp 0.75s cubic-bezier(0.25, 1, 0.4, 1) both;
  }

  @media (prefers-reduced-motion: reduce) {
    .animate-fade-in-up,
    .scroll-animate {
      animation: none !important;
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
  }

  :global(.low-end) .animate-fade-in-up,
  :global(.low-end) .scroll-animate,
  :global(.low-end) .opacity-0 {
    animation: none !important;
    opacity: 1 !important;
    transform: none !important;
  }
  :global(.low-end) img { transition: none !important; }
</style>