            <div class="scroll-animate opacity-0 relative bg-zinc-950 rounded-[2.5rem] overflow-hidden px-8 py-14 md:px-14 md:py-20">
              <!-- Safari fix: orb jen na desktopu -->
              <div class="hidden md:block pointer-events-none absolute -top-40 left-1/2 -translate-x-1/2 w-[700px] h-[400px] rounded-full bg-[#81b344]/8" style="filter: blur(80px);"></div>
              <div class="relative z-10 grid lg:grid-cols-2 gap-16 lg:gap-24">

                <div class="scroll-animate opacity-0">
                  <div class="mb-4">
                    <span class="text-[13px] font-bold text-[#81b344] tracking-[0.2em] uppercase">Rozsah služby</span>
                  </div>
                  <h2 class="text-2xl sm:text-3xl md:text-4xl font-extrabold text-white tracking-tighter leading-[1.1] mb-8">
