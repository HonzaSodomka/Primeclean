---
import Layout from '../layouts/Layout.astro';

const tabs = [
  { id: 'kancelare', label: 'Kaneláře a firmy',  icon: 'briefcase'  },
  { id: 'svj',       label: 'SVJ a bytové domy', icon: 'building-2' },
  { id: 'airbnb',    label: 'Airbnb a apartmány', icon: 'key-round'  },
];

const kancelare = {
  tag: 'Pravidelný úklid',
  tagBadge: 'Nejpopulárnější',
  headline: 'Úklid kaneláří,\nkterý prostě funguje.',
  sub: 'Většina klientů k nám přichází proto, že předchozí firma nedodržovala termíny nebo měnila pracovníky každý měsíc. My nastavujeme pravidelný harmonogram, stálý tým a vše sledujete v aplikaci — bez telefonování a doptávání.',
  cta: 'Chci nacenit úklid kaneláře',
  ctaBottom: 'Domluvit pravidelný úklid',
  image: '/sluzba-kancelare.jpg',
  imageWidth: 800, imageHeight: 600,
  heroFeature: {
    icon: 'camera',
    title: 'Fotoreport ihned po každém úklidu',
    desc: 'Po každé návštěvě našich pracovníků dostanete do aplikace fotodokumentaci. Víte přesně, co bylo provedeno a v jakém stavu kanelář odevzdáváme — žádné dohady. Toto ostatní firmy nenabízejí.',
    badge: 'Náš unikátní standard',
  },
  features: [
    { icon: 'calendar-check',  title: 'Pevný harmonogram',       desc: 'Úklid probíhá pravidelně — brzy ráno, večer nebo o víkendech. Vždy stejný rozsah, diskrétně a profesionálně.' },
    { icon: 'clipboard-list',  title: 'Jasná pravidla a checklist', desc: 'Předem domluvený rozsah prací a checklist — jasně dané, co se uklizí, jak často a kdo za úklid zodpovídá.' },
    { icon: 'users',           title: 'Stálí pracovníci',           desc: 'Úklid provádějí vždy stejní pracovníci, kteří prostory znají. Žádní cizí lidé, o nichž nic nevíte.' },
    { icon: 'shield-check',    title: 'Spolehlivost bez starostí',  desc: 'Máte jednoho partnera, který řeší úklid dlouhodobě. Komunikace rychlá, pravidla jasná, kvalita pod kontrolou.' },
    { icon: 'zap',             title: 'Flexibilita na vyžádání',    desc: 'Potřebujete mimořádný úklid před důležitou návštěvou nebo po firemním večírku? Řešíme to jednoduše a přímo.' },
  ],
  includes: [
    'Vysávání a vytírání podlah ve všech prostorách',
    'Vynášení odpadků a doplňování hygienických potřeb',
    'Stírání prachu z volných ploch stolů a nábytku',
    'Kompletní úklid a dezinfekce sociálního zázemí a kuchyněk',
    'Čištění skleněných příček a vstupních dveří',
  ],
  forWhom: [
    { icon: 'building',      label: 'Administrativní budovy'          },
    { icon: 'laptop',        label: 'Coworkingy a sdílené kaneláře'  },
    { icon: 'stethoscope',   label: 'Ordinace a zdravotnická zařízení' },
    { icon: 'utensils',      label: 'Restaurace a kavárny'            },
  ],
};

const svj = {
  tag: 'Správa budov',
  tagBadge: 'Pro SVJ a správce',
  headline: 'Čisté společné prostory\nbez starostí.',
  sub: 'Správci a výbory SVJ často řeší reklamace od obyvatel nebo zoufale shání náhradu za brigádníky, co nepřišli. My dodáváme stálý tým, který domy zná a dodržuje harmonogram. U menších objektů dokumentujeme každou návštěvu fotoreportem. U rozsáhlých budov rozsah fotodokumentace domluvíme individuálně.',
  cta: 'Chci nabídku pro SVJ',
  ctaBottom: 'Domluvit úklid domu',
  image: '/sluzba-svj.jpg',
  imageWidth: 800, imageHeight: 600,
  heroFeature: {
    icon: 'camera',
    title: 'Fotodokumentace přizpůsobená objektu',
    desc: 'U menších domů dokumentujeme celý průběh úklidu fotoreportem v aplikaci. U větších objektů se rozsah a způsob fotodokumentace domlouvá individuálně, aby byl pro vás opravdu přínosný, ne jen formální.',
    badge: 'Přizpůsobujeme se realitě',
  },
  features: [
    { icon: 'calendar-check',    title: 'Pravidelný harmonogram',        desc: 'Úklid týdně, 2× týdně nebo individuálně podle potřeb domu. Vždy stejný rozsah, žádné výmluvy.' },
    { icon: 'clipboard-list',    title: 'Jasná pravidla a checklist',      desc: 'Každý dům má vlastní plán úklidu a checklist — jasně dané, co se uklizí, jak často a kdo za to zodpovídá.' },
    { icon: 'users',             title: 'Stálí pracovníci',               desc: 'Úklid provádějí vždy stejní pracovníci, kteří dům znají. Obyvatelé vidí pořád stejné obličeje.' },
    { icon: 'shield-check',      title: 'Spolehlivost pro SVJ i správce', desc: 'Máte jednoho partnera, který řeší úklid dlouhodobě. Komunikace rychlá, pravidla jasná, kvalita pod kontrolou.' },
    { icon: 'sliders-horizontal', title: 'Plán pro každý dům zvlášť',   desc: 'Jinak se uklizí malý dům, jinak velký panelák s více vchody. Plán nastavuime přesně podle reálných potřeb objektu.' },
  ],
  includes: [
    'Zametení a vytření podlah ve společných prostorách',
    'Otření zábradlí, madel a schoditště',
    'Úklid vstupních dveří a prosklených ploch',
    'Otření poštovních schránek a vypínačů',
    'Úklid výtahu (pokud je součástí domu)',
  ],
  forWhom: [
    { icon: 'building-2', label: 'Společentství vlastníků (SVJ)' },
    { icon: 'key-round',  label: 'Bytová družstva'                },
    { icon: 'briefcase',  label: 'Správci nemovitostí'           },
    { icon: 'home',       label: 'Majitelé bytových domů'        },
  ],
};

const airbnb = {
  tag: 'Krátkodobé pronájmy',
  tagBadge: 'Airbnb & Booking',
  headline: 'Apartmán připravený\npro každého hosta.',
  sub: 'Hostitelé nejvíce stresují z toho, že apartmán nebude včas připravený nebo že nemají přehled o jeho stavu, když jsou mimo město. My řešíme obě věci — příchozí host dostane čistý apartmán a vy vidíte fotky přímo v aplikaci ihned po dokončení.',
  cta: 'Chci nabídku pro Airbnb',
  ctaBottom: 'Nastavit úklid apartmánu',
  image: '/sluzba-airbnb.jpg',
  imageWidth: 800, imageHeight: 600,
  heroFeature: {
    icon: 'camera',
    title: 'Fotoreport ihned po každém úklidu',
    desc: 'Po každém úklidu dostanete v aplikaci fotky apartmánu — vidíte, že je vše připraveno dřív, než host přijde. Klidně kontrolujete stav z druhého konce republiky. Navíc máte důkaz pro případ reklamace škody ze strany hosta.',
    badge: 'Náš unikátní standard',
  },
  features: [
    { icon: 'zap',            title: 'Rychlá příprava',                desc: 'Úklid zvládneme ve vašem časovém okně mezi odjezdem a příjezdem hostů. Bez stresu a zpoždení.' },
    { icon: 'clipboard-list', title: 'Jasný rozsah prací',              desc: 'Předem domluvený checklist — jasně dané, co se uklizí při každé návštěvě. Vždy stejný standard.' },
    { icon: 'users',          title: 'Stálí pracovníci',               desc: 'Úklid provádějí vždy stejní pracovníci, kteří apartmán znají. Žádní náhodní lidé v soukromém prostoru.' },
    { icon: 'shirt',          title: 'Výměna ložního prádla',          desc: 'Zajístíme výměnu a doplnění čistého prádla a ručníků před každým příjezdem hostů.' },
    { icon: 'shield-check',   title: 'Spolehlivost pro pronájímatele', desc: 'Máte jednoho partnera, který řeší úklid dlouhodobě. Komunikace rychlá, pravidla jasná, kvalita pod kontrolou.' },
  ],
  includes: [
    'Kompletní úklid koupelny a WC',
    'Úklid kuchyně včetně spotřebičů',
    'Vysávání a vytírání podlah',
    'Výměna ložního prádla a ručníků',
    'Doplnění spotřebního materiálu',
    'Kontrola a hlášení případného poškození',
  ],
  forWhom: [
    { icon: 'home',       label: 'Majitelé Airbnb apartmánů'         },
    { icon: 'building',   label: 'Správci více nemovitostí'           },
    { icon: 'key-round',  label: 'Provozovatelé apartmán. domů'       },
    { icon: 'globe',      label: 'Booking.com pronájímatelé'           },
  ],
};

const tabData = { kancelare, svj, airbnb };
---

<Layout title="Naše služby | PrimeClean">
  <main class="bg-white selection:bg-[#81b344]/30 selection:text-zinc-900">

    <!-- HERO -->
    <section class="relative pt-28 pb-20 md:pt-36 md:pb-28 lg:pt-44 lg:pb-36 bg-zinc-50 overflow-hidden">
      <div class="s-blob s-blob--tr" aria-hidden="true"></div>
      <div class="s-blob s-blob--bl" aria-hidden="true"></div>

      <div class="relative z-10 max-w-[1100px] mx-auto px-5 md:px-8 lg:px-12 text-center">
        <div class="inline-flex items-center gap-2.5 px-5 py-2 rounded-full bg-white border border-zinc-200 shadow-sm mb-6 md:mb-8 opacity-0 animate-fade-in-up" style="animation-delay:0ms">
          <span class="w-1.5 h-1.5 rounded-full bg-[#81b344] animate-pulse flex-shrink-0"></span>
          <span class="text-[11px] sm:text-xs font-bold text-zinc-600 tracking-[0.15em] uppercase">Profesionální úklid Brno a okolí</span>
        </div>

        <h1 class="text-[2.75rem] sm:text-[3.75rem] md:text-6xl lg:text-[6rem] font-extrabold text-zinc-950 tracking-tighter leading-[1.05] md:leading-[0.95] mb-6 opacity-0 animate-fade-in-up" style="animation-delay:150ms">
          Tři služby.<br class="hidden sm:block" /><span class="text-[#6a9438]"> Jeden standard.</span>
        </h1>

        <p class="text-base sm:text-lg md:text-[19px] lg:text-[21px] text-zinc-600 max-w-xl mx-auto leading-relaxed font-medium mb-10 md:mb-14 opacity-0 animate-fade-in-up" style="animation-delay:300ms">
          Specializujeme se na tři oblasti, kde máme vyladěné procesy a prověřené týmy. Vyberte si tu vaši.
        </p>

        <!-- TAB SWITCHER -->
        <div class="opacity-0 animate-fade-in-up" style="animation-delay:450ms">
          <!-- Desktop -->
          <div id="tab-switcher" class="hidden sm:inline-flex gap-2 p-1.5 bg-white border border-zinc-200 rounded-2xl shadow-sm">
            {tabs.map((tab, i) => (
              <button
                data-tab={tab.id}
                class={`tab-btn flex items-center gap-2.5 px-6 py-3.5 rounded-xl text-[14px] font-bold transition-all duration-200 whitespace-nowrap ${
                  i === 0 ? 'bg-[#81b344] text-white shadow-md shadow-[#81b344]/25'
                          : 'text-zinc-500 hover:text-zinc-800 hover:bg-zinc-50'
                }`}
              >
                <i data-lucide={tab.icon} class="w-4 h-4 flex-shrink-0" aria-hidden="true"></i>
                {tab.label}
              </button>
            ))}
          </div>
          <!-- Mobile -->
          <div id="tab-switcher-mobile" class="sm:hidden flex flex-col gap-2 w-full max-w-xs mx-auto">
            {tabs.map((tab, i) => (
              <button
                data-tab={tab.id}
                class={`tab-btn flex items-center justify-center gap-2.5 w-full px-5 py-4 rounded-2xl text-[15px] font-bold transition-all duration-200 ${
                  i === 0 ? 'bg-[#81b344] text-white shadow-md shadow-[#81b344]/25'
                          : 'bg-white border border-zinc-200 text-zinc-600 hover:border-[#81b344]/40 hover:text-zinc-900'
                }`}
              >
                <i data-lucide={tab.icon} class="w-5 h-5 flex-shrink-0" aria-hidden="true"></i>
                {tab.label}
              </button>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- TAB CONTENT -->
    {Object.entries(tabData).map(([id, data], tabIndex) => (
      <div id={`tab-${id}`} class={`tab-content ${id !== 'kancelare' ? 'hidden' : ''}`}>

        <!-- 1. HERO PANEL -->
        <section class="py-20 md:py-28 bg-white">
          <div class="max-w-[1200px] mx-auto px-5 md:px-8 lg:px-12">
            <div class={`flex flex-col gap-12 lg:gap-20 items-center ${tabIndex % 2 === 0 ? 'lg:flex-row' : 'lg:flex-row-reverse'}`}>

              <div class="w-full lg:w-1/2">
                <div class="scroll-animate opacity-0 mb-5">
                  <span class="inline-block px-3 py-1.5 rounded-md bg-[#81b344]/10">
                    <span class="text-[12px] font-bold text-[#6a9438] tracking-[0.1em] uppercase">{data.tag}</span>
                  </span>
                </div>
                <h2 class="scroll-animate opacity-0 text-3xl sm:text-4xl md:text-5xl font-extrabold text-zinc-950 tracking-tighter leading-[1.1] mb-6 whitespace-pre-line" style="animation-delay:80ms">
                  {data.headline}
                </h2>
                <p class="scroll-animate opacity-0 text-[17px] md:text-[19px] text-zinc-600 font-medium leading-relaxed mb-10" style="animation-delay:160ms">
                  {data.sub}
                </p>
                <div class="scroll-animate opacity-0 flex flex-col sm:flex-row gap-3" style="animation-delay:240ms">
                  <a href="/kontakt" class="inline-flex items-center justify-center gap-2 px-8 py-4 text-[15px] font-bold text-white transition-all duration-300 ease-out bg-[#81b344] rounded-xl hover:bg-[#729f3c] hover:-translate-y-1 shadow-md shadow-[#81b344]/20">
                    {data.cta}
                    <i data-lucide="arrow-right" class="w-4 h-4" aria-hidden="true"></i>
                  </a>
                  <a href={`#features-${id}`} class="inline-flex items-center justify-center gap-2 px-8 py-4 text-[15px] font-bold text-zinc-700 transition-all duration-300 ease-out bg-white border-2 border-zinc-200 rounded-xl hover:border-zinc-300 hover:bg-zinc-50 hover:-translate-y-1">
                    Co zahrnuje služba
                  </a>
                </div>
              </div>

              <div class="scroll-animate opacity-0 w-full lg:w-1/2" style="animation-delay:200ms">
                <div class="relative aspect-[4/3] rounded-[2rem] overflow-hidden bg-zinc-100 border border-zinc-200/60 shadow-lg group">
                  <img
                    src={data.image}
                    alt={data.tag}
                    width={data.imageWidth}
                    height={data.imageHeight}
                    class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.03]"
                    loading={tabIndex === 0 ? 'eager' : 'lazy'}
                    decoding="async"
                    fetchpriority={tabIndex === 0 ? 'high' : 'low'}
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-zinc-950/20 to-transparent pointer-events-none"></div>
                  <div class="absolute bottom-5 left-5 px-3 py-1.5 rounded-full bg-white/90 backdrop-blur-sm shadow-sm">
                    <span class="text-[12px] font-bold text-zinc-700 tracking-[0.06em] uppercase">{data.tagBadge}</span>
                  </div>
                </div>
              </div>

            </div>
          </div>
        </section>

        <!-- 2. FEATURES GRID -->
        <section id={`features-${id}`} class="py-20 md:py-28 bg-zinc-50">
          <div class="max-w-[1200px] mx-auto px-5 md:px-8 lg:px-12">
            <div class="scroll-animate opacity-0 text-center max-w-2xl mx-auto mb-14">
              <p class="text-[13px] font-bold text-[#81b344] tracking-[0.2em] uppercase mb-4">Jak spolupráce funguje</p>
              <h2 class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-zinc-950 tracking-tighter leading-[1.1]">
                Co konkrétně <span class="text-[#6a9438]">získáte.</span>
              </h2>
            </div>

            <!-- HERO FEATURE KARTA -->
            <div class="scroll-animate opacity-0 mb-8">
              <div class="relative bg-[#81b344] rounded-[2rem] overflow-hidden p-8 md:p-12 flex flex-col md:flex-row items-start md:items-center gap-8 border border-[#6a9438]">
                <div class="feat-blob" aria-hidden="true"></div>
                <div class="relative z-10 flex-shrink-0 w-16 h-16 rounded-2xl bg-white/20 border border-white/30 flex items-center justify-center text-white">
                  <i data-lucide={data.heroFeature.icon} class="w-7 h-7" aria-hidden="true"></i>
                </div>
                <div class="relative z-10 flex-1">
                  <div class="flex flex-wrap items-center gap-3 mb-3">
                    <h3 class="text-[20px] md:text-[22px] font-extrabold text-white tracking-tight">{data.heroFeature.title}</h3>
                    <span class="px-2.5 py-1 rounded-full bg-white/20 border border-white/30">
                      <span class="text-[11px] font-bold text-white tracking-[0.1em] uppercase">{data.heroFeature.badge}</span>
                    </span>
                  </div>
                  <p class="text-[15px] md:text-[16px] text-white/80 font-medium leading-relaxed max-w-2xl">{data.heroFeature.desc}</p>
                </div>
              </div>
            </div>

            <!-- 5 FEATURE KARET -->
            <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
              {data.features.map((f, index) => (
                <div
                  class={`scroll-animate opacity-0 relative bg-white rounded-[1.5rem] p-8 lg:p-10 border border-zinc-100 transition-all duration-300 ease-out hover:-translate-y-1 hover:shadow-lg hover:border-[#81b344]/20 overflow-hidden group ${
                    data.features.length === 5 && index === 4 ? 'sm:col-span-2 lg:col-span-1' : ''
                  }`}
                  style={`animation-delay:${index * 100}ms`}
                >
                  <span class="absolute top-5 right-7 text-[4rem] font-extrabold text-[#81b344]/8 leading-none select-none pointer-events-none" aria-hidden="true">
                    {String(index + 1).padStart(2, '0')}
                  </span>
                  <div class="w-14 h-14 rounded-2xl bg-white border border-zinc-200 flex items-center justify-center text-[#6a9438] mb-8 group-hover:border-[#81b344]/30 group-hover:bg-[#81b344]/5 transition-colors duration-300">
                    <i data-lucide={f.icon} class="w-6 h-6" aria-hidden="true"></i>
                  </div>
                  <h3 class="text-[19px] font-bold text-zinc-950 tracking-tight leading-snug mb-3">{f.title}</h3>
                  <p class="text-[15px] font-medium text-zinc-600 leading-relaxed">{f.desc}</p>
                </div>
              ))}
            </div>
          </div>
        </section>

        <!-- 3. CO ZAHRNUJE + PRO KOHO -->
        <section class="py-20 md:py-28 bg-white">
          <div class="max-w-[1200px] mx-auto px-5 md:px-8 lg:px-12">
            <div class="scroll-animate opacity-0 relative bg-zinc-950 rounded-[2.5rem] overflow-hidden px-8 py-14 md:px-14 md:py-20">
              <div class="dark-blob" aria-hidden="true"></div>
              <div class="relative z-10 grid lg:grid-cols-2 gap-16 lg:gap-24">

                <div class="scroll-animate opacity-0">
                  <p class="text-[13px] font-bold text-[#81b344] tracking-[0.2em] uppercase mb-4">Rozsah služby</p>
                  <h2 class="text-2xl sm:text-3xl md:text-4xl font-extrabold text-white tracking-tighter leading-[1.1] mb-8">
                    Co zahrnuje <span class="text-[#81b344]">každá návštěva.</span>
                  </h2>
                  <ul class="flex flex-col gap-4" role="list">
                    {data.includes.map((item, i) => (
                      <li
                        class="scroll-animate opacity-0 flex items-center gap-4 text-[16px] text-zinc-300 font-medium"
                        style={`animation-delay:${i * 60}ms`}
                      >
                        <div class="flex-shrink-0 w-6 h-6 rounded-full bg-[#81b344] flex items-center justify-center text-zinc-950">
                          <i data-lucide="check" class="w-3 h-3" style="stroke-width:3" aria-hidden="true"></i>
                        </div>
                        {item}
                      </li>
                    ))}
                  </ul>
                </div>

                <div class="scroll-animate opacity-0" style="animation-delay:150ms">
                  <p class="text-[13px] font-bold text-[#81b344] tracking-[0.2em] uppercase mb-4">Cílová skupina</p>
                  <h2 class="text-2xl sm:text-3xl md:text-4xl font-extrabold text-white tracking-tighter leading-[1.1] mb-8">
                    Pro koho je tato <span class="text-[#81b344]">služba.</span>
                  </h2>
                  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    {data.forWhom.map((item, i) => (
                      <div
                        class="scroll-animate opacity-0 flex items-center gap-4 p-5 bg-white/5 rounded-2xl border border-white/10 hover:bg-white/10 hover:border-[#81b344]/30 hover:-translate-y-0.5 transition-all duration-200 group"
                        style={`animation-delay:${i * 80}ms`}
                      >
                        <div class="flex-shrink-0 w-10 h-10 rounded-xl bg-[#81b344]/15 border border-[#81b344]/25 flex items-center justify-center text-[#81b344] group-hover:bg-[#81b344]/25 transition-colors duration-200">
                          <i data-lucide={item.icon} class="w-5 h-5" aria-hidden="true"></i>
                        </div>
                        <span class="text-[15px] font-semibold text-zinc-200 leading-snug">{item.label}</span>
                      </div>
                    ))}
                  </div>
                  <div class="mt-10 pt-10 border-t border-white/10">
                    <a href="/kontakt" class="inline-flex items-center justify-center gap-2 px-8 py-4 text-[15px] font-bold text-zinc-950 transition-all duration-300 ease-out bg-[#81b344] rounded-xl hover:bg-white hover:-translate-y-1 shadow-md shadow-[#81b344]/20">
                      {data.ctaBottom}
                      <i data-lucide="arrow-right" class="w-5 h-5" aria-hidden="true"></i>
                    </a>
                  </div>
                </div>

              </div>
            </div>
          </div>
        </section>

        <!-- 4. OSTATNÍ SLUŽBY PREVIEW -->
        <section class="py-20 md:py-28 bg-zinc-50">
          <div class="max-w-[1200px] mx-auto px-5 md:px-8 lg:px-12">
            <div class="scroll-animate opacity-0 text-center max-w-2xl mx-auto mb-14">
              <p class="text-[13px] font-bold text-[#81b344] tracking-[0.2em] uppercase mb-4">Další možnosti</p>
              <h2 class="text-3xl sm:text-4xl font-extrabold text-zinc-950 tracking-tighter leading-[1.1]">
                Poptáváte něco <span class="text-[#6a9438]">jiného?</span>
              </h2>
            </div>
            <div class="grid sm:grid-cols-2 gap-8">
              {Object.entries(tabData)
                .filter(([key]) => key !== id)
                .map(([key, s], i) => (
                  <button
                    data-tab-link={key}
                    class="scroll-animate opacity-0 text-left flex flex-col bg-white rounded-[2rem] border border-zinc-200 shadow-sm transition-all duration-300 ease-out hover:shadow-lg hover:-translate-y-1 overflow-hidden group cursor-pointer"
                    style={`animation-delay:${i * 120}ms`}
                  >
                    <div class="relative w-full aspect-[4/3] bg-zinc-100 overflow-hidden">
                      <img src={s.image} alt={s.tag} width="600" height="450" class="w-full h-full object-cover object-center transition-transform duration-500 ease-out group-hover:scale-[1.03]" loading="lazy" decoding="async" />
                      <div class="absolute top-4 left-4 px-2.5 py-1 rounded-full bg-white shadow-sm">
                        <span class="text-[11px] font-bold text-zinc-700 tracking-[0.06em] uppercase">{s.tagBadge}</span>
                      </div>
                    </div>
                    <div class="p-7 flex-grow flex flex-col">
                      <h3 class="text-[20px] font-bold text-zinc-950 tracking-tight leading-snug mb-3">{s.headline.replace(/\n/g, ' ')}</h3>
                      <p class="text-[15px] text-zinc-600 font-medium leading-relaxed mb-5 flex-grow">{s.sub.slice(0, 100)}…</p>
                      <div class="pt-4 border-t border-zinc-100">
                        <span class="inline-flex items-center gap-1.5 font-bold text-[15px] text-[#81b344] group-hover:text-[#6a9438] transition-colors">
                          Zjistit více
                          <i data-lucide="arrow-right" class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" aria-hidden="true"></i>
                        </span>
                      </div>
                    </div>
                  </button>
                ))
              }
            </div>
          </div>
        </section>

      </div>
    ))}

  </main>
</Layout>

<script>
  const VALID_TABS = ['kancelare', 'svj', 'airbnb'] as const;
  type TabId = typeof VALID_TABS[number];

  const isLowEnd = () => document.documentElement.classList.contains('low-end');

  // Single shared observer — disconnect & recreate on tab switch
  let scrollObserver: IntersectionObserver | null = null;

  function initScrollAnimations(scope: Element) {
    scrollObserver?.disconnect();
    const els = scope.querySelectorAll<HTMLElement>('.scroll-animate');

    if (isLowEnd()) {
      els.forEach(el => { el.style.opacity = '1'; el.classList.remove('opacity-0'); });
      return;
    }

    scrollObserver = new IntersectionObserver(
      entries => entries.forEach(entry => {
        if (!entry.isIntersecting) return;
        (entry.target as HTMLElement).classList.add('animate-fade-in-up');
        (entry.target as HTMLElement).classList.remove('opacity-0');
        scrollObserver?.unobserve(entry.target);
      }),
      { threshold: 0, rootMargin: '0px 0px -5% 0px' }
    );
    els.forEach(el => scrollObserver!.observe(el));
  }

  function activateTab(target: string, scrollToContent: boolean) {
    if (!(VALID_TABS as readonly string[]).includes(target)) return;

    // Update buttons
    document.querySelectorAll<HTMLElement>('.tab-btn').forEach(btn => {
      const isMobile = !!btn.closest('#tab-switcher-mobile');
      const isTarget = btn.dataset.tab === target;
      btn.classList.remove('bg-[#81b344]', 'text-white', 'shadow-md', 'shadow-[#81b344]/25');
      if (isMobile) {
        if (isTarget) {
          btn.classList.remove('bg-white', 'border', 'border-zinc-200', 'text-zinc-600');
          btn.classList.add('bg-[#81b344]', 'text-white', 'shadow-md', 'shadow-[#81b344]/25');
        } else {
          btn.classList.add('bg-white', 'border', 'border-zinc-200', 'text-zinc-600');
        }
      } else {
        if (isTarget) {
          btn.classList.remove('text-zinc-500', 'hover:text-zinc-800', 'hover:bg-zinc-50');
          btn.classList.add('bg-[#81b344]', 'text-white', 'shadow-md', 'shadow-[#81b344]/25');
        } else {
          btn.classList.add('text-zinc-500', 'hover:text-zinc-800', 'hover:bg-zinc-50');
        }
      }
    });

    // Show active tab content
    document.querySelectorAll<HTMLElement>('.tab-content').forEach(c => c.classList.add('hidden'));
    const active = document.getElementById('tab-' + target);
    if (!active) return;
    active.classList.remove('hidden');

    // Scroll
    if (scrollToContent) {
      const firstSection = active.querySelector('section');
      const offset = firstSection
        ? firstSection.getBoundingClientRect().top + window.scrollY - 80
        : 0;
      window.scrollTo({ top: offset, behavior: 'smooth' });
    }

    // Reset + re-observe animations in newly visible tab
    active.querySelectorAll<HTMLElement>('.scroll-animate').forEach(el => {
      el.classList.remove('animate-fade-in-up');
      el.classList.add('opacity-0');
      el.style.opacity = '';
    });
    // Double rAF ensures layout is settled before observing
    requestAnimationFrame(() => requestAnimationFrame(() => initScrollAnimations(active)));
  }

  document.addEventListener('DOMContentLoaded', () => {
    // Low-end: kill all animations globally
    if (isLowEnd()) {
      document.querySelectorAll<HTMLElement>('.opacity-0').forEach(el => {
        el.style.opacity = '1';
        el.style.transform = 'none';
        el.style.animation = 'none';
        el.classList.remove('opacity-0');
      });
    }

    // Activate initial tab from URL hash or default
    const hash = window.location.hash.replace('#tab-', '');
    const initial: string = (VALID_TABS as readonly string[]).includes(hash) ? hash : 'kancelare';
    activateTab(initial, false);

    // Tab button clicks
    document.querySelectorAll<HTMLElement>('.tab-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const t = btn.dataset.tab;
        if (t) activateTab(t, true);
      });
    });

    // "Zjistit více" card clicks
    document.addEventListener('click', e => {
      const card = (e.target as HTMLElement).closest<HTMLElement>('[data-tab-link]');
      if (!card) return;
      const t = card.dataset.tabLink;
      if (t) activateTab(t, true);
    });
  });
</script>

