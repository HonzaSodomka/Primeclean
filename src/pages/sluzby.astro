const tabData = { kancelare, svj, airbnb };
---

<Layout title="Naše služby | PrimeClean">
  <main class="bg-white selection:bg-[#81b344]/30 selection:text-zinc-900">

    <!-- HERO -->
    <section class="relative pt-28 pb-20 md:pt-36 md:pb-28 lg:pt-44 lg:pb-36 bg-zinc-50 overflow-hidden">
      <!-- Safari fix: orby jen na desktopu, redukovaný blur -->
      <div class="hidden md:block pointer-events-none absolute -top-32 -right-32 w-[500px] h-[500px] rounded-full bg-[#81b344]/6" style="filter: blur(70px);"></div>
      <div class="hidden md:block pointer-events-none absolute -bottom-20 -left-20 w-[350px] h-[350px] rounded-full bg-[#81b344]/4" style="filter: blur(60px);"></div>

      <div class="relative z-10 max-w-[1100px] mx-auto px-5 md:px-8 lg:px-12 text-center">
        <div class="inline-flex items-center gap-2.5 px-5 py-2 rounded-full bg-white border border-zinc-200 shadow-sm mb-6 md:mb-8 opacity-0 animate-fade-in-up" style="animation-delay: 0ms;">
          <span class="w-1.5 h-1.5 rounded-full bg-[#81b344] animate-pulse flex-shrink-0"></span>
          <span class="text-[11px] sm:text-xs font-bold text-zinc-600 tracking-[0.15em] uppercase">Profesionální úklid Brno a okolí</span>
        </div>

        <h1 class="text-[2.75rem] sm:text-[3.75rem] md:text-6xl lg:text-[6rem] font-extrabold text-zinc-950 tracking-tighter leading-[1.05] md:leading-[0.95] mb-6 opacity-0 animate-fade-in-up" style="animation-delay: 150ms;">
          Naše <span class="text-[#6a9438]">služby.</span>
        </h1>

        <p class="text-base sm:text-lg md:text-[19px] lg:text-[21px] text-zinc-600 max-w-xl mx-auto leading-relaxed font-medium mb-10 md:mb-14 opacity-0 animate-fade-in-up" style="animation-delay: 300ms;">
          Specializujeme se na tři oblasti, kde máme vyladěné procesy a prověřené týmy. Vyberte si tu vaši.
        </p>

        <!-- TAB SWITCHER -->
        <div class="opacity-0 animate-fade-in-up" style="animation-delay: 450ms;">
          <div id="tab-switcher" class="hidden sm:inline-flex gap-2 p-1.5 bg-white border border-zinc-200 rounded-2xl shadow-sm">
            {tabs.map((tab, i) => (
              <button
                data-tab={tab.id}
                class={`tab-btn flex items-center gap-2.5 px-6 py-3.5 rounded-xl text-[14px] font-bold transition-all duration-200 whitespace-nowrap ${
                  i === 0
                    ? 'bg-[#81b344] text-white shadow-md shadow-[#81b344]/25'
                    : 'text-zinc-500 hover:text-zinc-800 hover:bg-zinc-50'
                }`}
              >
                <span class="w-4 h-4 flex-shrink-0" set:html={icons[tab.icon]} />
                {tab.label}
              </button>
            ))}
          </div>
          <div id="tab-switcher-mobile" class="sm:hidden flex flex-col gap-2 w-full max-w-xs mx-auto">
            {tabs.map((tab, i) => (
              <button
                data-tab={tab.id}
                class={`tab-btn flex items-center justify-center gap-2.5 w-full px-5 py-4 rounded-2xl text-[15px] font-bold transition-all duration-200 ${
                  i === 0
                    ? 'bg-[#81b344] text-white shadow-md shadow-[#81b344]/25'
                    : 'bg-white border border-zinc-200 text-zinc-600 hover:border-[#81b344]/40 hover:text-zinc-900'
                }`}
              >
                <span class="w-5 h-5 flex-shrink-0" set:html={icons[tab.icon]} />
                {tab.label}
              </button>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- TAB CONTENT -->
    {Object.entries(tabData).map(([id, data], tabIndex) => (
      <div id={`tab-${id}`} class={`tab-content ${id !== 'kancelare' ? 'hidden' : ''}`}>

        <!-- 1. HERO PANEL -->
        <section class="py-20 md:py-28 bg-white">
          <div class="max-w-[1200px] mx-auto px-5 md:px-8 lg:px-12">
            <div class={`flex flex-col gap-12 lg:gap-20 items-center ${ tabIndex % 2 === 0 ? 'lg:flex-row' : 'lg:flex-row-reverse' }`}>

              <div class="w-full lg:w-1/2">
                <div class="scroll-animate opacity-0 mb-5">
                  <span class="inline-block px-3 py-1.5 rounded-md bg-[#81b344]/10">
                    <span class="text-[12px] font-bold text-[#6a9438] tracking-[0.1em] uppercase">{data.tag}</span>
                  </span>
                </div>
                <h2 class="scroll-animate opacity-0 text-3xl sm:text-4xl md:text-5xl font-extrabold text-zinc-950 tracking-tighter leading-[1.1] mb-6 whitespace-pre-line" style="animation-delay: 80ms;">
                  {data.headline}
                </h2>
                <p class="scroll-animate opacity-0 text-[17px] md:text-[19px] text-zinc-600 font-medium leading-relaxed mb-10" style="animation-delay: 160ms;">
                  {data.sub}
                </p>
                <div class="scroll-animate opacity-0 flex flex-col sm:flex-row gap-3" style="animation-delay: 240ms;">
                  <a href="/kontakt" class="inline-flex items-center justify-center gap-2 px-8 py-4 text-[15px] font-bold text-white transition-all duration-300 ease-out bg-[#81b344] rounded-xl hover:bg-[#729f3c] hover:-translate-y-1 shadow-md shadow-[#81b344]/20">
                    {data.cta}
                    <span class="w-4 h-4" set:html={icons['arrow-right']} />
                  </a>
                  <a href={`#features-${id}`} class="inline-flex items-center justify-center gap-2 px-8 py-4 text-[15px] font-bold text-zinc-700 transition-all duration-300 ease-out bg-white border-2 border-zinc-200 rounded-xl hover:border-zinc-300 hover:bg-zinc-50 hover:-translate-y-1">
                    Co zahrnuje služba
                  </a>
