          </div>
        </section>

      </div>
    ))}

  </main>
</Layout>

<script is:inline>
  // ─── Safari & výkon detekce ───────────────────────────────────────────────
  (function () {
    const cores = navigator.hardwareConcurrency || 4;
    const ram = navigator.deviceMemory || 4;
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (cores <= 2 || ram <= 2 || reducedMotion) {
      document.documentElement.classList.add('low-end');
    }
  })();

  const VALID_TABS = ['kancelare', 'svj', 'airbnb'];

  function activateTab(target, scrollToContent) {
    if (!VALID_TABS.includes(target)) return;
    const allButtons = document.querySelectorAll('.tab-btn');
    const contents = document.querySelectorAll('.tab-content');
    const isLowEnd = document.documentElement.classList.contains('low-end');

    allButtons.forEach(b => {
      const isMobile = b.closest('#tab-switcher-mobile') !== null;
      const isTarget = b.getAttribute('data-tab') === target;
      b.classList.remove('bg-[#81b344]', 'text-white', 'shadow-md', 'shadow-[#81b344]/25');
      if (isMobile) {
        if (isTarget) {
          b.classList.remove('bg-white', 'border', 'border-zinc-200', 'text-zinc-600');
          b.classList.add('bg-[#81b344]', 'text-white', 'shadow-md', 'shadow-[#81b344]/25');
        } else {
          b.classList.add('bg-white', 'border', 'border-zinc-200', 'text-zinc-600');
        }
      } else {
        if (isTarget) {
          b.classList.remove('text-zinc-500', 'hover:text-zinc-800', 'hover:bg-zinc-50');
          b.classList.add('bg-[#81b344]', 'text-white', 'shadow-md', 'shadow-[#81b344]/25');
        } else {
          b.classList.add('text-zinc-500', 'hover:text-zinc-800', 'hover:bg-zinc-50');
        }
      }
    });

    contents.forEach(c => c.classList.add('hidden'));
    const active = document.getElementById('tab-' + target);
    if (!active) return;
    active.classList.remove('hidden');

    if (scrollToContent) {
      const heroSection = active.querySelector('section');
      if (heroSection) {
        const offset = heroSection.getBoundingClientRect().top + window.scrollY - 80;
        window.scrollTo({ top: offset, behavior: 'smooth' });
      } else {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }
    }

    const animEls = active.querySelectorAll('.scroll-animate');
    animEls.forEach(el => {
      el.classList.remove('animate-fade-in-up');
      el.classList.add('opacity-0');
      el.style.opacity = '';
    });
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        initScrollAnimations(active, isLowEnd);
      });
    });
  }

  function initScrollAnimations(scope, isLowEnd) {
    const els = scope.querySelectorAll('.scroll-animate');
    if (isLowEnd) {
      els.forEach(el => { el.classList.remove('opacity-0'); el.style.opacity = '1'; });
      return;
    }
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('animate-fade-in-up');
          entry.target.classList.remove('opacity-0');
          observer.unobserve(entry.target);
        }
      });
    }, { root: null, threshold: 0, rootMargin: '0px 0px -8% 0px' });
    els.forEach(el => observer.observe(el));
  }

  document.addEventListener('DOMContentLoaded', () => {
    const isLowEnd = document.documentElement.classList.contains('low-end');
    const hash = window.location.hash.replace('#tab-', '');
    const initialTab = VALID_TABS.includes(hash) ? hash : 'kancelare';
    activateTab(initialTab, false);

    document.querySelectorAll('.tab-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const target = btn.getAttribute('data-tab');
        activateTab(target, true);
      });
    });

    document.addEventListener('click', (e) => {
      const card = e.target.closest('[data-tab-link]');
      if (!card) return;
      const target = card.getAttribute('data-tab-link');
      activateTab(target, true);
    });
  });
</script>

<style is:global>
  @keyframes softFadeUp {
    0%   { opacity: 0; transform: translateY(22px); }
    100% { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in-up {
    animation-name: softFadeUp;
    animation-duration: 0.9s;
    animation-timing-function: cubic-bezier(0.25, 1, 0.4, 1);
    animation-fill-mode: both;
  }
  @media (prefers-reduced-motion: reduce) {
    .animate-fade-in-up, .scroll-animate {
      animation: none !important;
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
    .animate-pulse { animation: none !important; }
  }
  .low-end .animate-fade-in-up,
  .low-end .scroll-animate {
    animation: none !important;
    opacity: 1 !important;
    transform: none !important;
  }
  .low-end .animate-pulse { animation: none !important; }
  .low-end img { transition: none !important; }
</style>