---
import Layout from '../layouts/Layout.astro';

const tabs = [
  { id: 'kancelare', label: 'Kanceláře a firmy', icon: 'briefcase' },
  { id: 'svj', label: 'SVJ a bytové domy', icon: 'building-2' },
  { id: 'airbnb', label: 'Airbnb a apartmány', icon: 'key-round' },
];

const kancelare = {
  tag: 'Pravidelný úklid',
  headline: 'Úklid kanceláří,\nkterý prostě funguje.',
  sub: 'Zajišťujeme pravidelný úklid podle pevně domluveného harmonogramu. Žádné nahodilé návštěvy — jen profesionální servis, díky kterému se můžete plně soustředit na své podnikání.',
  image: 'https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&w=900&q=80',
  features: [
    { icon: 'calendar-check', title: 'Pevný harmonogram', desc: 'Úklid probíhá pravidelně — brzy ráno, večer nebo o víkendech. Vždy stejný rozsah, diskrétně a profesionálně.' },
    { icon: 'clipboard-list', title: 'Jasná pravidla a checklist', desc: 'Předem domluvený rozsah prací a checklist — jasně dané, co se uklízí, jak často a kdo za úklid odpovídá.' },
    { icon: 'users', title: 'Stálí pracovníci', desc: 'Úklid provádějí vždy stejní pracovníci, kteří prostory znají. Žádní cizí lidé, o nichž nic nevíte.' },
    { icon: 'smartphone', title: 'Přehled v aplikaci', desc: 'V aplikaci vidíte historii úklidů, provedené práce i poznámky. Přehled kdykoliv — bez telefonování a obíhání.' },
    { icon: 'shield-check', title: 'Spolehlivost bez starostí', desc: 'Máte jednoho partnera, který řeší úklid dlouhodobě. Komunikace rychlá, pravidla jasná, kvalita pod kontrolou.' },
    { icon: 'zap', title: 'Flexibilita na vyžádání', desc: 'Potřebujete mimořádný úklid před důležitou návštěvou nebo po firemním večírku? Řešíme to jednoduše a přímo.' },
  ],
  includes: [
    'Vysávání a vytírání podlah ve všech prostorách',
    'Vynášení odpadků a doplňování hygienických potřeb',
    'Stírání prachu z volných ploch stolů a nábytku',
    'Kompletní úklid a dezinfekce sociálního zázemí a kuchyněk',
    'Čištění skleněných příček a vstupních dveří',
  ],
  forWhom: [
    { icon: 'building', label: 'Administrativní budovy' },
    { icon: 'laptop', label: 'Coworkingy a sdílené kanceláře' },
    { icon: 'stethoscope', label: 'Ordinace a zdravotnická zařízení' },
    { icon: 'utensils', label: 'Restaurace a kavárny' },
  ],
};

const svj = {
  tag: 'Správa budov',
  headline: 'Čisté společné prostory\nbez starostí.',
  sub: 'Zajišťujeme kompletní a pravidelný úklid panelových domů a SVJ. Stálí pracovníci, jasný plán a přehled v aplikaci — správce ani výbor nemusí řešit každodenní kontrolu.',
  image: 'https://images.unsplash.com/photo-1545324418-cc1a3fa10c00?auto=format&fit=crop&w=900&q=80',
  features: [
    { icon: 'calendar-check', title: 'Pravidelný harmonogram', desc: 'Úklid týdně, 2× týdně nebo individuálně podle potřeb domu. Vždy stejný rozsah, žádné výmluvy.' },
    { icon: 'clipboard-list', title: 'Jasná pravidla a checklist', desc: 'Každý dům má vlastní plán úklidu a checklist — jasně dané, co se uklízí, jak často a kdo za to odpovídá.' },
    { icon: 'users', title: 'Stálí pracovníci', desc: 'Úklid provádějí vždy stejní pracovníci, kteří dům znají. Obyvatelé vidí pořád stejné obličeje.' },
    { icon: 'smartphone', title: 'Přehled v aplikaci', desc: 'V aplikaci vidíte historii úklidů, provedené práce i poznámky. Přehled kdykoliv — bez telefonování a obíhání.' },
    { icon: 'shield-check', title: 'Spolehlivost pro SVJ i správce', desc: 'Máte jednoho partnera, který řeší úklid dlouhodobě. Komunikace rychlá, pravidla jasná, kvalita pod kontrolou.' },
    { icon: 'sliders-horizontal', title: 'Plán pro každý dům zvlášť', desc: 'Jinak se uklízí malý dům, jinak velký panelák. Plán nastavíme přesně podle reálných potřeb objektu.' },
  ],
  includes: [
    'Zametení a vytření podlah ve společných prostorách',
    'Otření zábradlí, madel a schodiště',
    'Úklid vstupních dveří a prosklených ploch',
    'Otření poštovních schránek a vypínačů',
    'Úklid výtahu (pokud je součástí domu)',
  ],
  forWhom: [
    { icon: 'building-2', label: 'Společenství vlastníků jednotek (SVJ)' },
    { icon: 'key-round', label: 'Bytová družstva' },
    { icon: 'briefcase', label: 'Správci nemovitostí' },
    { icon: 'home', label: 'Majitelé bytových domů' },
  ],
};

const airbnb = {
  tag: 'Krátkodobé pronájmy',
  headline: 'Apartmán připravený\npro každého hosta.',
  sub: 'Zajišťujeme rychlý a spolehlivý úklid mezi pobyty hostů. Stálí pracovníci, jasný rozsah prací a přehled v aplikaci — vy se staráte o hosty, my o čistotu.',
  image: 'https://images.unsplash.com/photo-1522708323590-d24dbb6b0267?auto=format&fit=crop&w=900&q=80',
  features: [
    { icon: 'zap', title: 'Rychlá příprava', desc: 'Úklid zvládneme ve vašem časovém okně mezi odjezdem a příjezdem hostů. Bez stresu a zpoždění.' },
    { icon: 'clipboard-list', title: 'Jasný rozsah prací', desc: 'Předem domluvený checklist — jasně dané, co se uklízí při každé návštěvě. Vždy stejný standard.' },
    { icon: 'users', title: 'Stálí pracovníci', desc: 'Úklid provádějí vždy stejní pracovníci, kteří apartmán znají. Žádní náhodní lidé v soukromém prostoru.' },
    { icon: 'smartphone', title: 'Přehled v aplikaci', desc: 'Po každém úklidu vidíte v aplikaci, co bylo provedeno a v jakém stavu apartmán hosté přebírají.' },
    { icon: 'shirt', title: 'Výměna ložního prádla', desc: 'Zajistíme výměnu a doplnění čistého prádla a ručníků před každým příjezdem hostů.' },
    { icon: 'shield-check', title: 'Spolehlivost pro pronajímatele', desc: 'Máte jednoho partnera, který řeší úklid dlouhodobě. Komunikace rychlá, pravidla jasná, kvalita pod kontrolou.' },
  ],
  includes: [
    'Kompletní úklid koupelny a WC',
    'Úklid kuchyně včetně spotřebičů',
    'Vysávání a vytírání podlah',
    'Výměna ložního prádla a ručníků',
    'Doplnění spotřebního materiálu',
    'Kontrola a hlášení případného poškození',
  ],
  forWhom: [
    { icon: 'home', label: 'Majitelé Airbnb apartmánů' },
    { icon: 'building', label: 'Správci více nemovitostí' },
    { icon: 'key-round', label: 'Provozovatelé apartmánových domů' },
    { icon: 'globe', label: 'Booking.com pronajímatelé' },
  ],
};

const tabData: Record<string, typeof kancelare> = { kancelare, svj, airbnb };
---

<Layout title="Naše služby | PrimeClean">
  <main class="bg-white selection:bg-[#81b344]/30 selection:text-zinc-900">

    <!-- HERO -->
    <section class="relative pt-28 pb-20 md:pt-36 md:pb-28 lg:pt-44 lg:pb-36 bg-zinc-50 overflow-hidden">

      <!-- Dekorativní blob pozadí -->
      <div class="pointer-events-none absolute -top-32 -right-32 w-[500px] h-[500px] rounded-full bg-[#81b344]/6 blur-[100px]"></div>
      <div class="pointer-events-none absolute -bottom-20 -left-20 w-[350px] h-[350px] rounded-full bg-[#81b344]/4 blur-[80px]"></div>

      <div class="relative z-10 max-w-[1100px] mx-auto px-5 md:px-8 lg:px-12 text-center">

        <div class="inline-flex items-center gap-2.5 px-5 py-2 rounded-full bg-white border border-zinc-200 shadow-sm mb-6 md:mb-8 opacity-0 animate-fade-in-up" style="animation-delay: 0ms;">
          <span class="w-1.5 h-1.5 rounded-full bg-[#81b344] animate-pulse flex-shrink-0"></span>
          <span class="text-[11px] sm:text-xs font-bold text-zinc-600 tracking-[0.15em] uppercase">Profesionální úklid Brno a okolí</span>
        </div>

        <h1 class="text-[2.75rem] sm:text-[3.75rem] md:text-6xl lg:text-[6rem] font-extrabold text-zinc-950 tracking-tighter leading-[1.05] md:leading-[0.95] mb-6 opacity-0 animate-fade-in-up" style="animation-delay: 150ms;">
          Naše <span class="text-[#6a9438]">služby.</span>
        </h1>

        <p class="text-base sm:text-lg md:text-[19px] lg:text-[21px] text-zinc-600 max-w-xl mx-auto leading-relaxed font-medium mb-10 md:mb-14 opacity-0 animate-fade-in-up" style="animation-delay: 300ms;">
          Specializujeme se na tři oblasti, kde máme vyladěné procesy a prověřené týmy. Vyberte si tu vaši.
        </p>

        <!-- TAB SWITCHER -->
        <div class="opacity-0 animate-fade-in-up" style="animation-delay: 450ms;">
          <!-- Desktop: inline horizontally -->
          <div id="tab-switcher" class="hidden sm:inline-flex gap-2 p-1.5 bg-white border border-zinc-200 rounded-2xl shadow-sm">
            {tabs.map((tab, i) => (
              <button
                data-tab={tab.id}
                class={`tab-btn flex items-center gap-2.5 px-6 py-3.5 rounded-xl text-[14px] font-bold transition-all duration-200 whitespace-nowrap ${
                  i === 0
                    ? 'bg-[#81b344] text-white shadow-md shadow-[#81b344]/25'
                    : 'text-zinc-500 hover:text-zinc-800 hover:bg-zinc-50'
                }`}
              >
                <i data-lucide={tab.icon} class="w-4 h-4 flex-shrink-0"></i>
                {tab.label}
              </button>
            ))}
          </div>

          <!-- Mobil: full-width sloupcová tlačítka -->
          <div id="tab-switcher-mobile" class="sm:hidden flex flex-col gap-2 w-full max-w-xs mx-auto">
            {tabs.map((tab, i) => (
              <button
                data-tab={tab.id}
                class={`tab-btn flex items-center justify-center gap-2.5 w-full px-5 py-4 rounded-2xl text-[15px] font-bold transition-all duration-200 ${
                  i === 0
                    ? 'bg-[#81b344] text-white shadow-md shadow-[#81b344]/25'
                    : 'bg-white border border-zinc-200 text-zinc-600 hover:border-[#81b344]/40 hover:text-zinc-900'
                }`}
              >
                <i data-lucide={tab.icon} class="w-5 h-5 flex-shrink-0"></i>
                {tab.label}
              </button>
            ))}
          </div>
        </div>

      </div>
    </section>

    <!-- TAB CONTENT -->
    {Object.entries(tabData).map(([id, data]) => (
      <div id={`tab-${id}`} class={`tab-content ${id !== 'kancelare' ? 'hidden' : ''}`}>

        <!-- MAIN PANEL -->
        <section class="py-20 md:py-28 bg-white">
          <div class="max-w-[1200px] mx-auto px-5 md:px-8 lg:px-12">
            <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-20">

              <div class="w-full lg:w-1/2">
                <div class="scroll-animate opacity-0 inline-block px-3 py-1.5 rounded-md bg-[#81b344]/10 mb-5">
                  <span class="text-[12px] font-bold text-[#6a9438] tracking-[0.1em] uppercase">{data.tag}</span>
                </div>
                <h2 class="scroll-animate opacity-0 text-3xl sm:text-4xl md:text-5xl font-extrabold text-zinc-950 tracking-tighter leading-[1.1] mb-6 whitespace-pre-line" style="animation-delay: 80ms;">
                  {data.headline}
                </h2>
                <p class="scroll-animate opacity-0 text-[17px] md:text-[19px] text-zinc-600 font-medium leading-relaxed mb-8" style="animation-delay: 160ms;">
                  {data.sub}
                </p>
                <div class="scroll-animate opacity-0" style="animation-delay: 240ms;">
                  <a href="/kontakt" class="inline-flex items-center justify-center gap-2 px-8 py-4 text-[16px] font-bold text-white transition-all duration-300 ease-out bg-[#81b344] rounded-xl hover:bg-[#729f3c] hover:-translate-y-1 shadow-md shadow-[#81b344]/20">
                    Chci nezávaznou nabídku
                    <i data-lucide="arrow-right" class="w-4 h-4"></i>
                  </a>
                </div>
              </div>

              <div class="scroll-animate opacity-0 w-full lg:w-1/2" style="animation-delay: 200ms;">
                <div class="relative aspect-[4/3] rounded-[2rem] overflow-hidden bg-zinc-100 border border-zinc-200/50 shadow-lg group">
                  <img
                    src={data.image}
                    alt={data.tag}
                    class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.03]"
                    loading="lazy"
                    referrerpolicy="no-referrer"
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-zinc-950/20 to-transparent pointer-events-none"></div>
                  <div class="absolute bottom-4 left-4 px-3 py-1.5 rounded-full bg-white/90 backdrop-blur-sm shadow-sm">
                    <span class="text-[12px] font-bold text-zinc-700 tracking-[0.06em] uppercase">{data.tag}</span>
                  </div>
                </div>
              </div>

            </div>
          </div>
        </section>

        <!-- FEATURES GRID -->
        <section class="py-20 md:py-28 bg-zinc-50 relative overflow-hidden">
          <div class="pointer-events-none absolute top-0 right-0 w-[400px] h-[400px] rounded-full bg-[#81b344]/4 blur-[80px]"></div>

          <div class="max-w-[1200px] mx-auto px-5 md:px-8 lg:px-12 relative z-10">

            <div class="scroll-animate opacity-0 text-center max-w-2xl mx-auto mb-16">
              <div class="mb-4">
                <span class="text-[13px] font-bold text-[#81b344] tracking-[0.2em] uppercase">Proč zvolit PrimeClean</span>
              </div>
              <h2 class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-zinc-950 tracking-tighter leading-[1.1]">
                Co od nás <span class="text-[#6a9438]">dostanete.</span>
              </h2>
            </div>

            <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
              {data.features.map((f, index) => (
                <div
                  class="scroll-animate opacity-0 relative bg-white rounded-[1.5rem] p-8 border border-zinc-100 transition-all duration-300 ease-out hover:-translate-y-1.5 hover:shadow-xl hover:border-[#81b344]/25 overflow-hidden group"
                  style={`animation-delay: ${index * 100}ms`}
                >
                  <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none" style="background: radial-gradient(ellipse at top left, rgba(129,179,68,0.05) 0%, transparent 70%);"></div>
                  <span class="absolute top-5 right-7 text-[4rem] font-extrabold text-[#81b344]/8 leading-none select-none pointer-events-none">
                    {String(index + 1).padStart(2, '0')}
                  </span>
                  <div class="w-14 h-14 rounded-2xl bg-zinc-50 border border-zinc-200 flex items-center justify-center text-[#6a9438] mb-8 group-hover:border-[#81b344]/40 group-hover:bg-[#81b344]/8 group-hover:scale-110 transition-all duration-300">
                    <i data-lucide={f.icon} class="w-6 h-6"></i>
                  </div>
                  <h3 class="text-[19px] font-bold text-zinc-950 tracking-tight leading-snug mb-3">{f.title}</h3>
                  <p class="text-[15px] font-medium text-zinc-600 leading-relaxed">{f.desc}</p>
                </div>
              ))}
            </div>

          </div>
        </section>

        <!-- CO ZAHRNUJE + PRO KOHO -->
        <section class="py-20 md:py-28 bg-white">
          <div class="max-w-[1200px] mx-auto px-5 md:px-8 lg:px-12">
            <div class="grid lg:grid-cols-2 gap-12 lg:gap-20">

              <!-- CO ZAHRNUJE -->
              <div class="scroll-animate opacity-0">
                <div class="mb-4">
                  <span class="text-[13px] font-bold text-[#81b344] tracking-[0.2em] uppercase">Rozsah služby</span>
                </div>
                <h2 class="text-2xl sm:text-3xl md:text-4xl font-extrabold text-zinc-950 tracking-tighter leading-[1.1] mb-8">
                  Co zahrnuje <span class="text-[#6a9438]">každá návštěva.</span>
                </h2>
                <ul class="flex flex-col gap-3">
                  {data.includes.map((item, i) => (
                    <li
                      class="scroll-animate opacity-0 flex items-start gap-4 text-[16px] text-zinc-700 font-medium"
                      style={`animation-delay: ${i * 60}ms`}
                    >
                      <div class="flex-shrink-0 mt-0.5 w-5 h-5 rounded-full bg-[#81b344] flex items-center justify-center text-white">
                        <i data-lucide="check" class="w-3 h-3" style="stroke-width: 3"></i>
                      </div>
                      {item}
                    </li>
                  ))}
                </ul>
              </div>

              <!-- PRO KOHO -->
              <div class="scroll-animate opacity-0" style="animation-delay: 150ms;">
                <div class="mb-4">
                  <span class="text-[13px] font-bold text-[#81b344] tracking-[0.2em] uppercase">Cílová skupina</span>
                </div>
                <h2 class="text-2xl sm:text-3xl md:text-4xl font-extrabold text-zinc-950 tracking-tighter leading-[1.1] mb-8">
                  Pro koho je tato <span class="text-[#6a9438]">služba určena.</span>
                </h2>
                <div class="grid grid-cols-2 gap-4">
                  {data.forWhom.map((item, i) => (
                    <div
                      class="scroll-animate opacity-0 flex items-center gap-3 p-4 bg-zinc-50 rounded-2xl border border-zinc-100 hover:border-[#81b344]/30 hover:bg-[#81b344]/5 hover:-translate-y-0.5 transition-all duration-200 group"
                      style={`animation-delay: ${i * 60}ms`}
                    >
                      <div class="flex-shrink-0 w-9 h-9 rounded-xl bg-white border border-zinc-200 flex items-center justify-center text-[#6a9438] group-hover:border-[#81b344]/30 group-hover:scale-110 transition-all duration-200">
                        <i data-lucide={item.icon} class="w-4 h-4"></i>
                      </div>
                      <span class="text-[14px] font-semibold text-zinc-700 leading-snug break-words hyphens-auto min-w-0">
                        {item.label}
                      </span>
                    </div>
                  ))}
                </div>
              </div>

            </div>
          </div>
        </section>

        <!-- UKAZKY PRACE placeholder -->
        <section class="py-20 md:py-28 bg-zinc-50">
          <div class="max-w-[1200px] mx-auto px-5 md:px-8 lg:px-12">
            <div class="scroll-animate opacity-0 text-center max-w-2xl mx-auto mb-12">
              <div class="mb-4">
                <span class="text-[13px] font-bold text-[#81b344] tracking-[0.2em] uppercase">Fotogalerie</span>
              </div>
              <h2 class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-zinc-950 tracking-tighter leading-[1.1]">
                Ukázky <span class="text-[#6a9438]">naší práce.</span>
              </h2>
              <p class="mt-4 text-[16px] text-zinc-500 font-medium">Fotografie z reálných zakázek budou brzy k dispozici.</p>
            </div>
            <!-- Grid placeholderů -->
            <div class="grid grid-cols-2 md:grid-cols-3 gap-4 lg:gap-6">
              {[1,2,3,4,5,6].map((n) => (
                <div
                  class="scroll-animate opacity-0 relative aspect-[4/3] rounded-2xl overflow-hidden bg-zinc-200 border border-zinc-200 group"
                  style={`animation-delay: ${(n-1) * 70}ms`}
                >
                  <div class="absolute inset-0 flex flex-col items-center justify-center gap-2 text-zinc-400">
                    <i data-lucide="image" class="w-8 h-8"></i>
                    <span class="text-[12px] font-semibold tracking-wide uppercase">Foto brzy</span>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </section>

        <!-- CTA -->
        <section class="py-16 md:py-24 bg-zinc-950 relative overflow-hidden">
          <div class="pointer-events-none absolute -top-40 left-1/2 -translate-x-1/2 w-[600px] h-[300px] rounded-full bg-[#81b344]/10 blur-[80px]"></div>
          <div class="relative z-10 max-w-[900px] mx-auto px-5 md:px-8 lg:px-12 text-center">
            <div class="scroll-animate opacity-0 mb-4">
              <span class="text-[13px] font-bold text-[#81b344] tracking-[0.2em] uppercase">Spolupráce</span>
            </div>
            <h2 class="scroll-animate opacity-0 text-3xl sm:text-4xl md:text-5xl font-extrabold text-white tracking-tighter leading-[1.1] mb-6" style="animation-delay: 80ms;">
              Zajímá vás <span class="text-[#81b344]">spolupráce?</span>
            </h2>
            <p class="scroll-animate opacity-0 text-[17px] text-zinc-400 font-medium leading-relaxed mb-10 max-w-xl mx-auto" style="animation-delay: 160ms;">
              Připravíme vám nezávaznou nabídku na míru. Stačí nás kontaktovat — zbytek zařídíme my.
            </p>
            <div class="scroll-animate opacity-0" style="animation-delay: 240ms;">
              <a href="/kontakt" class="inline-flex items-center justify-center gap-2 px-10 py-4 text-[16px] font-bold text-zinc-950 transition-all duration-300 ease-out bg-[#81b344] rounded-xl hover:bg-white hover:-translate-y-1 shadow-md shadow-[#81b344]/20">
                Chci nezávazně nacenit úklid
                <i data-lucide="arrow-right" class="w-5 h-5"></i>
              </a>
            </div>
          </div>
        </section>

      </div>
    ))}

  </main>
</Layout>

<script src="https://unpkg.com/lucide@latest" is:inline></script>
<script is:inline>
  (function () {
    const cores = navigator.hardwareConcurrency || 4;
    const ram = navigator.deviceMemory || 4;
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (cores <= 2 || ram <= 2 || reducedMotion) {
      document.documentElement.classList.add('low-end');
    }
  })();

  document.addEventListener('DOMContentLoaded', () => {
    lucide.createIcons();

    const isLowEnd = document.documentElement.classList.contains('low-end');

    function initScrollAnimations(scope) {
      const els = scope.querySelectorAll('.scroll-animate');
      if (isLowEnd) {
        els.forEach(el => {
          el.classList.remove('opacity-0');
          el.style.opacity = '1';
        });
        return;
      }
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('animate-fade-in-up');
            entry.target.classList.remove('opacity-0');
            observer.unobserve(entry.target);
          }
        });
      }, { root: null, threshold: 0, rootMargin: '0px 0px -8% 0px' });
      els.forEach(el => observer.observe(el));
    }

    const defaultTab = document.getElementById('tab-kancelare');
    if (defaultTab) initScrollAnimations(defaultTab);

    const allButtons = document.querySelectorAll('.tab-btn');
    const contents = document.querySelectorAll('.tab-content');

    allButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        const target = btn.getAttribute('data-tab');

        allButtons.forEach(b => {
          const isMobile = b.closest('#tab-switcher-mobile') !== null;
          b.classList.remove('bg-[#81b344]', 'text-white', 'shadow-md', 'shadow-[#81b344]/25');
          if (isMobile) {
            b.classList.remove('bg-[#81b344]');
            b.classList.add('bg-white', 'border', 'border-zinc-200', 'text-zinc-600');
          } else {
            b.classList.add('text-zinc-500', 'hover:text-zinc-800', 'hover:bg-zinc-50');
          }
        });

        const isMobileBtn = btn.closest('#tab-switcher-mobile') !== null;
        btn.classList.add('bg-[#81b344]', 'text-white', 'shadow-md', 'shadow-[#81b344]/25');
        if (isMobileBtn) {
          btn.classList.remove('bg-white', 'border', 'border-zinc-200', 'text-zinc-600');
        } else {
          btn.classList.remove('text-zinc-500', 'hover:text-zinc-800', 'hover:bg-zinc-50');
        }

        allButtons.forEach(b => {
          if (b !== btn && b.getAttribute('data-tab') === target) {
            b.classList.add('bg-[#81b344]', 'text-white', 'shadow-md', 'shadow-[#81b344]/25');
            const isMob = b.closest('#tab-switcher-mobile') !== null;
            if (isMob) {
              b.classList.remove('bg-white', 'border', 'border-zinc-200', 'text-zinc-600');
            } else {
              b.classList.remove('text-zinc-500', 'hover:text-zinc-800', 'hover:bg-zinc-50');
            }
          }
        });

        contents.forEach(c => c.classList.add('hidden'));
        const active = document.getElementById('tab-' + target);
        if (!active) return;

        active.classList.remove('hidden');
        lucide.createIcons();

        const animEls = active.querySelectorAll('.scroll-animate');
        animEls.forEach(el => {
          el.classList.remove('animate-fade-in-up');
          el.classList.add('opacity-0');
          el.style.opacity = '';
        });

        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            initScrollAnimations(active);
          });
        });
      });
    });
  });
</script>

<style is:global>
  @keyframes softFadeUp {
    0%   { opacity: 0; transform: translateY(22px); }
    100% { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in-up {
    animation-name: softFadeUp;
    animation-duration: 0.85s;
    animation-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
    animation-fill-mode: both;
  }
  @media (prefers-reduced-motion: reduce) {
    .animate-fade-in-up, .scroll-animate {
      animation: none !important;
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
    .animate-pulse { animation: none !important; }
  }
  .low-end .animate-fade-in-up,
  .low-end .scroll-animate {
    animation: none !important;
    opacity: 1 !important;
    transform: none !important;
  }
  .low-end .animate-pulse { animation: none !important; }
  .low-end img { transition: none !important; }
</style>
