---
import Layout from '../layouts/Layout.astro';

const tabs = [
  { id: 'kancelare', label: 'Kanceláře a firmy',  icon: 'briefcase'  },
  { id: 'svj',       label: 'SVJ a bytové domy',  icon: 'building-2' },
  { id: 'airbnb',    label: 'Airbnb a apartmány', icon: 'key-round'  },
];

const kancelare = {
  tag: 'Pravidelný úklid',
  tagBadge: 'Nejpopulárnější',
  headline: 'Úklid kanceláří,\nkterý prostě funguje.',
  sub: 'Většina klientů k nám přichází proto, že předchozí firma nedodržovala termíny nebo měnila pracovníky každý měsíc. My nastavujeme pravidelný harmonogram, stálý tým a vše sledujete ve webové aplikaci — bez telefonování a doptávání.',
  cta: 'Nacenit úklid kanceláře',
  image: '/sluzba-kancelare.webp',
  imageAlt: 'Profesionální úklid kanceláří a firem v Brně — PrimeClean',
  imageWidth: 800, imageHeight: 600,
  services: [
    { icon: 'footprints',  title: 'Kompletní péče o podlahy',      desc: 'Vysávání koberců a vytírání tvrdých podlah (laminát, dlažba, vinyl) profesionální neutralizační chemií.' },
    { icon: 'monitor',     title: 'Prach a povrchy',               desc: 'Otření prachu z pracovních stolů (volné plochy), parapetů, polic a skříní do výšky 1,7 m.' },
    { icon: 'keyboard',    title: 'IT technika',                   desc: 'Šetrné očištění monitorů, klávesnic a tiskáren speciální antistatickou utěrkou.' },
    { icon: 'droplets',    title: 'Hygienické zázemí',             desc: 'Hloubková dezinfekce toalet, umyvadel, zrcadel a obkladů. Leštění vodovodních baterií.' },
    { icon: 'coffee',      title: 'Kuchyňka a denní místnost',     desc: 'Otření kuchyňské linky, dřezu a vnějších ploch spotřebičů (lednice, mikrovlnka, kávovar).' },
    { icon: 'trash-2',     title: 'Odpadové hospodářství',         desc: 'Vynesení všech košů, výměna sáčků a odvoz tříděného odpadu do domovních kontejnerů.' },
    { icon: 'door-open',   title: 'Reprezentativní vstup',         desc: 'Čištění skleněných výplní vnitřních dveří, leštění klik a otření vypínačů — nejčastější zdroj bakterií.' },
    { icon: 'camera',      title: 'Fotoreport ve webové aplikaci', desc: 'Po každém úklidu nahrajeme fotodokumentaci přímo do webové aplikace PrimeClean — vidíte výsledky okamžitě v prohlížeči.' },
  ],
  material: [
    { icon: 'scroll',       label: 'Hygienický papír',      desc: 'Toaletní papíry, papírové ručníky, kapesníčky.' },
    { icon: 'spray-can',    label: 'Drogerie a dezinfekce', desc: 'Tekutá mýdla, dezinfekce, krémy na ruce.' },
    { icon: 'shopping-bag', label: 'Odpadkové pytle',       desc: 'Všechny velikosti sáčků do všech typů košů.' },
    { icon: 'utensils',     label: 'Vybavení kuchyňky',     desc: 'Tablety a sůl do myčky, saponáty na nádobí.' },
  ],
  forWhom: [
    { icon: 'building',    label: 'Administrativní budovy'           },
    { icon: 'laptop',      label: 'Coworkingy a sdílené kanceláře'   },
    { icon: 'stethoscope', label: 'Ordinace a zdravotnická zařízení' },
    { icon: 'utensils',    label: 'Restaurace a kavárny'             },
  ],
};

const svj = {
  tag: 'Správa budov',
  tagBadge: 'Pro SVJ a správce',
  headline: 'Čisté společné prostory\nbez starostí.',
  sub: 'Správci a výbory SVJ nejčastěji řeší reklamace od obyvatel nebo zoufale shání náhradu za brigádníky. My dodáváme stálý tým se stálým harmonogramem — a každý úklid je doložen fotodokumentací ve webové aplikaci.',
  cta: 'nabídku pro SVJ',
  image: '/sluzba-svj.webp',
  imageAlt: 'Úklid společných prostor SVJ a bytových domů v Brně — PrimeClean',
  imageWidth: 800, imageHeight: 600,
  services: [
    { icon: 'calendar-check', title: 'Pravidelný servis',       desc: 'Zametání a vytírání chodeb, sklepů, čištění zábradlí, madel, parapetů, schránek a vypínačů.' },
    { icon: 'door-open',      title: 'Péče o vstupy',           desc: 'Leštění prosklených dveří a čištění vstupních prostor — první dojem, který vidí každý.' },
    { icon: 'arrow-up-down',  title: 'Výtahy',                  desc: 'Kompletní úklid kabiny, leštění nerezů a zrcadel. Pravidelně a bez výmluv.' },
    { icon: 'camera',         title: 'Digitální standard',      desc: 'Každý úklid je doložen fotodokumentací ve webové aplikaci PrimeClean — průhlednost pro správce i obyvatele bez instalace.' },
    { icon: 'spray-can',      title: 'Chemie a pomůcky v ceně', desc: 'Veškerá profesionální čisticí chemie a pracovní pomůcky jsou standardní součástí každé návštěvy bez příplatku.' },
  ],
  winter: [
    { icon: 'droplets',     title: 'Neutralizace soli', desc: 'Použití speciální chemie, která odstraňuje bílé mapy z dlažby.' },
    { icon: 'shield-check', title: 'Ochrana povrchů',   desc: 'Intenzivnější odstraňování štěrku, aby nedošlo k poškrábání podlah.' },
    { icon: 'layers',       title: 'Čištění rohoží',    desc: 'Aby se nečistoty netahaly dále do pater.' },
  ],
  forWhom: [
    { icon: 'building-2', label: 'Společenství vlastníků (SVJ)' },
    { icon: 'key-round',  label: 'Bytová družstva'               },
    { icon: 'briefcase',  label: 'Správci nemovitostí'           },
    { icon: 'home',       label: 'Majitelé bytových domů'        },
  ],
};

const airbnb = {
  tag: 'Krátkodobé pronájmy',
  tagBadge: 'Airbnb & Booking',
  headline: 'Apartmán připravený\npro každého hosta.',
  sub: 'Hostitelé nejvíce stresují z toho, že apartmán nebude včas připravený nebo že nemají přehled o jeho stavu, když jsou mimo město. My řešíme obě věci najednou.',
  cta: 'nabídku pro Airbnb',
  image: '/sluzba-airbnb.webp',
  imageAlt: 'Úklid Airbnb apartmánů a krátkodobých pronájmů v Brně — PrimeClean',
  imageWidth: 800, imageHeight: 600,
  standard: [
    { icon: 'bed-double',   title: 'Hotelový styling',     desc: 'Profesionální stlaní postelí, načechrání polštářů a příprava ručníků pro hosty.' },
    { icon: 'sparkles',     title: 'Hloubková dezinfekce', desc: 'Koupelny a toalety čistíme s důrazem na hygienu a leštění všech povrchů.' },
    { icon: 'coffee',       title: 'Kuchyňský servis',     desc: 'Kontrola lednice, umytí nádobí, vyčištění kávovaru a vynesení odpadu.' },
    { icon: 'camera',       title: 'Detailní fotoreport',  desc: 'Po každém úklidu nahrajeme do webové aplikace fotky připraveného bytu — důkaz kvality přímo v prohlížeči.' },
    { icon: 'alert-circle', title: 'Hlášení škod',         desc: 'Pokud hosté něco poškodí, okamžitě to vyfotíme do webové aplikace. Máte v ruce důkaz pro Airbnb k vymáhání náhrady.' },
  ],
  laundry: [
    { set: 'Set 1', desc: 'Aktuálně na posteli pro hosta.' },
    { set: 'Set 2', desc: 'Čistý a připravený v bytě pro okamžitý check-in.' },
    { set: 'Set 3', desc: 'Špinavý set v procesu praní a čištění.' },
  ],
  extras: [
    { icon: 'shirt', label: 'Kompletní servis prádla', price: '250 Kč / set', desc: 'Odvezeme špinavé, přivezeme profesionálně vyprané a vyžehlené. Žádná starost o sušení v bytě.' },
    { icon: 'box',   label: 'Materiálový balíček',     price: 'Dle spotřeby',  desc: 'Dodáme vlastní toaletní papír, mýdlo, kapsle do kávovaru a tablety do myčky. Nemusíte hlídat nákupy.' },
    { icon: 'gift',  label: 'Welcome balíčky',         price: 'Dle dohody',    desc: 'Připravíme víno, čokoládu nebo lokální dárky přesně podle vašich instrukcí pro nezapomenutelný zážitek hostů.' },
    { icon: 'brush', label: 'Generální úklid',         price: 'Individuálně',  desc: 'Hloubkové čištění (např. po sezóně nebo malování) naceníme individuálně.' },
  ],
  app: [
    { icon: 'bell-ring',     label: 'Notifikace o dokončení', desc: 'Ihned víte, že můžete hostům potvrdit dřívější příjezd.' },
    { icon: 'package-check', label: 'Skladové zásoby',        desc: 'Ve webové aplikaci vidíte, kolik a čeho bylo použito.' },
    { icon: 'wrench',        label: 'Hlášení závad',          desc: 'Dozvíte se o protékajícím záchodu nebo prasklé žárovce dřív, než si začne stěžovat host.' },
  ],
  forWhom: [
    { icon: 'home',      label: 'Majitelé Airbnb apartmánů'       },
    { icon: 'building',  label: 'Správci více nemovitostí'         },
    { icon: 'key-round', label: 'Provozovatelé apartmánových domů' },
    { icon: 'globe',     label: 'Booking.com pronajímatelé'        },
  ],
};
---

<Layout
  title="Úklidové služby Brno — Kanceláře, SVJ a Airbnb | PrimeClean"
  description="Profesionální úklidové služby v Brně. Úklid kanceláří a firem, úklid SVJ a bytových domů, úklid Airbnb apartmánů. Spolehlivá úklidová firma Brno s pojištěním 5 mil. Kč."
>
  <main class="bg-white selection:bg-[#81b344]/30 selection:text-zinc-900">

    <!-- SEO: skrytý blok pro vyhledávače, vizuálně neviditelný -->
    <div class="sr-only" aria-hidden="true">
      <h1>Úklidové služby Brno — kanceláře, SVJ a Airbnb</h1>
      <p>PrimeClean nabízí profesionální úklidové služby v Brně a okolí. Specializujeme se na tři oblasti: úklid kanceláří a firem v Brně, úklid SVJ a bytových domů v Brně a úklid Airbnb apartmánů v Brně.</p>

      <h2>Úklid kanceláří Brno</h2>
      <p>Pravidelný úklid kanceláří, administrativních budov a firemních prostor v Brně. Stálý tým pracovníků, jasný harmonogram a kontrola přes webovou aplikaci s fotodokumentací. Úklid firem Brno bez výmluv a bez přepisování pracovníků každý měsíc.</p>

      <h2>Úklid SVJ Brno</h2>
      <p>Pravidelný úklid společných prostor SVJ a bytových domů v Brně. Úklid vchodů, chodeb, schodišť, výtahů a suterénních prostor. Spolehlivé řešení pro správce nemovitostí, bytová družstva a SVJ v Brně a okolí. Úklid bytových domů Brno s fotoreportem po každém úklidu.</p>

      <h2>Úklid Airbnb Brno</h2>
      <p>Profesionální úklid apartmánů a bytů pro krátkodobé pronájmy v Brně. Rychlá a spolehlivá příprava mezi pobyty hostů, výměna lůžkovin, doplnění spotřebního materiálu. Úklid pro hostitele Airbnb v Brně s online přehledem a fotodokumentací.</p>
    </div>

    <!-- ═══════════ HERO ═══════════ -->
    <section class="relative pt-24 pb-16 md:pt-32 md:pb-20 lg:pt-40 lg:pb-28 bg-zinc-50 overflow-hidden">
      <div class="hidden md:block pointer-events-none absolute -top-32 -right-32 w-[600px] h-[600px] rounded-full bg-[#81b344]/5 blur-[80px]"></div>
      <div class="hidden md:block pointer-events-none absolute -bottom-20 -left-20 w-[400px] h-[400px] rounded-full bg-[#81b344]/5 blur-[60px]"></div>

      <div class="relative z-10 max-w-[1100px] mx-auto px-5 md:px-8 lg:px-12 text-center">
        <div class="inline-flex items-center gap-2.5 px-5 py-2 rounded-full bg-white border border-zinc-200 shadow-sm mb-5 md:mb-7 opacity-0 animate-fade-in-up" style="animation-delay:0ms">
          <span class="w-1.5 h-1.5 rounded-full bg-[#81b344] flex-shrink-0"></span>
          <span class="text-xs font-bold text-zinc-600 tracking-[0.15em] uppercase">Kanceláře · SVJ · Airbnb</span>
        </div>

        <h1 class="fluid-h1 font-extrabold text-zinc-950 tracking-tighter leading-[1.05] mb-5 md:mb-6 opacity-0 animate-fade-in-up" style="animation-delay:150ms">
          Úklidové služby Brno —<br class="hidden sm:block" /><span class="text-[#6a9438]"> kanceláře, SVJ a Airbnb.</span>
        </h1>

        <p class="text-[15px] sm:text-[16px] md:text-[17px] text-zinc-600 max-w-xl mx-auto leading-relaxed font-medium mb-9 opacity-0 animate-fade-in-up" style="animation-delay:300ms">
          Specializujeme se na tři oblasti, kde máme vyladěné procesy a prověřené týmy. Vyberte si tu vaši.
        </p>

        <div class="opacity-0 animate-fade-in-up" style="animation-delay:450ms">
          <!-- Desktop tab switcher -->
          <div id="tab-switcher" class="hidden sm:inline-flex gap-2 p-1.5 bg-white border border-zinc-200 rounded-2xl shadow-sm">
            {tabs.map((tab, i) => (
              <button
                data-tab={tab.id}
                class={`tab-btn flex items-center gap-2.5 px-5 py-3 rounded-xl text-sm font-bold transition-all duration-200 whitespace-nowrap ${
                  i === 0
                    ? 'bg-[#81b344] text-white shadow-md shadow-[#81b344]/25'
                    : 'text-zinc-500 hover:text-zinc-800 hover:bg-zinc-50'
                }`}
              >
                <i data-lucide={tab.icon} class="w-4 h-4 flex-shrink-0" aria-hidden="true"></i>
                {tab.label}
              </button>
            ))}
          </div>
          <!-- Mobile tab switcher -->
          <div id="tab-switcher-mobile" class="sm:hidden flex flex-col gap-2 w-full max-w-xs mx-auto">
            {tabs.map((tab, i) => (
              <button
                data-tab={tab.id}
                class={`tab-btn flex items-center justify-center gap-2.5 w-full px-5 py-3.5 rounded-2xl text-[15px] font-bold transition-all duration-200 ${
                  i === 0
                    ? 'bg-[#81b344] text-white shadow-md shadow-[#81b344]/25'
                    : 'bg-white border border-zinc-200 text-zinc-600 hover:border-[#81b344]/40 hover:text-zinc-900'
                }`}
              >
                <i data-lucide={tab.icon} class="w-5 h-5 flex-shrink-0" aria-hidden="true"></i>
                {tab.label}
              </button>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         TAB: KANCELÁŘE
    ══════════════════════════════════════════ -->
    <div id="tab-kancelare" class="tab-content">

      <section class="py-16 md:py-20 lg:py-28 bg-white">
        <div class="max-w-[1100px] mx-auto px-5 md:px-8 lg:px-12">
          <div class="flex flex-col gap-10 lg:gap-16 items-center lg:flex-row">
            <div class="w-full lg:w-1/2">
              <div class="scroll-animate opacity-0 mb-4">
                <span class="inline-block px-3 py-1.5 rounded-md bg-[#81b344]/10">
                  <span class="text-xs font-bold text-[#6a9438] tracking-[0.1em] uppercase">{kancelare.tag}</span>
                </span>
              </div>
              <!-- H2: fluid, výrazně menší než H1 -->
              <h2 class="scroll-animate opacity-0 fluid-h2 font-extrabold text-zinc-950 tracking-tighter leading-[1.15] mb-5 whitespace-pre-line" style="animation-delay:80ms">
                {kancelare.headline}
              </h2>
              <p class="scroll-animate opacity-0 text-[15px] md:text-[16px] text-zinc-600 font-medium leading-relaxed mb-8" style="animation-delay:160ms">
                {kancelare.sub}
              </p>
              <div class="scroll-animate opacity-0 flex flex-col sm:flex-row gap-3" style="animation-delay:240ms">
                <a href="/kontakt" class="inline-flex items-center justify-center gap-2 px-6 py-3.5 text-[14px] font-bold text-white bg-[#81b344] rounded-xl hover:bg-[#729f3c] hover:-translate-y-1 transition-all duration-300 ease-out shadow-md shadow-[#81b344]/20 whitespace-nowrap">
                  {kancelare.cta}
                  <i data-lucide="arrow-right" class="w-4 h-4 flex-shrink-0" aria-hidden="true"></i>
                </a>
                <a href="#features-kancelare" data-scroll-to="features-kancelare" class="inline-flex items-center justify-center gap-2 px-6 py-3.5 text-[14px] font-bold text-zinc-700 bg-white border-2 border-zinc-200 rounded-xl hover:border-zinc-300 hover:bg-zinc-50 hover:-translate-y-1 transition-all duration-300 ease-out whitespace-nowrap">
                  Co zahrnuje služba
                </a>
              </div>
            </div>
            <div class="scroll-animate opacity-0 w-full lg:w-1/2" style="animation-delay:200ms">
              <div class="relative aspect-[4/3] rounded-[1.75rem] overflow-hidden bg-zinc-100 border border-zinc-200/60 shadow-lg group">
                <img src={kancelare.image} alt={kancelare.imageAlt} width={kancelare.imageWidth} height={kancelare.imageHeight}
                  class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.03]"
                  loading="eager" decoding="async" fetchpriority="high" />
                <div class="absolute inset-0 bg-gradient-to-t from-zinc-950/20 to-transparent pointer-events-none"></div>
                <div class="absolute bottom-4 left-4 px-3 py-1.5 rounded-full bg-white/90 backdrop-blur-sm shadow-sm">
                  <span class="text-xs font-bold text-zinc-700 tracking-[0.06em] uppercase">{kancelare.tagBadge}</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="features-kancelare" class="py-16 md:py-20 lg:py-28 bg-zinc-50">
        <div class="max-w-[1100px] mx-auto px-5 md:px-8 lg:px-12">
          <div class="scroll-animate opacity-0 text-center max-w-2xl mx-auto mb-10">
            <p class="text-[12px] font-bold text-[#81b344] tracking-[0.2em] uppercase mb-3">Rozsah služby</p>
            <h2 class="fluid-h2 font-extrabold text-zinc-950 tracking-tighter leading-[1.15] mb-3">
              Co zahrnuje <span class="text-[#6a9438]">každá návštěva.</span>
            </h2>
            <p class="text-[14px] md:text-[15px] text-zinc-500 font-medium leading-relaxed">
              Všechny tyto činnosti jsou standardní součástí každé návštěvy. Probíhají podle přesně definovaných checklistů viditelných ve webové aplikaci.
            </p>
          </div>
          <div class="grid sm:grid-cols-2 gap-4">
            {kancelare.services.map((item, i) => (
              <div
                class="scroll-animate opacity-0 flex items-start gap-4 bg-white border border-zinc-100 rounded-[1.5rem] p-5 hover:border-[#81b344]/30 hover:shadow-md hover:-translate-y-0.5 transition-all duration-200 group"
                style={`animation-delay:${(i + 1) * 80}ms`}
              >
                <div class="flex-shrink-0 w-11 h-11 rounded-xl bg-[#81b344]/10 flex items-center justify-center text-[#6a9438] group-hover:bg-[#81b344]/15 transition-colors duration-200">
                  <i data-lucide={item.icon} class="w-5 h-5" aria-hidden="true"></i>
                </div>
                <div>
                  <h3 class="text-[14px] font-bold text-zinc-900 mb-1">{item.title}</h3>
                  <p class="text-[13px] font-medium text-zinc-500 leading-relaxed">{item.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section class="py-16 md:py-20 lg:py-24 bg-white">
        <div class="max-w-[1100px] mx-auto px-5 md:px-8 lg:px-12">
          <div class="scroll-animate opacity-0 max-w-xl mx-auto text-center mb-10">
            <p class="text-[12px] font-bold text-[#81b344] tracking-[0.2em] uppercase mb-3">Doplňkový servis</p>
            <h2 class="fluid-h2 font-extrabold text-zinc-950 tracking-tighter leading-[1.15] mb-3">
              Doplňování hygieny —<br class="hidden sm:block" />
              <span class="text-[#6a9438]">s námi vám nedojde.</span>
            </h2>
            <p class="text-[14px] md:text-[15px] text-zinc-500 font-medium leading-relaxed">
              Spotřební materiál fakturujeme zvlášť za tržní ceny. Vy ušetříte čas, my zajistíme, aby v kuchyňce ani na WC nikdy nic nechybělo.
            </p>
          </div>
          <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
            {kancelare.material.map((item, i) => (
              <div
                class="scroll-animate opacity-0 flex flex-col gap-4 bg-zinc-50 border border-zinc-100 rounded-[1.5rem] p-5 hover:border-[#81b344]/30 hover:shadow-sm hover:-translate-y-0.5 transition-all duration-200 group"
                style={`animation-delay:${(i + 1) * 100}ms`}
              >
                <div class="w-11 h-11 rounded-xl bg-[#81b344]/10 flex items-center justify-center text-[#6a9438] group-hover:bg-[#81b344]/15 transition-colors duration-200">
                  <i data-lucide={item.icon} class="w-5 h-5" aria-hidden="true"></i>
                </div>
                <div>
                  <p class="text-[14px] font-bold text-zinc-900 mb-1">{item.label}</p>
                  <p class="text-[12px] font-medium text-zinc-500 leading-relaxed">{item.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section class="py-16 lg:py-20 bg-zinc-950 relative overflow-hidden">
        <div class="hidden md:block pointer-events-none absolute top-0 left-1/4 w-[500px] h-[300px] rounded-full bg-[#81b344]/10 blur-[80px]"></div>
        <div class="hidden md:block pointer-events-none absolute bottom-0 right-1/4 w-[400px] h-[250px] rounded-full bg-[#81b344]/5 blur-[70px]"></div>
