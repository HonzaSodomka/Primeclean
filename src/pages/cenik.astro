<script>
  declare const lucide: { createIcons: () => void };

  const CENIK_TABS = ['kancelare', 'svj', 'airbnb'];
  let activeObserver: IntersectionObserver | null = null;

  function activateCenikTab(target: string, pushState = true) {
    if (!CENIK_TABS.includes(target)) return;
    const isLowEnd = document.documentElement.classList.contains('low-end');

    if (pushState) {
      history.pushState({ tab: target }, '', '/cenik#' + target);
    }

    document.querySelectorAll('.cenik-tab-btn').forEach(btn => {
      const isMobile = btn.closest('#cenik-tab-switcher-mobile') !== null;
      const isTarget = btn.getAttribute('data-cenik-tab') === target;
      btn.classList.remove('bg-[#81b344]', 'text-white', 'shadow-md', 'shadow-[#81b344]/25');
      if (isMobile) {
        if (isTarget) {
          btn.classList.remove('bg-white', 'border', 'border-zinc-200', 'text-zinc-600');
          btn.classList.add('bg-[#81b344]', 'text-white', 'shadow-md', 'shadow-[#81b344]/25');
        } else {
          btn.classList.add('bg-white', 'border', 'border-zinc-200', 'text-zinc-600');
        }
      } else {
        if (isTarget) {
          btn.classList.remove('text-zinc-500', 'hover:text-zinc-800', 'hover:bg-zinc-50');
          btn.classList.add('bg-[#81b344]', 'text-white', 'shadow-md', 'shadow-[#81b344]/25');
        } else {
          btn.classList.add('text-zinc-500', 'hover:text-zinc-800', 'hover:bg-zinc-50');
        }
      }
    });

    document.querySelectorAll('.cenik-tab-content').forEach(c => c.classList.add('hidden'));
    const active = document.getElementById('cenik-tab-' + target);
    if (!active) return;
    active.classList.remove('hidden');

    const animEls = active.querySelectorAll<HTMLElement>('.scroll-animate');
    animEls.forEach(el => {
      el.classList.remove('animate-fade-in-up');
      el.style.opacity = '0';
      el.classList.add('opacity-0');
    });

    activeObserver?.disconnect();
    activeObserver = null;

    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        if (isLowEnd) {
          animEls.forEach(el => {
            el.classList.remove('opacity-0');
            el.style.opacity = '1';
          });
        } else {
          activeObserver = new IntersectionObserver(entries => {
            entries.forEach(entry => {
              if (!entry.isIntersecting) return;
              entry.target.classList.add('animate-fade-in-up');
              entry.target.classList.remove('opacity-0');
              activeObserver?.unobserve(entry.target);
            });
          }, { threshold: 0, rootMargin: '0px 0px -5% 0px' });
          animEls.forEach(el => activeObserver!.observe(el));
        }
        if (typeof lucide !== 'undefined') lucide.createIcons();
      });
    });
  }

  document.addEventListener('DOMContentLoaded', () => {
    const isLowEnd = document.documentElement.classList.contains('low-end');

    if (isLowEnd) {
      document.querySelectorAll<HTMLElement>('.opacity-0').forEach(el => {
        el.classList.remove('opacity-0');
        el.style.opacity = '1';
        el.style.transform = 'none';
        el.style.animation = 'none';
      });
    } else {
      const observer = new IntersectionObserver(entries => {
        entries.forEach(entry => {
          if (!entry.isIntersecting) return;
          entry.target.classList.add('animate-fade-in-up');
          entry.target.classList.remove('opacity-0');
          observer.unobserve(entry.target);
        });
      }, { threshold: 0, rootMargin: '0px 0px -5% 0px' });
      document.querySelectorAll('.scroll-animate').forEach(el => observer.observe(el));
    }

    const hashTab = window.location.hash.replace('#', '');
    const initialTab = CENIK_TABS.includes(hashTab) ? hashTab : 'kancelare';
    activateCenikTab(initialTab, false);

    document.querySelectorAll('.cenik-tab-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const target = btn.getAttribute('data-cenik-tab');
        if (target) activateCenikTab(target);
      });
    });

    window.addEventListener('popstate', e => {
      const tab = (e.state as { tab?: string })?.tab ?? 'kancelare';
      activateCenikTab(tab, false);
    });
  });
</script>

<style>
  @keyframes softFadeUp {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in-up {
    animation: softFadeUp 0.75s cubic-bezier(0.25, 1, 0.4, 1) both;
  }

  @media (prefers-reduced-motion: reduce) {
    .animate-fade-in-up,
    .scroll-animate {
      animation: none !important;
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
    .animate-pulse { animation: none !important; }
  }

  :global(.low-end) .animate-fade-in-up,
  :global(.low-end) .scroll-animate,
  :global(.low-end) .opacity-0 {
    animation: none !important;
    opacity: 1 !important;
    transform: none !important;
  }
  :global(.low-end) .animate-pulse { animation: none !important; }
  :global(.low-end) img { transition: none !important; }
</style>