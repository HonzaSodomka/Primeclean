<Layout title="Ceník | PrimeClean">
  <main class="bg-white selection:bg-[#81b344]/30 selection:text-zinc-900">

    <!-- ═══════════════════════════════════════════
         HERO
    ═══════════════════════════════════════════ -->
    <section class="relative pt-28 pb-20 md:pt-36 md:pb-28 lg:pt-44 lg:pb-36 overflow-hidden bg-zinc-50">
      <div class="hidden md:block pointer-events-none absolute -top-32 -right-32 w-[600px] h-[600px] rounded-full bg-[#81b344]/5" style="filter: blur(80px);"></div>
      <div class="hidden md:block pointer-events-none absolute -bottom-20 -left-20 w-[400px] h-[400px] rounded-full bg-[#81b344]/4" style="filter: blur(60px);"></div>

      <div class="relative z-10 max-w-[1100px] mx-auto px-5 md:px-8 lg:px-12 text-center">

        <div class="inline-flex items-center gap-2.5 px-5 py-2 rounded-full bg-white border border-zinc-200 shadow-sm mb-6 md:mb-8 opacity-0 animate-fade-in-up" style="animation-delay: 0ms;">
          <span class="w-1.5 h-1.5 rounded-full bg-[#81b344] animate-pulse flex-shrink-0"></span>
          <span class="text-[11px] sm:text-xs font-bold text-zinc-600 tracking-[0.15em] uppercase">Transparentní ceník</span>
        </div>

        <h1 class="text-[2.75rem] sm:text-[3.75rem] md:text-6xl lg:text-[6rem] font-extrabold text-zinc-950 tracking-tighter leading-[1.05] md:leading-[0.95] mb-6 opacity-0 animate-fade-in-up" style="animation-delay: 150ms;">
          Jasné ceny,<br class="hidden sm:block" />
          <span class="text-[#6a9438]">žádná překvapení.</span>
        </h1>

        <p class="text-base sm:text-lg md:text-[19px] lg:text-[21px] text-zinc-600 max-w-xl lg:max-w-2xl mx-auto leading-relaxed font-medium mb-10 md:mb-12 opacity-0 animate-fade-in-up" style="animation-delay: 300ms;">
          Jsme lokální brněnská firma a nejsme plátci DPH. Cena, kterou vidíte, je pro vás konečná — žádné navýšení o 21 % na faktuře.
        </p>

        <!-- Tab switcher -->
        <div class="opacity-0 animate-fade-in-up" style="animation-delay: 450ms;">
          <div id="cenik-tab-switcher" class="hidden sm:inline-flex gap-2 p-1.5 bg-white border border-zinc-200 rounded-2xl shadow-sm">
            {tabs.map((tab, i) => (
              <button
                data-cenik-tab={tab.id}
                class={`cenik-tab-btn px-6 py-3.5 rounded-xl text-[14px] font-bold transition-all duration-200 whitespace-nowrap ${
                  i === 0
                    ? 'bg-[#81b344] text-white shadow-md shadow-[#81b344]/25'
                    : 'text-zinc-500 hover:text-zinc-800 hover:bg-zinc-50'
                }`}
              >
                {tab.label}
              </button>
            ))}
          </div>
          <div id="cenik-tab-switcher-mobile" class="sm:hidden flex flex-col gap-2 w-full max-w-xs mx-auto">
            {tabs.map((tab, i) => (
              <button
                data-cenik-tab={tab.id}
                class={`cenik-tab-btn w-full px-5 py-4 rounded-2xl text-[15px] font-bold transition-all duration-200 ${
                  i === 0
                    ? 'bg-[#81b344] text-white shadow-md shadow-[#81b344]/25'
                    : 'bg-white border border-zinc-200 text-zinc-600'
                }`}
              >
                {tab.label}
              </button>
            ))}
          </div>
        </div>

      </div>
    </section>

    <!-- ═══════════════════════════════════════════
         KANCELÁŘE TAB
    ═══════════════════════════════════════════ -->
    <div id="cenik-tab-kancelare" class="cenik-tab-content">

      <!-- Cenová tabulka -->
      <section class="py-20 md:py-28 bg-white">
        <div class="max-w-[1100px] mx-auto px-5 md:px-8 lg:px-12">

          <div class="scroll-animate opacity-0 text-center max-w-2xl mx-auto mb-12">
            <div class="mb-4">
              <span class="text-[13px] font-bold text-[#81b344] tracking-[0.2em] uppercase">Kanceláře a firmy</span>
            </div>
            <h2 class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-zinc-950 tracking-tighter leading-[1.1] mb-4">
              Příklady <span class="text-[#6a9438]">nacenění.</span>
            </h2>
            <p class="text-[16px] text-zinc-500 font-medium leading-relaxed">
              Měsíční paušály jsou orientační — finální kalkulaci připravíme na míru vaší firmě po prohlídce zdarma.
            </p>
          </div>

