                    <p class="text-[15px] font-bold text-zinc-900">{item.label}</p>
                    <span class="text-[13px] font-bold text-[#6a9438] whitespace-nowrap">{item.price}</span>
                  </div>
                  <p class="text-[13px] font-medium text-zinc-500 leading-relaxed">{item.desc}</p>
                </div>
              </div>
            ))}
          </div>

        </div>
      </section>

      <!-- Byt v kapse -->
      <section class="py-20 md:py-28 bg-zinc-50">
        <div class="max-w-[1100px] mx-auto px-5 md:px-8 lg:px-12">

          <div class="scroll-animate opacity-0 text-center max-w-xl mx-auto mb-12">
            <h2 class="text-3xl sm:text-4xl font-extrabold text-zinc-950 tracking-tighter leading-[1.1] mb-4">
              Díky aplikaci PrimeClean
              <span class="text-[#6a9438]"> máte byt v kapse.</span>
            </h2>
          </div>

          <div class="grid sm:grid-cols-3 gap-5">
            {airbnbApp.map((item, i) => (
              <div
                class="scroll-animate opacity-0 flex flex-col items-start gap-4 bg-white border border-zinc-200 rounded-2xl p-6 hover:border-[#81b344]/30 hover:shadow-sm transition-all duration-200"
                style={`animation-delay: ${i * 80}ms`}
              >
                <div class="w-10 h-10 rounded-xl bg-[#81b344]/10 flex items-center justify-center text-[#6a9438]">
                  <span set:html={item.icon} />
                </div>
                <div>
                  <p class="text-[15px] font-bold text-zinc-900 mb-1">{item.label}</p>
                  <p class="text-[13px] font-medium text-zinc-500 leading-relaxed">{item.desc}</p>
                </div>
              </div>
            ))}
          </div>

        </div>
      </section>

      <!-- Proč Brno -->
      <div class="max-w-[1100px] mx-auto px-5 md:px-8 lg:px-12 pb-24">
        <div class="scroll-animate opacity-0 flex flex-col sm:flex-row items-center justify-between gap-6 bg-[#81b344]/8 border border-[#81b344]/20 rounded-2xl px-8 py-6">
          <p class="text-[15px] font-semibold text-zinc-700 text-center sm:text-left">
            Jsme místní, jsme rychlí a chápeme, že v Airbnb byznysu rozhodují detaily. Ceny jsou konečné, nejsme plátci DPH.
          </p>
          <a href="/kontakt" class="flex-shrink-0 inline-flex items-center gap-2 px-7 py-3.5 text-[14px] font-bold text-white bg-[#81b344] rounded-xl shadow-md shadow-[#81b344]/20 hover:bg-[#6a9438] hover:-translate-y-0.5 transition-all duration-200">
            Poptat nezávaznou prohlídku
            <span class="w-4 h-4" set:html={arrowRight} />
          </a>
        </div>
      </div>

    </div>

    <!-- ═══════════════════════════════════════════
         SPODNÍ CTA
    ═══════════════════════════════════════════ -->
    <section class="py-20 md:py-28 bg-zinc-50">
      <div class="max-w-[860px] mx-auto px-5 md:px-8 lg:px-12 text-center">
        <div class="scroll-animate opacity-0 bg-zinc-950 rounded-[2.5rem] p-10 md:p-16 relative overflow-hidden">
          <div class="hidden md:block pointer-events-none absolute -top-20 left-1/2 -translate-x-1/2 w-[600px] h-[300px] rounded-full bg-[#81b344]/10" style="filter: blur(80px);"></div>
          <div class="relative z-10">
            <p class="text-[13px] font-bold text-[#81b344] tracking-[0.2em] uppercase mb-5">Nezávazná kalkulace</p>
            <h2 class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-white tracking-tighter leading-[1.1] mb-5">
              Přijdeme se podívat<br /><span class="text-[#81b344]">a nacenění je zdarma.</span>
            </h2>
            <p class="text-[16px] md:text-[18px] text-zinc-400 font-medium leading-relaxed mb-10 max-w-xl mx-auto">
              Každý objekt je jiný. Přijedeme na místo, zhodnotíme rozsah prací a připravíme přesnou nabídku na míru — bez závazků.
            </p>
            <a href="/kontakt" class="inline-flex items-center justify-center gap-2 px-10 py-4 text-[16px] font-bold text-zinc-950 bg-[#81b344] rounded-xl hover:bg-white transition-all duration-300 hover:-translate-y-1 shadow-lg shadow-[#81b344]/20">
              Domluvit prohlídku zdarma
              <span class="w-5 h-5" set:html={arrowRight} />
            </a>
          </div>
        </div>
      </div>
    </section>

  </main>
</Layout>

<script is:inline>
  (function () {
    const lowEnd =
      (navigator.hardwareConcurrency ?? 4) <= 2 ||
      (navigator.deviceMemory ?? 4) <= 2 ||
      window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (lowEnd) document.documentElement.classList.add('low-end');
  })();

  const CENIK_TABS = ['kancelare', 'svj', 'airbnb'];

  function activateCenikTab(target) {
    if (!CENIK_TABS.includes(target)) return;
    const isLowEnd = document.documentElement.classList.contains('low-end');

    document.querySelectorAll('.cenik-tab-btn').forEach(btn => {
      const isMobile = btn.closest('#cenik-tab-switcher-mobile') !== null;
      const isTarget = btn.getAttribute('data-cenik-tab') === target;
      btn.classList.remove('bg-[#81b344]', 'text-white', 'shadow-md', 'shadow-[#81b344]/25');
      if (isMobile) {
        if (isTarget) {
          btn.classList.remove('bg-white', 'border', 'border-zinc-200', 'text-zinc-600');
          btn.classList.add('bg-[#81b344]', 'text-white', 'shadow-md', 'shadow-[#81b344]/25');
        } else {
          btn.classList.add('bg-white', 'border', 'border-zinc-200', 'text-zinc-600');
        }
      } else {
        if (isTarget) {
          btn.classList.remove('text-zinc-500', 'hover:text-zinc-800', 'hover:bg-zinc-50');
          btn.classList.add('bg-[#81b344]', 'text-white', 'shadow-md', 'shadow-[#81b344]/25');
        } else {
          btn.classList.add('text-zinc-500', 'hover:text-zinc-800', 'hover:bg-zinc-50');
        }
      }
    });

    document.querySelectorAll('.cenik-tab-content').forEach(c => c.classList.add('hidden'));
    const active = document.getElementById('cenik-tab-' + target);
    if (!active) return;
    active.classList.remove('hidden');

    const animEls = active.querySelectorAll('.scroll-animate');
    animEls.forEach(el => {
      el.classList.remove('animate-fade-in-up');
      el.classList.add('opacity-0');
    });
    requestAnimationFrame(() => requestAnimationFrame(() => {
      if (isLowEnd) {
        animEls.forEach(el => { el.classList.remove('opacity-0'); el.style.opacity = '1'; });
      } else {
        const obs = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('animate-fade-in-up');
              entry.target.classList.remove('opacity-0');
              obs.unobserve(entry.target);
            }
          });
        }, { threshold: 0, rootMargin: '0px 0px -8% 0px' });
        animEls.forEach(el => obs.observe(el));
      }
    }));
  }

  document.addEventListener('DOMContentLoaded', () => {
    const isLowEnd = document.documentElement.classList.contains('low-end');

    if (isLowEnd) {
      document.querySelectorAll('.opacity-0').forEach(el => {
        el.classList.remove('opacity-0');
        el.style.opacity = '1';
        el.style.transform = 'none';
        el.style.animation = 'none';
      });
    } else {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('animate-fade-in-up');
            entry.target.classList.remove('opacity-0');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0, rootMargin: '0px 0px -10% 0px' });
      document.querySelectorAll('.scroll-animate').forEach(el => observer.observe(el));
    }

    activateCenikTab('kancelare');

    document.querySelectorAll('.cenik-tab-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const target = btn.getAttribute('data-cenik-tab');
        if (target) activateCenikTab(target);
      });
    });
  });
</script>

<style is:global>
  @keyframes softFadeUp {
    0%   { opacity: 0; transform: translateY(20px); }
    100% { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in-up {
    animation-name: softFadeUp;
    animation-duration: 0.9s;
    animation-timing-function: cubic-bezier(0.25, 1, 0.4, 1);
    animation-fill-mode: both;
  }
  @media (prefers-reduced-motion: reduce) {
    .animate-fade-in-up, .scroll-animate {
      animation: none !important; opacity: 1 !important;
      transform: none !important; transition: none !important;
    }
    .animate-pulse { animation: none !important; }
  }
  .low-end .animate-fade-in-up,
  .low-end .scroll-animate {
    animation: none !important; opacity: 1 !important;
    transform: none !important;
  }
  .low-end .animate-pulse { animation: none !important; }
  .low-end img { transition: none !important; }
</style>
