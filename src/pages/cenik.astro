---
import Layout from '../layouts/Layout.astro';

const tabs = [
  { id: 'kancelare', label: 'Kanceláře a firmy' },
  { id: 'svj',       label: 'SVJ a bytové domy' },
  { id: 'airbnb',    label: 'Airbnb a apartmány' },
];

const kancPricing = [
  { plocha: '80 m²',    freq: '1× týdně',  cena1: '690 Kč',    pausal: '2 900 Kč',  tech: 'Přístup do aplikace PrimeClean' },
  { plocha: '150 m²',   freq: '2× týdně',  cena1: '840 Kč',    pausal: '6 900 Kč',  tech: 'Fotodokumentace každého úklidu' },
  { plocha: '300 m²',   freq: '3× týdně',  cena1: '1 120 Kč',  pausal: '14 500 Kč', tech: 'Online správa skladu a zásob' },
  { plocha: '500 m²',   freq: '3× týdně',  cena1: '1 480 Kč',  pausal: '19 800 Kč', tech: 'Detailní checklisty a reporty' },
  { plocha: '1 000 m²', freq: '5× týdně',  cena1: '1 790 Kč',  pausal: '36 500 Kč', tech: 'Kompletní digitální správa objektu' },
];

const svjPricing = [
  { typ: 'Malý dům',         vchody: '1', patra: '5',  byty: '12',  cena: '2 520 Kč' },
  { typ: 'Panelový dům',     vchody: '1', patra: '8',  byty: '40',  cena: '5 500 Kč' },
  { typ: 'Dvouvchodový dům', vchody: '2', patra: '16', byty: '70',  cena: '10 150 Kč' },
  { typ: 'Velký komplex',    vchody: '5', patra: '40', byty: '150', cena: 'Individuálně' },
];

const airbnbPlans = [
  { name: 'Studio / 1+kk',  price: '750 Kč',   highlight: false, desc: 'Kompletní servis + stlaní 1 lůžka' },
  { name: 'Apartmán 2+kk',  price: '1 100 Kč', highlight: true,  badge: 'Nejčastější', desc: 'Kompletní servis + stlaní 2 lůžek' },
  { name: 'Rodinný 3+kk+',  price: '1 550 Kč', highlight: false, desc: 'Kompletní servis + stlaní 3 lůžek' },
];

const kancWhyUs = [
  {
    icon: 'smartphone',
    title: 'Aplikace PrimeClean',
    desc: 'Po každém úklidu fotodokumentace a vyplněný checklist přímo v aplikaci. Žádné telefonáty, žádné dohady.',
  },
  {
    icon: 'users',
    title: 'Stálý tým, stálý člověk',
    desc: 'Neposíláme jiného pracovníka každý týden. Náš tým zná váš objekt a ví, co kde je.',
  },
  {
    icon: 'calendar-check',
    title: 'Pevný harmonogram',
    desc: 'Termíny dodržujeme. Pokud nastane výjimka, víte o ní dopředu — ne den poté.',
  },
  {
    icon: 'receipt',
    title: 'Cena bez DPH = cena na faktuře',
    desc: 'Jsme lokální firma a nejsme plátci DPH. Finální nabídku připravíme na míru — bez navýšení o 21 %.',
  },
];

const svjWhyUs = [
  {
    icon: 'camera',
    title: 'Fotodokumentace každého úklidu',
    desc: 'Obyvatelé reklamují, že chodba nebyla uklizena? Máte fotodůkaz s časovým razítkem přímo v aplikaci.',
  },
  {
    icon: 'shield-check',
    title: 'Profesionální chemie v ceně',
    desc: 'Veškerá chemie, mopy a pomůcky jsou součástí paušálu. Neřešíte nákupy, sklady ani doplňování.',
  },
  {
    icon: 'users',
    title: 'Stálý tým pro váš dům',
    desc: 'Neposíláme brigádníky na přespání. Náš tým zná váš dům a ví, kde je problémová rohož nebo špatně schnoucí výtah.',
  },
  {
    icon: 'receipt',
    title: 'Cena bez DPH = cena na faktuře',
    desc: 'Nejsme plátci DPH. Paušál schválený výborem SVJ je skutečně tím, co zaplatíte — žádné překvapení.',
  },
];

const airbnbWhyUs = [
  {
    icon: 'camera',
    title: 'Fotoreport po každém úklidu',
    desc: 'Fotky připraveného bytu v aplikaci ihned po dokončení. Víte, že je vše v pořádku ještě před příjezdem hosta.',
  },
  {
    icon: 'alert-triangle',
    title: 'Damage Report',
    desc: 'Poškození po hostech okamžitě vyfotíme a nahrajeme. Máte důkaz pro Airbnb k vymáhání náhrady škody.',
  },
  {
    icon: 'bell-ring',
    title: 'Notifikace v reálném čase',
    desc: 'Upozornění, jakmile je byt připravený. Můžete hostům potvrdit dřívější check-in a získat bonus hodnocení.',
  },
  {
    icon: 'receipt',
    title: 'Cleaning Fee pokryje host',
    desc: 'Ceny odpovídají standardnímu Cleaning Fee na Airbnb. Za úklid fakticky neplatíte vy — platí host.',
  },
];
---

<Layout title="Ceník | PrimeClean">
  <main class="bg-white selection:bg-[#81b344]/30 selection:text-zinc-900">

    <!-- ═══════════ HERO ═══════════ -->
    <section class="relative pt-28 pb-20 md:pt-36 md:pb-28 lg:pt-44 lg:pb-36 overflow-hidden bg-zinc-50">
      <div class="hidden md:block pointer-events-none absolute -top-32 -right-32 w-[600px] h-[600px] rounded-full bg-[#81b344]/5 blur-[80px]"></div>
      <div class="hidden md:block pointer-events-none absolute -bottom-20 -left-20 w-[400px] h-[400px] rounded-full bg-[#81b344]/4 blur-[60px]"></div>

      <div class="relative z-10 max-w-[1100px] mx-auto px-5 md:px-8 lg:px-12 text-center">

        <div class="inline-flex items-center gap-2.5 px-5 py-2 rounded-full bg-white border border-zinc-200 shadow-sm mb-6 md:mb-8 opacity-0 animate-fade-in-up" style="animation-delay:100ms">
          <span class="w-1.5 h-1.5 rounded-full bg-[#81b344] animate-pulse flex-shrink-0"></span>
          <span class="text-[11px] sm:text-xs font-bold text-zinc-600 tracking-[0.15em] uppercase">Transparentní ceník</span>
        </div>

        <h1 class="text-[2.75rem] sm:text-[3.75rem] md:text-6xl lg:text-[6rem] font-extrabold text-zinc-950 tracking-tighter leading-[1.05] md:leading-[0.95] mb-6 opacity-0 animate-fade-in-up" style="animation-delay:200ms">
          Jasné ceny,<br class="hidden sm:block" />
          <span class="text-[#6a9438]">žádná překvapení.</span>
        </h1>

        <p class="text-base sm:text-lg md:text-[19px] lg:text-[21px] text-zinc-600 max-w-xl lg:max-w-2xl mx-auto leading-relaxed font-medium mb-10 md:mb-12 opacity-0 animate-fade-in-up" style="animation-delay:300ms">
          Víte předem, co platíte a co za to dostanete. Jako lokální brněnská firma nejsme plátci DPH — cena na webu je vaše konečná cena na faktuře.
        </p>

        <div class="opacity-0 animate-fade-in-up" style="animation-delay:400ms">
          <!-- Desktop -->
          <div id="cenik-tab-switcher" class="hidden sm:inline-flex gap-2 p-1.5 bg-white border border-zinc-200 rounded-2xl shadow-sm">
            {tabs.map((tab, i) => (
              <button
                data-cenik-tab={tab.id}
                class={`cenik-tab-btn px-6 py-3.5 rounded-xl text-[14px] font-bold transition-all duration-200 whitespace-nowrap ${
                  i === 0
                    ? 'bg-[#81b344] text-white shadow-md shadow-[#81b344]/25'
                    : 'text-zinc-500 hover:text-zinc-800 hover:bg-zinc-50'
                }`}
              >
                {tab.label}
              </button>
            ))}
          </div>
          <!-- Mobile -->
          <div id="cenik-tab-switcher-mobile" class="sm:hidden flex flex-col gap-2 w-full max-w-xs mx-auto">
            {tabs.map((tab, i) => (
              <button
                data-cenik-tab={tab.id}
                class={`cenik-tab-btn w-full px-5 py-4 rounded-2xl text-[15px] font-bold transition-all duration-200 ${
                  i === 0
                    ? 'bg-[#81b344] text-white shadow-md shadow-[#81b344]/25'
                    : 'bg-white border border-zinc-200 text-zinc-600'
                }`}
              >
                {tab.label}
              </button>
            ))}
          </div>
        </div>

      </div>
    </section>


    <!-- ══════════════════════════════════════════
         TAB: KANCELÁŘE
    ══════════════════════════════════════════ -->
    <div id="cenik-tab-kancelare" class="cenik-tab-content">

      <section class="py-20 md:py-28 bg-white">
        <div class="max-w-[1100px] mx-auto px-5 md:px-8 lg:px-12">
          <div class="scroll-animate opacity-0 text-center max-w-3xl mx-auto mb-12">
            <h2 class="text-[20px] sm:text-[24px] md:text-[28px] font-extrabold text-[#81b344] uppercase tracking-wider mb-6">
              Kanceláře a firmy
            </h2>
            <p class="text-[16px] md:text-[18px] text-zinc-600 font-medium leading-relaxed mb-10">
              Jsme lokální brněnská firma a nejsme plátci DPH. Cena, kterou vidíte, je pro vás konečná. Žádné navýšení o 21 % na faktuře. K tomu vám jako jediní v Brně dáváme přístup do naší unikátní aplikace, se kterou máte čistotu svého objektu pod kontrolou přímo v kapse.
            </p>
            <h3 class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-zinc-950 tracking-tighter leading-[1.1] mb-4">
              Příklady nacenění <span class="text-[#6a9438]">úklidu kanceláří.</span>
            </h3>
            <p class="text-[16px] text-zinc-500 font-medium leading-relaxed">
              Měsíční paušály jsou orientační, finální kalkulaci připravíme na míru vaší firmě.
            </p>
          </div>

          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
            {kancPricing.map((row, i) => (
              <div
                class="scroll-animate opacity-0 flex flex-col bg-white border border-zinc-200 rounded-[2rem] p-8 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-300"
                style={`animation-delay:${(i + 1) * 100}ms`}
              >
                <div class="flex items-center justify-between mb-4 pb-4 border-b border-zinc-100 flex-nowrap">
                  <span class="text-[20px] font-extrabold text-zinc-950 whitespace-nowrap">{row.plocha}</span>
                  <span class="text-[13px] font-semibold text-zinc-500 uppercase tracking-widest whitespace-nowrap">{row.freq}</span>
                </div>
                <div class="mb-6 flex-1">
                  <div class="flex items-baseline gap-1.5 flex-nowrap mb-2">
                    <div class="text-[32px] font-extrabold text-[#6a9438] leading-none whitespace-nowrap">{row.pausal}</div>
                    <span class="text-[14px] font-medium text-zinc-500 whitespace-nowrap">/ měsíc</span>
                  </div>
                  <div class="text-[14px] font-medium text-zinc-600">Cena za 1 úklid: <strong class="text-zinc-900">{row.cena1}</strong></div>
                </div>
                <div class="mt-auto pt-6 border-t border-zinc-100">
                  <div class="flex items-start gap-3 text-[14px] font-semibold text-zinc-800">
                    <i data-lucide="check-circle-2" class="w-5 h-5 text-[#81b344] flex-shrink-0 mt-0.5" aria-hidden="true"></i>
                    {row.tech}
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- PROČ SI VYBRAT NÁS — černá -->
      <section class="py-16 md:py-20 bg-zinc-950 relative overflow-hidden">
        <div class="hidden md:block pointer-events-none absolute top-0 left-1/4 w-[500px] h-[300px] rounded-full bg-[#81b344]/10 blur-[80px]"></div>
        <div class="hidden md:block pointer-events-none absolute bottom-0 right-1/4 w-[400px] h-[250px] rounded-full bg-[#81b344]/6 blur-[70px]"></div>
        <div class="max-w-[1100px] mx-auto px-5 md:px-8 lg:px-12 relative z-10">
          <div class="scroll-animate opacity-0 text-center mb-10">
            <p class="text-[13px] font-bold text-[#81b344] tracking-[0.2em] uppercase mb-3">Proč si vybrat nás</p>
            <h3 class="text-2xl sm:text-3xl font-extrabold text-white tracking-tight">
              Co dostanete navíc oproti <span class="text-[#81b344]">běžné úklidové firmě.</span>
            </h3>
          </div>
          <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
            {kancWhyUs.map((item, i) => (
              <div
                class="scroll-animate opacity-0 flex flex-col gap-5 bg-white/5 border border-white/10 rounded-[1.5rem] p-6 hover:bg-white/10 hover:border-white/20 hover:-translate-y-0.5 transition-all duration-200 group"
                style={`animation-delay:${(i + 1) * 80}ms`}
              >
                <div class="w-12 h-12 rounded-xl bg-[#81b344]/15 border border-[#81b344]/20 flex items-center justify-center text-[#81b344] group-hover:bg-[#81b344]/25 transition-colors duration-200 flex-shrink-0">
                  <i data-lucide={item.icon} class="w-6 h-6" aria-hidden="true"></i>
                </div>
                <div>
                  <p class="text-[15px] font-bold text-white mb-1.5">{item.title}</p>
                  <p class="text-[13px] font-medium text-zinc-400 leading-relaxed">{item.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- PROČ BRNO VOLÍ -->
      <section class="py-16 md:py-24 bg-white border-b border-zinc-100">
        <div class="max-w-[1100px] mx-auto px-5 md:px-8 lg:px-12">
          <div class="scroll-animate opacity-0 relative bg-zinc-50 border border-zinc-200 rounded-[2.5rem] p-8 md:p-12 shadow-sm max-w-4xl mx-auto text-center overflow-hidden">
            <div class="absolute top-0 right-0 w-64 h-64 bg-[#81b344]/5 rounded-full blur-3xl pointer-events-none"></div>
            <div class="absolute bottom-0 left-0 w-64 h-64 bg-[#81b344]/5 rounded-full blur-3xl pointer-events-none"></div>
            <h3 class="relative z-10 text-3xl md:text-4xl font-extrabold text-zinc-950 mb-6 tracking-tight">
              Proč Brno volí <span class="text-[#6a9438]">PrimeClean?</span>
            </h3>
            <p class="relative z-10 text-[16px] md:text-[18px] text-zinc-600 font-medium leading-relaxed mb-8 max-w-2xl mx-auto">
              Jsme místní, jsme rychlí a chápeme, že v úklidovém servisu rozhodují detaily. S námi neřešíte výběr dodavatele, střídání brigádníků ani drogerii. Vy jen řídíte byznys — my se staráme o čistotu.
            </p>
            <div class="relative z-10 inline-flex items-start md:items-center gap-3 px-6 py-4 bg-white border border-zinc-200 rounded-2xl text-left md:text-center shadow-sm">
              <i data-lucide="info" class="w-5 h-5 text-[#81b344] flex-shrink-0 mt-0.5 md:mt-0" aria-hidden="true"></i>
              <p class="text-[13px] sm:text-[14px] font-semibold text-zinc-600">
                Nejsme plátci DPH. Uvedené částky jsou orientační — finální nabídku bez překvapení připravíme po prohlídce.
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- CTA -->
      <section class="relative py-20 md:py-28 bg-zinc-50 overflow-hidden">
        <div class="hidden md:block pointer-events-none absolute -top-32 -right-32 w-[600px] h-[600px] rounded-full bg-[#81b344]/5 blur-[80px]"></div>
        <div class="hidden md:block pointer-events-none absolute -bottom-20 -left-20 w-[400px] h-[400px] rounded-full bg-[#81b344]/5 blur-[60px]"></div>
        <div class="relative z-10 max-w-[1100px] mx-auto px-5 md:px-8 lg:px-12 text-center">
          <p class="scroll-animate opacity-0 text-[13px] font-bold text-[#81b344] tracking-[0.2em] uppercase mb-4">Nezávazná kalkulace</p>
          <h2 class="scroll-animate opacity-0 text-3xl sm:text-4xl md:text-5xl font-extrabold text-zinc-950 tracking-tighter leading-[1.08] mb-5" style="animation-delay:100ms">
            Přijedeme se podívat<br />
            <span class="text-[#6a9438]">a nacenění je zdarma.</span>
          </h2>
          <p class="scroll-animate opacity-0 text-[16px] md:text-[18px] text-zinc-500 font-medium leading-relaxed mb-10 max-w-2xl mx-auto" style="animation-delay:200ms">
            Každý objekt je jiný. Přijedeme na místo, zhodnotíme rozsah prací a připravíme přesnou nabídku na míru. Bez závazků, bez překvapení a bez navýšení o DPH.
          </p>
          <div class="scroll-animate opacity-0" style="animation-delay:300ms">
            <a href="/kontakt" class="inline-flex items-center justify-center gap-2 px-10 py-4 text-[16px] font-bold text-white bg-[#81b344] rounded-xl hover:bg-[#6a9438] transition-all duration-300 hover:-translate-y-1 shadow-lg shadow-[#81b344]/20">
              Poptat nezávaznou prohlídku
              <i data-lucide="arrow-right" class="w-5 h-5" aria-hidden="true"></i>
            </a>
          </div>
        </div>
      </section>

    </div>


    <!-- ══════════════════════════════════════════
         TAB: SVJ
    ══════════════════════════════════════════ -->
    <div id="cenik-tab-svj" class="cenik-tab-content hidden">

      <section class="py-20 md:py-28 bg-white">
        <div class="max-w-[1100px] mx-auto px-5 md:px-8 lg:px-12">
          <div class="scroll-animate opacity-0 text-center max-w-3xl mx-auto mb-12">
            <h2 class="text-[20px] sm:text-[24px] md:text-[28px] font-extrabold text-[#81b344] uppercase tracking-wider mb-6">
              Vchody SVJ a panelové domy
            </h2>
            <p class="text-[16px] md:text-[18px] text-zinc-600 font-medium leading-relaxed mb-10">
              Úklid společných prostor bez starostí a dohadů s nájemníky. Díky digitální kontrole přesně víte, kdy byl dům uklizen.
            </p>
            <h3 class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-zinc-950 tracking-tighter leading-[1.1] mb-4">
              Příklady nacenění <span class="text-[#6a9438]">úklidu SVJ (1× týdně).</span>
            </h3>
            <p class="text-[16px] text-zinc-500 font-medium leading-relaxed">
              Měsíční paušály jsou orientační, finální kalkulaci připravíme na míru vašemu domu.
            </p>
          </div>

          <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5 lg:gap-6">
            {svjPricing.map((row, i) => (
              <div
                class="scroll-animate opacity-0 flex flex-col bg-white border border-zinc-200 rounded-[2rem] p-7 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-300"
                style={`animation-delay:${(i + 1) * 100}ms`}
              >
                <div class="flex items-center justify-between mb-4 pb-4 border-b border-zinc-100 flex-nowrap min-h-[56px]">
                  <span class="text-[18px] font-extrabold text-zinc-950 leading-tight">{row.typ}</span>
                </div>
                <div class="mb-6 flex-1">
                  <div class="flex items-baseline gap-1.5 flex-nowrap mb-2">
                    <div class={`font-extrabold leading-none whitespace-nowrap ${row.cena === 'Individuálně' ? 'text-zinc-500 text-[24px]' : 'text-[#6a9438] text-[28px] lg:text-[30px]'}`}>
                      {row.cena}
                    </div>
                    {row.cena !== 'Individuálně' && (
                      <span class="text-[13px] font-medium text-zinc-500 whitespace-nowrap">/ měsíc</span>
                    )}
                  </div>
                  <div class="text-[13px] font-medium text-zinc-600">Počet bytů: <strong class="text-zinc-900">{row.byty}</strong></div>
                </div>
                <div class="mt-auto pt-5 border-t border-zinc-100 space-y-2">
                  <div class="flex justify-between text-[13px] text-zinc-600">
                    <span>Počet vchodů:</span>
                    <strong class="text-zinc-900">{row.vchody}</strong>
                  </div>
                  <div class="flex justify-between text-[13px] text-zinc-600">
                    <span>Počet pater:</span>
                    <strong class="text-zinc-900">{row.patra}</strong>
                  </div>
                </div>
              </div>
            ))}
          </div>

          <div class="scroll-animate opacity-0 mt-8 max-w-2xl mx-auto" style="animation-delay:500ms">
            <div class="flex items-center gap-3 px-6 py-4 bg-blue-50 border border-blue-100 rounded-2xl">
              <i data-lucide="snowflake" class="w-5 h-5 text-blue-400 flex-shrink-0" aria-hidden="true"></i>
              <p class="text-[14px] font-semibold text-zinc-700">
                V zimních měsících (listopad–březen) se uplatňuje zimní servisní příplatek <strong class="text-blue-600">+20 % k paušálu.</strong>
                <a href="/sluzby#tab-svj" class="ml-2 text-[#81b344] hover:underline font-bold">Více o zimním režimu →</a>
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- PROČ SI VYBRAT NÁS — černá -->
      <section class="py-16 md:py-20 bg-zinc-950 relative overflow-hidden">
        <div class="hidden md:block pointer-events-none absolute top-0 left-1/4 w-[500px] h-[300px] rounded-full bg-[#81b344]/10 blur-[80px]"></div>
        <div class="hidden md:block pointer-events-none absolute bottom-0 right-1/4 w-[400px] h-[250px] rounded-full bg-[#81b344]/6 blur-[70px]"></div>
        <div class="max-w-[1100px] mx-auto px-5 md:px-8 lg:px-12 relative z-10">
          <div class="scroll-animate opacity-0 text-center mb-10">
            <p class="text-[13px] font-bold text-[#81b344] tracking-[0.2em] uppercase mb-3">Proč si vybrat nás</p>
            <h3 class="text-2xl sm:text-3xl font-extrabold text-white tracking-tight">
              Co dostanete navíc oproti <span class="text-[#81b344]">běžné úklidové firmě.</span>
            </h3>
          </div>
          <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
            {svjWhyUs.map((item, i) => (
              <div
