---
import Layout from '../layouts/Layout.astro';

const features = [
  {
    title: "Systém a kontrola úklidů",
    description: "Každý úklid má jasný rozsah a kontrolu provedení. Máte absolutní přehled o zakázkách bez neustálého telefonování.",
    icon: "shield-check"
  },
  {
    title: "Spolehlivost a domluva",
    description: "Dodržujeme domluvené termíny i rozsah prací. Vždy přesně víte, kdy, kde a co přesně se u vás bude uklízet.",
    icon: "clipboard-check"
  },
  {
    title: "Profesionální tým a technika",
    description: "Pracujeme s vyškoleným týmem a profesionální čistící technikou. Zvládáme i náročné a vysoce specializované zakázky.",
    icon: "zap"
  }
];

const services = [
  {
    title: "Úklid kanceláří a firem",
    description: "Pravidelný úklid přizpůsobený provozu vaší firmy. Stálý tým, jasný rozsah prací a přehled o úklidech bez starostí.",
    image: "/sluzba-kancelare.webp",
    link: "/sluzby#tab-kancelare",
    tag: "Nejoblíbenější"
  },
  {
    title: "Úklid SVJ a bytových domů",
    description: "Pravidelný úklid vchodů, chodeb a společných prostor. Spolehlivé řešení pro bytová družstva a správce nemovitostí.",
    image: "/sluzba-svj.webp",
    link: "/sluzby#tab-svj",
    tag: "Správa budov"
  },
  {
    title: "Úklid pro Airbnb a apartmány",
    description: "Spolehlivý úklid pro krátkodobé pronájmy mezi pobyty hostů. Rychlá příprava bytu a přehled o každém úklidu online.",
    image: "/sluzba-airbnb.webp",
    link: "/sluzby#tab-airbnb",
    tag: "Krátkodobé pronájmy"
  }
];

const stats = [
  { value: 21,  suffix: '',  label: "Pravidelných objektů",  icon: "building-2"     },
  { value: 90,  suffix: '+', label: "Spokojených klientů",   icon: "users"          },
  { value: 290, suffix: '+', label: "Realizovaných úklidů",  icon: "badge-check"    },
  { value: 5,   suffix: '+', label: "Let v oboru",           icon: "calendar-check" },
];

const trustBadges = [
  { icon: "shield-check", label: "Pojištění 5 mil. Kč"         },
  { icon: "user-check",   label: "Prověřený personál"          },
  { icon: "camera",       label: "Fotoreport po každém úklidu" },
  { icon: "clock",        label: "Pravidelný harmonogram"      },
];

const testimonials = [
  {
    name: "Anatolij Ramaldan",
    role: "Hostitel na Airbnb",
    text: "Jako hostitel na Airbnb potřebuju mít jistotu, že je apartmán vždy perfektně připravený a v naprostém pořádku. PrimeClean to zvládá spolehlivě i na poslední chvíli. Díky fotkám v aplikaci mám klid, i když zrovna nejsem v Brně.",
    rating: 5,
    initials: "AR"
  },
  {
    name: "Autoškola TiGO s.r.o.",
    role: "Kancelář & učebna",
    text: "S touto úklidovou firmou máme velmi dobrou zkušenost. Už přibližně 3 měsíce se starají o čistotu naší kanceláře i učebny a vždy odvedou skvělou práci. Velké plus je komunikace — domluva je vždy rychlá a bez problémů. Dokonce ani změna termínu nikdy nebyla komplikace. Za nás maximální spokojenost.",
    rating: 5,
    initials: "AT"
  },
  {
    name: "Magdalena Kopecká",
    role: "Správce objektu",
    text: "Konečně úklidovka, co u práce i přemýšlí. Nejen že je všude čisto, ale hlavně nám v jejich appce přistávají fotky a hlášení, když je v baráku něco špatně – třeba prasklá žárovka nebo uvolněný práh. Máme o všem přehled dřív, než si začnou lidi stěžovat. Pecka přístup!",
    rating: 5,
    initials: "MK"
  },
  {
    name: "Petr Zeman",
    role: "Majitel kanceláří",
    text: "Po špatné zkušenosti s nespolehlivou firmou jsem konečně narazil na úklidovou firmu, na kterou je opravdu spoleh. Vše je vždy perfektně uklizené, termíny dodržují a komunikace je bezproblémová. Jsem rád, že jsem je našel, a určitě je doporučuji dál.",
    rating: 5,
    initials: "PZ"
  },
];

const faqItems = [
  {
    q: "Jak máme jistotu, že se úklid opravdu provádí pravidelně a kvalitně?",
    a: "Každý úklid je evidovaný a dohledatelný. V naší webové aplikaci vidíte, kdy byl úklid proveden, v jakém rozsahu a případné poznámky. Nemusíte nikoho obcházet ani kontrolovat osobně – máte přehled kdykoliv, přímo v prohlížeči bez instalace."
  },
  {
    q: "Co když nebude kvalita odpovídat domluvě nebo někdo úklid vynechá?",
    a: "Rozsah úklidu je jasně daný a nemění se bez domluvy. Pokud by nastal problém, řešíme ho okamžitě – bez výmluv a přehazování odpovědnosti. Máte jednoho partnera, ne anonymní brigádu."
  },
  {
    q: "Jak je to s komunikací a změnami (svátky, mimořádný úklid, úprava frekvence)?",
    a: "Uklízíme stabilně v domluvených termínech, a to i během svátků. Pokud vám termín vyhovuje, nic se nemění. Jakékoliv mimořádné požadavky, úpravy frekvence nebo změny termínů řešíme vždy včasnou dohodou, abyste měli absolutní jasno bez chaosu a nejasností."
  },
  {
    q: "Pracujete s vlastními zaměstnanci, nebo živnostníky?",
    a: "Pouze s našimi kmenovými a prověřenými zaměstnanci. Nejsme agentura — každý pracovník prochází interním zaškolením, zná váš objekt a vy vždy víte, kdo u vás uklízí."
  },
  {
    q: "Jste pojištěni?",
    a: "Ano, máme pojištění odpovědnosti za škodu do výše 5\u202f000\u202f000 Kč. V případě náhodného poškození při úklidu jste plně krytí."
  },
];
---

<Layout
  title="Úklid Brno — PrimeClean | Kanceláře, SVJ, Airbnb"
  description="Profesionální úklid Brno a okolí. Specializujeme se na úklid kanceláří, úklid SVJ a bytových domů a úklid Airbnb apartmánů. Pojištění 5 mil. Kč, fotoreport po každém úklidu."
>
  <main class="bg-white selection:bg-[#81b344]/30 selection:text-zinc-900">

    <!-- SEO: skrytý blok pro vyhledávače, vizuálně neviditelný -->
    <div class="sr-only" aria-hidden="true">
      <h2>Úklid Brno — profesionální úklidová firma</h2>
      <p>PrimeClean zajišťuje profesionální úklid v Brně a okolí. Nabízíme úklid kanceláří Brno, úklid SVJ Brno, úklid bytových domů Brno a úklid Airbnb apartmánů v Brně. Spolehlivá úklidová firma Brno s pojištěním 5 mil. Kč a fotodokumentací po každém úklidu.</p>
      <h3>Úklid SVJ Brno</h3>
      <p>Pravidelný úklid společných prostor SVJ a bytových domů v Brně. Úklid vchodů, chodeb, schodišť, výtahů a sklepních prostor. Spolehlivé řešení pro správce nemovitostí a bytová družstva v Brně a okolí.</p>
      <h3>Úklid kanceláří Brno</h3>
      <p>Pravidelný úklid kancelářských prostor, firem a administrativních budov v Brně. Stálý tým, jasný harmonogram a kontrola kvality přes webovou aplikaci. Úklid firem Brno bez starostí.</p>
      <h3>Úklid Airbnb Brno</h3>
      <p>Profesionální úklid apartmánů a bytů pro krátkodobé pronájmy v Brně. Rychlá příprava mezi pobyty hostů, fotoreport a online přehled. Úklid pro hostitele Airbnb v Brně.</p>
    </div>

    <!-- 1. HERO -->
    <section class="relative pt-24 pb-16 md:pt-32 md:pb-20 lg:pt-40 lg:pb-28 overflow-hidden bg-zinc-50">
      <div class="hero-blob hero-blob--tr" aria-hidden="true"></div>
      <div class="hero-blob hero-blob--bl" aria-hidden="true"></div>

      <div class="relative z-10 max-w-[1100px] mx-auto px-5 md:px-8 lg:px-12 text-center">

        <div class="inline-flex items-center gap-2.5 px-5 py-2 rounded-full bg-white border border-zinc-200 shadow-sm mb-5 md:mb-7 opacity-0 animate-fade-in-up" style="animation-delay:0ms">
          <span class="w-1.5 h-1.5 rounded-full bg-[#81b344] flex-shrink-0"></span>
          <span class="text-xs font-bold text-zinc-600 tracking-[0.15em] uppercase">Profesionální úklid Brno a okolí</span>
        </div>

        <h1 class="fluid-h1 font-extrabold text-zinc-950 tracking-tighter leading-[1.05] mb-5 md:mb-6 opacity-0 animate-fade-in-up" style="animation-delay:150ms">
          Úklid pro Brno a okolí<br class="hidden sm:block" />
          <span class="text-[#6a9438]">spolehlivě a bez starostí.</span>
        </h1>

        <div class="flex flex-wrap items-center justify-center gap-2 sm:gap-3 text-[13px] sm:text-[14px] font-bold tracking-[0.1em] uppercase mb-7 md:mb-9 opacity-0 animate-fade-in-up" style="animation-delay:300ms">
          <span class="text-zinc-800 bg-zinc-200/50 px-3 py-1 rounded-md">SVJ</span>
          <span class="text-[#81b344]">·</span>
          <span class="text-zinc-800 bg-zinc-200/50 px-3 py-1 rounded-md">Kanceláře</span>
          <span class="text-[#81b344]">·</span>
          <span class="text-zinc-800 bg-zinc-200/50 px-3 py-1 rounded-md">Airbnb</span>
        </div>

        <p class="text-[15px] sm:text-[16px] md:text-[17px] text-zinc-600 max-w-[95%] md:max-w-xl lg:max-w-2xl mx-auto leading-relaxed font-medium mb-10 opacity-0 animate-fade-in-up" style="animation-delay:450ms">
          Mějte úklid konečně vyřešený. S naší klientskou webovou aplikací vidíte fotoreporty ihned po dokončení práce. Pojištění 5 mil. Kč a prověřený personál.
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-3 px-4 sm:px-0 opacity-0 animate-fade-in-up" style="animation-delay:600ms">
          <a href="/kontakt" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-7 py-3.5 text-[15px] font-bold text-white transition-all duration-300 ease-out bg-[#81b344] rounded-xl hover:bg-[#729f3c] hover:-translate-y-1 shadow-md shadow-[#81b344]/20">
            Chci nezávaznou nabídku
            <i data-lucide="arrow-right" class="w-4 h-4" aria-hidden="true"></i>
          </a>
          <a href="#proc-my" class="w-full sm:w-auto inline-flex items-center justify-center px-7 py-3.5 text-[15px] font-bold text-zinc-700 transition-all duration-300 ease-out bg-white border-2 border-zinc-200 rounded-xl hover:border-zinc-300 hover:bg-zinc-50 hover:-translate-y-1">
            Proč PrimeClean?
          </a>
        </div>

        <div class="mt-12 md:mt-20 relative max-w-5xl mx-auto group opacity-0 animate-fade-in-up pb-10 sm:pb-0" style="animation-delay:800ms">
          <div class="relative aspect-[4/3] sm:aspect-[16/9] rounded-2xl md:rounded-[2rem] overflow-hidden bg-zinc-100 border border-zinc-200/50 z-10">
            <img
              src="/hero-image.webp"
              alt="PrimeClean — profesionální úklid kancelářských prostor v Brně"
              width="1200" height="675"
              class="w-full h-full object-cover object-center transition-transform duration-700 ease-out group-hover:scale-[1.02]"
              fetchpriority="high"
              loading="eager"
              decoding="async"
            />
          </div>
          <div class="absolute -bottom-6 left-2 sm:-bottom-8 sm:left-8 z-20 bg-white rounded-2xl shadow-xl border border-zinc-100 p-4 flex items-center gap-4 w-[calc(100%-1rem)] sm:w-auto sm:max-w-[320px]">
            <div class="flex-shrink-0 w-10 h-10 bg-[#81b344]/10 rounded-xl flex items-center justify-center text-[#6a9438]">
              <i data-lucide="image" class="w-5 h-5" aria-hidden="true"></i>
            </div>
            <div class="text-left min-w-0">
              <p class="text-[13px] font-bold text-zinc-950 leading-tight">Fotografie z úklidu</p>
              <p class="text-xs font-medium text-zinc-600 mt-0.5 leading-snug">Prohlížejte si fotoreporty po každém úklidu rovnou ve webové aplikaci — bez instalace, přímo v prohlížeči.</p>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- TRUST BADGE BAR -->
<section class="bg-white border-y border-zinc-100 py-4">
  <div class="max-w-[1100px] mx-auto px-5 md:px-8 lg:px-12">
    <div class="scroll-animate opacity-0 flex flex-wrap items-center justify-center gap-x-6 gap-y-3 md:gap-x-10">
      {trustBadges.map(badge => (
        <div class="flex items-center gap-2 text-zinc-600">
          <span class="text-[#81b344] flex-shrink-0" aria-hidden="true">
            <i data-lucide={badge.icon} class="w-4 h-4"></i>
          </span>
          <span class="text-[12px] sm:text-[13px] font-semibold whitespace-nowrap">{badge.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>

    <!-- 2. SLUŽBY -->
    <section id="sluzby" class="py-16 md:py-20 lg:py-28 bg-zinc-50 relative overflow-hidden scroll-mt-20 md:scroll-mt-24">
      <div class="max-w-[1200px] mx-auto px-5 md:px-8 lg:px-12 relative z-10 text-center">
        <div class="scroll-animate opacity-0 max-w-2xl mx-auto mb-12 lg:mb-16">
          <p class="text-[12px] font-bold text-[#81b344] tracking-[0.2em] uppercase mb-3">NAŠE SLUŽBY</p>
          <!--
            H2: fluid clamp()
            min 1.5rem (24px) — mobil
            mid 3.5vw         — tablet/notas
            max 2.5rem (40px) — desktop
          -->
          <h2 class="fluid-h2 font-extrabold text-zinc-950 tracking-tighter leading-[1.15] mb-4">
            Kde odvádíme tu <span class="text-[#6a9438]">nejlepší práci.</span>
          </h2>
          <p class="text-[15px] md:text-[16px] text-zinc-600 font-medium leading-relaxed max-w-xl mx-auto">
            Specializujeme se na oblasti, kde máme vyladěné procesy. Díky zkušenostem a klientské aplikaci vám zajistíme spolehlivé plánování a absolutní kontrolu.
          </p>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 text-left">
          {services.map((service, index) => (
            <div
              class="scroll-animate opacity-0 flex flex-col bg-white rounded-[1.75rem] border border-zinc-200 shadow-sm transition-all duration-300 ease-out hover:shadow-lg hover:-translate-y-1 overflow-hidden group"
              style={`animation-delay:${index * 120}ms`}
            >
              <div class="relative w-full aspect-[4/3] bg-zinc-100 overflow-hidden">
                <img
                  src={service.image}
                  alt={service.title}
                  width="600" height="450"
                  class="w-full h-full object-cover object-center transition-transform duration-500 ease-out group-hover:scale-[1.03]"
                  loading="lazy"
                  decoding="async"
                />
                <div class="absolute top-3 left-3 px-2.5 py-1 rounded-full bg-white shadow-sm">
                  <span class="text-xs font-bold text-zinc-700 tracking-[0.06em] uppercase">{service.tag}</span>
                </div>
              </div>
              <div class="p-6 md:p-7 flex-grow flex flex-col">
                <h3 class="text-[18px] font-bold text-zinc-950 tracking-tight leading-snug mb-2">{service.title}</h3>
                <p class="text-[14px] text-zinc-600 font-medium leading-relaxed mb-5 flex-grow">{service.description}</p>
                <div class="pt-4 border-t border-zinc-100">
                  <a href={service.link} class="inline-flex items-center gap-1.5 font-bold text-[14px] text-[#81b344] hover:text-[#6a9438] transition-colors group/link">
                    Zjistit více
                    <i data-lucide="arrow-right" class="w-4 h-4 transition-transform duration-300 group-hover/link:translate-x-1" aria-hidden="true"></i>
                  </a>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- 3. PROČ MY & APLIKACE -->
    <section id="proc-my" class="py-16 md:py-20 lg:py-28 bg-white scroll-mt-20 md:scroll-mt-24 relative overflow-hidden">
      <div class="max-w-[1200px] mx-auto px-5 md:px-8 lg:px-12 relative z-10">

        <div class="text-center max-w-2xl mx-auto mb-12 lg:mb-16 scroll-animate opacity-0">
          <p class="text-[12px] font-bold text-[#81b344] tracking-[0.2em] uppercase mb-3">Výhody spolupráce</p>
          <h2 class="fluid-h2 font-extrabold text-zinc-950 tracking-tighter mb-4 leading-[1.15]">
            Nenechte nic <span class="text-[#6a9438]">náhodě.</span>
          </h2>
          <p class="text-[15px] md:text-[16px] text-zinc-600 font-medium leading-relaxed max-w-xl mx-auto">
            Úklid v Brně a okolí zajišťujeme profesionálně a bez výmluv. Pracujeme systematicky, s nekompromisní kontrolou kvality.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 lg:gap-6 mb-16 md:mb-20">
          {features.map((feature, index) => (
            <div
              class="scroll-animate opacity-0 relative bg-zinc-50 rounded-[1.5rem] p-7 lg:p-8 border border-zinc-100 transition-all duration-300 ease-out hover:-translate-y-1 hover:shadow-lg hover:border-[#81b344]/20 overflow-hidden group"
              style={`animation-delay:${index * 120}ms`}
            >
              <span class="absolute top-4 right-6 text-[3.5rem] font-extrabold text-[#81b344]/8 leading-none select-none pointer-events-none" aria-hidden="true">
                {String(index + 1).padStart(2, '0')}
              </span>
              <div class="w-12 h-12 rounded-xl bg-white border border-zinc-200 flex items-center justify-center text-[#6a9438] mb-6 relative z-10 group-hover:border-[#81b344]/30 group-hover:bg-[#81b344]/5 transition-colors duration-300">
                <i data-lucide={feature.icon} class="w-5 h-5" aria-hidden="true"></i>
              </div>
              <h3 class="text-[18px] font-bold text-zinc-950 tracking-tight leading-snug mb-3 relative z-10">{feature.title}</h3>
              <p class="text-[14px] font-medium text-zinc-600 leading-relaxed relative z-10">{feature.description}</p>
            </div>
          ))}
        </div>

        <!-- DARK APP PROMO -->
        <div class="scroll-animate opacity-0 flex flex-col lg:flex-row items-center gap-10 lg:gap-16 bg-zinc-950 text-white rounded-[2rem] p-7 sm:p-10 md:p-12 border border-zinc-800 shadow-2xl">
          <div class="w-full lg:w-[55%] relative z-10">
            <div class="inline-block px-3 py-1.5 rounded-md bg-white/10 mb-5">
              <span class="text-[11px] font-bold text-zinc-300 tracking-[0.1em] uppercase">Klientská webová aplikace</span>
            </div>
            <!--
              H3 app: fluid clamp()
              min 1.375rem (22px) — mobil
              mid 3vw             — tablet
              max 2.25rem  (36px) — desktop
            -->
            <h3 class="fluid-h3-app font-extrabold leading-[1.2] mb-5 tracking-tighter">
              Přehled v aplikaci.<br /><span class="text-[#81b344]">Vše o úklidu pohodlně ve vaší kapse.</span>
            </h3>
            <p class="text-[15px] md:text-[16px] text-zinc-400 font-medium leading-relaxed mb-3 max-w-lg">
              Objednávky, historie úklidů, faktury i platby přehledně na jednom místě. Žádné zbytečné maily a doptávání se, jestli už je hotovo.
            </p>
            <p class="text-[13px] text-zinc-500 font-medium leading-relaxed mb-7 max-w-lg">
              Funguje přímo v prohlížeči — žádná instalace, dostupné z mobilu i počítače.
            </p>
            <ul class="flex flex-col gap-3 mb-8" role="list">
              {[
                'Živé fotoreporty po každém úklidu',
                'Přehled faktur a historie plateb',
                'Notifikace o dokončení úklidu',
                'Přístup 24/7 z mobilu i počítače',
              ].map((item) => (
                <li class="flex items-center gap-3 text-[14px] text-zinc-200 font-semibold tracking-tight">
                  <div class="flex-shrink-0 w-5 h-5 rounded-full bg-[#81b344] flex items-center justify-center text-zinc-950" aria-hidden="true">
                    <i data-lucide="check" class="w-3 h-3" style="stroke-width:3"></i>
                  </div>
                  {item}
                </li>
              ))}
            </ul>
            <a href="/aplikace" class="inline-flex items-center justify-center gap-2 px-7 py-3.5 text-[14px] font-bold text-zinc-950 transition-all duration-300 ease-out bg-[#81b344] rounded-xl hover:bg-white hover:-translate-y-1">
              Prozkoumat aplikaci
              <i data-lucide="arrow-right" class="w-4 h-4" aria-hidden="true"></i>
            </a>
          </div>
          <div class="w-full sm:max-w-xs md:max-w-sm mx-auto lg:w-[45%] relative mt-6 lg:mt-0 z-10">
            <div class="relative aspect-[4/5] rounded-[1.5rem] overflow-hidden bg-zinc-900 border border-zinc-700">
              <img
                src="/dashboard.webp"
                alt="Klientská webová aplikace PrimeClean — přehled úklidů a fotoreportů"
                width="600" height="750"
                class="w-full h-full object-cover object-top"
                loading="lazy"
                decoding="async"
              />
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- 4. STATISTIKY -->
    <section class="py-16 lg:py-20 bg-[#81b344] relative overflow-hidden count-up-container">
      <div class="max-w-[1200px] mx-auto px-5 md:px-8 lg:px-12 relative z-10">
        <div class="scroll-animate opacity-0 text-center mb-10 md:mb-12">
