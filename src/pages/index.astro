<script>
  const isLowEnd = () => document.documentElement.classList.contains('low-end');

  function initScrollAnimate() {
    if (isLowEnd()) {
      document.querySelectorAll<HTMLElement>('.scroll-animate').forEach(el => {
        el.style.opacity = '1';
        el.style.transform = 'none';
        el.style.animation = 'none';
        el.classList.remove('opacity-0');
      });
      return;
    }
    const observer = new IntersectionObserver(
      entries => entries.forEach(entry => {
        if (!entry.isIntersecting) return;
        (entry.target as HTMLElement).classList.add('animate-fade-in-up');
        (entry.target as HTMLElement).classList.remove('opacity-0');
        observer.unobserve(entry.target);
      }),
      { threshold: 0, rootMargin: '0px 0px -5% 0px' }
    );
    document.querySelectorAll('.scroll-animate').forEach(el => observer.observe(el));
  }

  function initFaq() {
    document.querySelectorAll('.faq-item').forEach(item => {
      const trigger  = item.querySelector('.faq-trigger')   as HTMLButtonElement | null;
      const body     = item.querySelector('.faq-body')      as HTMLElement | null;
      const iconWrap = item.querySelector('.faq-icon')      as HTMLElement | null;
      const iconPlus = item.querySelector('.faq-icon-plus') as HTMLElement | null;
      const iconX    = item.querySelector('.faq-icon-x')    as HTMLElement | null;
      if (!trigger || !body) return;

      trigger.addEventListener('click', () => {
        const open = trigger.getAttribute('aria-expanded') === 'true';
        if (open) {
          body.style.maxHeight = body.scrollHeight + 'px';
          requestAnimationFrame(() => requestAnimationFrame(() => { body.style.maxHeight = '0px'; }));
          trigger.setAttribute('aria-expanded', 'false');
          item.classList.remove('border-[#81b344]/40', 'bg-white');
          item.classList.add('bg-zinc-50', 'border-zinc-200');
          iconWrap?.classList.replace('bg-zinc-100', 'bg-zinc-200');
          iconPlus?.classList.remove('hidden');
          iconX?.classList.add('hidden');
        } else {
          body.style.maxHeight = body.scrollHeight + 'px';
          trigger.setAttribute('aria-expanded', 'true');
          item.classList.add('border-[#81b344]/40', 'bg-white');
          item.classList.remove('bg-zinc-50', 'border-zinc-200');
          iconWrap?.classList.replace('bg-zinc-200', 'bg-zinc-100');
          iconPlus?.classList.add('hidden');
          iconX?.classList.remove('hidden');
        }
      });

      body.addEventListener('transitionend', () => {
        if (trigger.getAttribute('aria-expanded') === 'true') body.style.maxHeight = 'none';
      });
    });
  }

  function initCountUp() {
    const section = document.querySelector<HTMLElement>('.count-up-container');
    if (!section) return;
    if (isLowEnd()) {
      section.querySelectorAll<HTMLElement>('.count-up').forEach(el => { el.textContent = el.dataset.target ?? '0'; });
      return;
    }
    let done = false;
    const run = () => {
      if (done) return;
      done = true;
      section.querySelectorAll<HTMLElement>('.count-up').forEach(el => {
        const target = parseInt(el.dataset.target ?? '0', 10);
        const duration = 1400;
        let start: number | null = null;
        const step = (ts: number) => {
          if (!start) start = ts;
          const p = Math.min((ts - start) / duration, 1);
          el.textContent = String(Math.floor((1 - Math.pow(1 - p, 3)) * target));
          if (p < 1) requestAnimationFrame(step);
          else el.textContent = String(target);
        };
        requestAnimationFrame(step);
      });
    };
    const r = section.getBoundingClientRect();
    if (r.top < window.innerHeight && r.bottom > 0) { run(); return; }
    const obs = new IntersectionObserver(entries => {
      if (entries[0].isIntersecting) { run(); obs.disconnect(); }
    }, { rootMargin: '0px 0px -5% 0px' });
    obs.observe(section);
  }

  function initSlider() {
    const track = document.getElementById('testimonials-track') as HTMLElement | null;
    const dots  = document.querySelectorAll<HTMLElement>('.testimonial-dot');
    if (!track || !dots.length) return;
    let rafId = 0;
    const updateDots = () => {
      const cards = track.children;
      if (!cards.length) return;
      const active = Math.round(track.scrollLeft / ((cards[0] as HTMLElement).offsetWidth + 16));
      dots.forEach((dot, i) => {
        dot.style.width      = i === active ? '24px' : '8px';
        dot.style.height     = '8px';
        dot.style.background = i === active ? '#81b344' : '#3f3f46';
      });
    };
    track.addEventListener('scroll', () => {
      cancelAnimationFrame(rafId);
      rafId = requestAnimationFrame(updateDots);
    }, { passive: true });
    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => {
        const cards = track.children;
        if (!cards.length) return;
        track.scrollTo({ left: i * ((cards[0] as HTMLElement).offsetWidth + 16), behavior: 'smooth' });
      });
    });
  }

  document.addEventListener('DOMContentLoaded', () => {
    initScrollAnimate();
    initFaq();
    initCountUp();
    initSlider();
  });
</script>

