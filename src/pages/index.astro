<script is:inline>
  (function () {
    const cores = navigator.hardwareConcurrency || 4;
    const ram = navigator.deviceMemory || 4;
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (cores <= 2 || ram <= 2 || reducedMotion) {
      document.documentElement.classList.add('low-end');
    }
  })();

  document.addEventListener('DOMContentLoaded', () => {
    const isLowEnd = document.documentElement.classList.contains('low-end');
    const scrollAnimateEls = document.querySelectorAll('.scroll-animate');

    if (isLowEnd) {
      scrollAnimateEls.forEach(el => { el.classList.remove('opacity-0'); });
    } else {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('animate-fade-in-up');
            entry.target.classList.remove('opacity-0');
            observer.unobserve(entry.target);
          }
        });
      }, { root: null, threshold: 0, rootMargin: "0px 0px -10% 0px" });
      scrollAnimateEls.forEach(el => observer.observe(el));
    }

    if (isLowEnd) {
      document.querySelectorAll('.animate-fade-in-up').forEach(el => {
        el.style.opacity = '1';
        el.style.transform = 'none';
        el.style.animation = 'none';
      });
    }

    const statsSection = document.querySelector('.count-up-container');
    if (!statsSection) return;

    if (isLowEnd) {
      statsSection.querySelectorAll('.count-up').forEach(counter => {
        counter.innerHTML = counter.getAttribute('data-target') || '0';
      });
      return;
    }

    const animateValue = (obj, start, end, duration) => {
      let startTimestamp = null;
      const step = (timestamp) => {
        if (!startTimestamp) startTimestamp = timestamp;
        const progress = Math.min((timestamp - startTimestamp) / duration, 1);
        const easeOut = 1 - Math.pow(1 - progress, 3);
        obj.innerHTML = Math.floor(easeOut * (end - start) + start).toString();
        if (progress < 1) { window.requestAnimationFrame(step); }
        else { obj.innerHTML = end.toString(); }
      };
      window.requestAnimationFrame(step);
    };

    const statsObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.querySelectorAll('.count-up').forEach(counter => {
            const targetNum = parseInt(counter.getAttribute('data-target') || '0', 10);
            animateValue(counter, 0, targetNum, 2000);
          });
          statsObserver.unobserve(entry.target);
        }
      });
    }, { rootMargin: "0px 0px -10% 0px" });

    statsObserver.observe(statsSection);
  });
</script>

<style is:global>
  @keyframes softFadeUp {
    0% { opacity: 0; transform: translateY(20px); }
    100% { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in-up {
    animation-name: softFadeUp;
    animation-duration: 0.9s;
    animation-timing-function: cubic-bezier(0.25, 1, 0.4, 1);
    animation-fill-mode: both;
  }
  details summary::-webkit-details-marker { display: none; }
  @media (prefers-reduced-motion: reduce) {
    .animate-fade-in-up, .scroll-animate {
      animation: none !important; opacity: 1 !important;
      transform: none !important; transition: none !important;
    }
    .animate-pulse { animation: none !important; }
  }
  .low-end .animate-fade-in-up,
  .low-end .scroll-animate {
    animation: none !important; opacity: 1 !important;
    transform: none !important; transition: none !important;
  }
  .low-end .animate-pulse { animation: none !important; }
  .low-end img { transition: none !important; }
</style>
