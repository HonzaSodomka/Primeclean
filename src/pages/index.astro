    background-image: repeating-linear-gradient(
      90deg, #d4e8b8 0, #d4e8b8 10px, transparent 10px, transparent 22px
    );
  }

  /* ── Scroll-reveal animation ───────────────────────────────────── */
  @keyframes softFadeUp {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in-up {
    animation: softFadeUp 0.75s cubic-bezier(0.25, 1, 0.4, 1) both;
  }

  /* ── Testimonials scrollbar hide ────────────────────────────────── */
  #testimonials-track::-webkit-scrollbar { display: none; }

  /* ── FAQ body transition ────────────────────────────────────────── */
  .faq-body { transition: max-height 0.3s cubic-bezier(0.25, 1, 0.4, 1); }

  /* ── Reduced motion ──────────────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .animate-fade-in-up, .scroll-animate {
      animation: none !important;
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
    .animate-pulse { animation: none !important; }
    .faq-body      { transition: none !important; }
  }

  /* ── Low-end device overrides ───────────────────────────────────────── */
  :global(.low-end) .animate-fade-in-up,
  :global(.low-end) .scroll-animate,
  :global(.low-end) .opacity-0 {
    animation: none !important;
    opacity: 1 !important;
    transform: none !important;
  }
  :global(.low-end) .animate-pulse { animation: none !important; }
  :global(.low-end) img             { transition: none !important; }
  :global(.low-end) .faq-body       { transition: none !important; }
</style>
