---
import Layout from '../layouts/Layout.astro';

const features = [
  {
    title: "Systém a kontrola úklidů",
    description: "Každý úklid má jasný rozsah a kontrolu provedení. Máte absolutní přehled o zakázkách bez neustálého telefonování.",
    icon: "shield-check"
  },
  {
    title: "Spolehlivost a domluva",
    description: "Dodržujeme domluvené termíny i rozsah prací. Vždy přesně víte, kdy, kde a co přesně se u vás bude uklízet.",
    icon: "clipboard-check"
  },
  {
    title: "Profesionální tým a technika",
    description: "Pracujeme s vyškoleným týmem a profesionální čistící technikou. Zvládáme i náročné a vysoce specializované zakázky.",
    icon: "zap"
  }
];

const services = [
  {
    title: "Kanceláře a firmy",
    description: "Pravidelný úklid přizpůsobený provozu vaší firmy. Stálý tým, jasný rozsah prací a přehled o úklidech bez starostí.",
    image: "/sluzba-kancelare.jpg",
    link: "/sluzby#tab-kancelare",
    tag: "Nejoblíbenejší"
  },
  {
    title: "SVJ a bytové domy",
    description: "Pravidelný úklid vchodů, chodeb a společných prostor. Spolehlivé řešení pro bytová družstva a správce nemovitostí.",
    image: "/sluzba-svj.jpg",
    link: "/sluzby#tab-svj",
    tag: "Správa budov"
  },
  {
    title: "Airbnb a apartmány",
    description: "Spolehlivý úklid pro krátkodobé pronájmy mezi pobyty hostů. Rychlá příprava bytu a přehled o každém úklidu online.",
    image: "/sluzba-airbnb.jpg",
    link: "/sluzby#tab-airbnb",
    tag: "Krátkodobé pronájmy"
  }
];

const stats = [
  { value: 295, label: "Aktivních úklidů",     icon: "calendar-check" },
  { value: 400, label: "Spokojených klientů",  icon: "users"          },
  { value: 527, label: "Dokončených zakázek", icon: "badge-check"    },
  { value: 21,  label: "Pravidelných objektů", icon: "building-2"     },
];

const trustBadges = [
  { icon: "shield-check", label: "Pojištění 5 mil. Kč"        },
  { icon: "user-check",   label: "Prověřený personál"         },
  { icon: "camera",       label: "Fotoreport po každém úklidu" },
  { icon: "clock",        label: "Pravidelný harmonogram"       },
];

const testimonials = [
  {
    name: "Ing. Petra Horáčková",
    role: "Předsedkyně výboru SVJ",
    location: "Brno-Královo Pole",
    text: "S PrimeClean spolupracujeme druhý rok. Oceněuji hlavne aplikaci — víme přesně, kdy byl úklid proveden a co bylo uděláno. Žádné dohady, žádné teleforáty. Výbor i obyvatelé jsou spokojeni.",
    rating: 5,
    initials: "PH"
  },
  {
    name: "Martin Blažek",
    role: "Office Manager",
    location: "IT firma, Brno-střed",
    text: "Přešli jsme od předchozí firmy, která nás opakovaně zklamala pozdími příchody. PrimeClean přišli v domluvený čas od první návštěvy a drží to konzistentne. To je přesně to, co jsme hledali.",
    rating: 5,
    initials: "MB"
  },
  {
    name: "Lucie Marková",
    role: "Majitelka Airbnb",
    location: "3 apartmány, Brno",
    text: "Jako hostitelka na Airbnb potřebuji mít jistotu, že apartmán je vždy perfektně připravený. PrimeClean to zvládá spolehlivee i na poslední chvíli. Fotky v aplikaci mi dávají klid, i když jsem mimo Brno.",
    rating: 5,
    initials: "LM"
  },
  {
    name: "Radek Pospíšil",
    role: "Správce nemovitostí",
    location: "Brno a okolí",
    text: "Spravuji více objektů a potřebuji partnera, který funguje bez dozoru. PrimeClean má nastavené procesy, stálé pracovníky a vše hlídá přes aplikaci. Ušetřil jsem si spoustu starostí.",
    rating: 5,
    initials: "RP"
  },
];

const faqItems = [
  {
    q: "Jak máme jistotu, že se úklid opravdu provádí pravidelně a kvalitně?",
    a: "Každý úklid je evidovaný a dohledatelný. V naší aplikaci vidíte, kdy byl úklid proveden, v jakém rozsahu a případné poznámky. Nemusíte nikoho obcházet ani kontrolovat osobně – máte přehled kdykoliv."
  },
  {
    q: "Co když nebude kvalita odpovídat domluvě nebo někdo úklid vynechá?",
    a: "Rozsah úklidu je jasně daný a nemění se bez domluvy. Pokud by nastal problém, řešíme ho okamžitě – bez výmluv a přehazování odpovědnosti. Máte jednoho partnera, ne anonymní brigádu."
  },
  {
    q: "Jak je to s komunikací a změnami (svátky, mimořádný úklid, úprava frekvence)?",
    a: "Změny řešíme vždy po dohodě. Předem vás informujeme o úpravách kvůli svátkům, mimořádnému úklidu nebo změně frekvence. Máte jasno, co se bude dít a kdy – bez chaosu a nejasností."
  },
  {
    q: "Pracujete s vlastními zaměstnanci, nebo živostníky?",
    a: "Pouze s prověřenými zaměstnanci na HPP. Nejsme agentura — každý pracovník prochází naším zaškolením, zná váš objekt a vy vždy víte, kdo u vás uklizí."
  },
  {
    q: "Jste pojištěni?",
    a: "Ano, máme pojištění odpovědnosti za škodu do výše 5\u202f000\u202f000 Kč. V případě náhodného poškození při úklidu jste plně krytí."
  },
];
---

<Layout title="Profesionální úklid Brno a okolí | PrimeClean">
  <main class="bg-white selection:bg-[#81b344]/30 selection:text-zinc-900">

    <!-- 1. HERO -->
    <section class="relative pt-28 pb-20 md:pt-36 md:pb-28 lg:pt-44 lg:pb-36 overflow-hidden bg-zinc-50">
      <div class="hero-blob hero-blob--tr" aria-hidden="true"></div>
      <div class="hero-blob hero-blob--bl" aria-hidden="true"></div>

      <div class="relative z-10 max-w-[1100px] mx-auto px-5 md:px-8 lg:px-12 text-center">

        <div class="inline-flex items-center gap-2.5 px-5 py-2 rounded-full bg-white border border-zinc-200 shadow-sm mb-6 md:mb-8 opacity-0 animate-fade-in-up" style="animation-delay:0ms">
          <span class="w-1.5 h-1.5 rounded-full bg-[#81b344] animate-pulse flex-shrink-0"></span>
          <span class="text-[11px] sm:text-xs font-bold text-zinc-600 tracking-[0.15em] uppercase">Profesionální úklid Brno a okolí</span>
        </div>

        <h1 class="text-[2.75rem] sm:text-[3.75rem] md:text-6xl lg:text-[6rem] font-extrabold text-zinc-950 tracking-tighter leading-[1.05] md:leading-[0.95] mb-6 opacity-0 animate-fade-in-up" style="animation-delay:150ms">
          Čistota, kterou máte <br class="hidden sm:block" />
          <span class="text-[#6a9438]">plně pod kontrolou.</span>
        </h1>

        <div class="flex flex-wrap items-center justify-center gap-3 sm:gap-4 text-[14px] sm:text-[15px] md:text-[16px] font-bold tracking-[0.1em] uppercase mb-8 md:mb-10 opacity-0 animate-fade-in-up" style="animation-delay:300ms">
          <span class="text-zinc-800 bg-zinc-200/50 px-3 py-1 rounded-md">SVJ</span>
          <span class="text-[#81b344]">·</span>
          <span class="text-zinc-800 bg-zinc-200/50 px-3 py-1 rounded-md">Kanceláře</span>
          <span class="text-[#81b344]">·</span>
          <span class="text-zinc-800 bg-zinc-200/50 px-3 py-1 rounded-md">Airbnb</span>
        </div>

        <p class="text-base sm:text-lg md:text-[19px] lg:text-[21px] text-zinc-600 max-w-[95%] md:max-w-xl lg:max-w-2xl mx-auto leading-relaxed font-medium mb-12 opacity-0 animate-fade-in-up" style="animation-delay:450ms">
          Mějte úklid konečně vyřešený. S naší klientskou aplikací vidíte fotoreporty ihned po dokončení práce. Pojištění 5 mil. Kč a prověřený personál.
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 px-4 sm:px-0 opacity-0 animate-fade-in-up" style="animation-delay:600ms">
          <a href="/kontakt" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-8 py-4 text-[16px] font-bold text-white transition-all duration-300 ease-out bg-[#81b344] rounded-xl hover:bg-[#729f3c] hover:-translate-y-1 shadow-md shadow-[#81b344]/20">
            Chci nezávaznou nabídku
            <i data-lucide="arrow-right" class="w-4 h-4" aria-hidden="true"></i>
          </a>
          <a href="#proc-my" class="w-full sm:w-auto inline-flex items-center justify-center px-8 py-4 text-[16px] font-bold text-zinc-700 transition-all duration-300 ease-out bg-white border-2 border-zinc-200 rounded-xl hover:border-zinc-300 hover:bg-zinc-50 hover:-translate-y-1">
            Proč PrimeClean?
          </a>
        </div>

        <div class="mt-16 md:mt-24 relative max-w-5xl mx-auto group opacity-0 animate-fade-in-up" style="animation-delay:800ms">
          <div class="relative aspect-[4/3] sm:aspect-[16/9] rounded-2xl md:rounded-[2rem] overflow-hidden bg-zinc-100 border border-zinc-200/50 z-10">
            <img
              src="/hero-image.jpg"
              alt="PrimeClean úklid"
              width="1200" height="675"
              class="w-full h-full object-cover object-center transition-transform duration-700 ease-out group-hover:scale-[1.02]"
              fetchpriority="high"
              decoding="async"
            />
          </div>
          <div class="absolute -bottom-6 -left-2 sm:-bottom-8 sm:left-8 z-20 bg-white rounded-2xl shadow-xl border border-zinc-100 p-4 flex items-center gap-4 max-w-[calc(100%-16px)] sm:max-w-[320px]">
            <div class="flex-shrink-0 w-11 h-11 bg-[#81b344]/10 rounded-xl flex items-center justify-center text-[#6a9438]">
              <i data-lucide="image" class="w-5 h-5" aria-hidden="true"></i>
            </div>
            <div class="text-left min-w-0">
              <p class="text-[13.5px] font-bold text-zinc-950 leading-tight">Fotografie z úklidu</p>
              <p class="text-[12px] font-medium text-zinc-600 mt-0.5 leading-snug">Prohlížejte si fotoreporty po každém úklidu rovnou v aplikaci.</p>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- 1b. TRUST BADGE BAR -->
    <section class="bg-white border-y border-zinc-100 py-4 sm:py-5">
      <div class="max-w-[1200px] mx-auto px-5 md:px-8 lg:px-12">
        <div class="grid grid-cols-1 sm:grid-cols-2 md:flex md:flex-wrap items-center justify-center gap-y-3 sm:gap-y-4 gap-x-8 md:gap-x-12">
          {trustBadges.map(badge => (
            <div class="flex items-center gap-2.5 text-zinc-600 justify-center md:justify-start">
              <span class="text-[#81b344] flex-shrink-0">
                <i data-lucide={badge.icon} class="w-[22px] h-[22px]" aria-hidden="true"></i>
              </span>
              <span class="text-[14px] font-semibold whitespace-nowrap">{badge.label}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- 2. SLUŽBY -->
    <section id="sluzby" class="py-20 md:py-32 bg-zinc-50 relative overflow-hidden scroll-mt-20 md:scroll-mt-24">
      <div class="max-w-[1200px] mx-auto px-5 md:px-8 lg:px-12 relative z-10 text-center">
        <div class="scroll-animate opacity-0 max-w-3xl mx-auto mb-16 lg:mb-24">
          <p class="text-[13px] font-bold text-[#81b344] tracking-[0.2em] uppercase mb-4">NAŠE SLUŽBY</p>
          <h2 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-extrabold text-zinc-950 tracking-tighter leading-[1.1] mb-6">
            Kde odvádíme tu <span class="text-[#6a9438]">nejlepší práci.</span>
          </h2>
          <p class="text-lg md:text-[20px] text-zinc-600 font-medium leading-relaxed max-w-2xl mx-auto">
            Specializujeme se na oblasti, kde máme vyladěné procesy. Díky našim zkušenostem a klientské aplikaci vám zajístíme spolehlivé plánování a absolutní kontrolu.
          </p>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 text-left">
          {services.map((service, index) => (
            <div
              class="scroll-animate opacity-0 flex flex-col bg-white rounded-[2rem] border border-zinc-200 shadow-sm transition-all duration-300 ease-out hover:shadow-lg hover:-translate-y-1 overflow-hidden group"
              style={`animation-delay:${index * 120}ms`}
            >
              <div class="relative w-full aspect-[4/3] bg-zinc-100 overflow-hidden">
                <img
                  src={service.image}
                  alt={service.title}
                  width="600" height="450"
                  class="w-full h-full object-cover object-center transition-transform duration-500 ease-out group-hover:scale-[1.03]"
                  loading="lazy"
                  decoding="async"
                />
                <div class="absolute top-4 left-4 px-2.5 py-1 rounded-full bg-white shadow-sm">
                  <span class="text-[11px] font-bold text-zinc-700 tracking-[0.06em] uppercase">{service.tag}</span>
                </div>
              </div>
              <div class="p-8 flex-grow flex flex-col">
                <h3 class="text-[22px] font-bold text-zinc-950 tracking-tight leading-snug mb-3">{service.title}</h3>
                <p class="text-[15px] text-zinc-600 font-medium leading-relaxed mb-6 flex-grow">{service.description}</p>
                <div class="pt-5 border-t border-zinc-100">
                  <a href={service.link} class="inline-flex items-center gap-1.5 font-bold text-[15px] text-[#81b344] hover:text-[#6a9438] transition-colors group/link">
                    Zjistit více
                    <i data-lucide="arrow-right" class="w-4 h-4 transition-transform duration-300 group-hover/link:translate-x-1" aria-hidden="true"></i>
                  </a>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- 3. PROČ MY & APLIKACE -->
    <section id="proc-my" class="py-20 md:py-32 bg-white scroll-mt-20 md:scroll-mt-24 relative overflow-hidden">
      <div class="max-w-[1200px] mx-auto px-5 md:px-8 lg:px-12 relative z-10">

        <div class="text-center max-w-3xl mx-auto mb-16 lg:mb-24 scroll-animate opacity-0">
          <p class="text-[13px] font-bold text-[#81b344] tracking-[0.2em] uppercase mb-4">Výhody spolupráce</p>
          <h2 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-extrabold text-zinc-950 tracking-tighter mb-6 leading-[1.1]">
            Nenechte nic <span class="text-[#6a9438]">náhodě.</span>
          </h2>
          <p class="text-lg md:text-[20px] text-zinc-600 font-medium leading-relaxed max-w-2xl mx-auto">
            Úklid v Brně a okolí zajišťujeme profesionálně a bez výmluv. Pracujeme systematicky, s nekompromisní kontrolou kvality.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8 mb-24">
          {features.map((feature, index) => (
            <div
              class="scroll-animate opacity-0 relative bg-zinc-50 rounded-[1.5rem] p-8 lg:p-10 border border-zinc-100 transition-all duration-300 ease-out hover:-translate-y-1 hover:shadow-lg hover:border-[#81b344]/20 overflow-hidden group"
              style={`animation-delay:${index * 120}ms`}
            >
              <span class="absolute top-5 right-7 text-[4rem] font-extrabold text-[#81b344]/8 leading-none select-none pointer-events-none" aria-hidden="true">
                {String(index + 1).padStart(2, '0')}
              </span>
              <div class="w-14 h-14 rounded-2xl bg-white border border-zinc-200 flex items-center justify-center text-[#6a9438] mb-8 relative z-10 group-hover:border-[#81b344]/30 group-hover:bg-[#81b344]/5 transition-colors duration-300">
                <i data-lucide={feature.icon} class="w-6 h-6" aria-hidden="true"></i>
              </div>
              <h3 class="text-[20px] lg:text-[22px] font-bold text-zinc-950 tracking-tight leading-snug mb-4 relative z-10">{feature.title}</h3>
              <p class="text-[15px] lg:text-[16px] font-medium text-zinc-600 leading-relaxed relative z-10">{feature.description}</p>
            </div>
          ))}
        </div>

        <!-- DARK APP PROMO -->
        <div class="scroll-animate opacity-0 flex flex-col lg:flex-row items-center gap-12 lg:gap-20 bg-zinc-950 text-white rounded-[2rem] lg:rounded-[3rem] p-8 sm:p-12 md:p-16 border border-zinc-800 shadow-2xl">
          <div class="w-full lg:w-[55%] relative z-10">
            <div class="inline-block px-3 py-1.5 rounded-md bg-white/10 mb-6">
              <span class="text-[12px] font-bold text-zinc-300 tracking-[0.1em] uppercase">Klientská Aplikace</span>
            </div>
            <h3 class="text-3xl sm:text-4xl md:text-5xl font-extrabold leading-[1.1] mb-6 tracking-tighter">
              Přehled v aplikaci.<br /><span class="text-[#81b344]">Vše o úklidu pohodlně ve Vaší kapse.</span>
            </h3>
            <p class="text-base md:text-[18px] text-zinc-400 font-medium leading-relaxed mb-8 max-w-lg">
              Objednávky, historie úklidů, faktury i platby přehledně na jednom místě. Žádné zbytečné maily a doptávání se, jestli už je hotovo.
            </p>
            <ul class="flex flex-col gap-4 mb-10" role="list">
              {[
                'Živé fotoreporty po každém úklidu',
                'Přehled faktur a historie plateb',
                'Notifikace o dokončení úklidu',
                'Přístup 24/7 z mobilu i počítăe',
              ].map(item => (
                <li class="flex items-center gap-4 text-[16px] text-zinc-200 font-semibold tracking-tight">
                  <div class="flex-shrink-0 w-6 h-6 rounded-full bg-[#81b344] flex items-center justify-center text-zinc-950">
                    <i data-lucide="check" class="w-3 h-3" style="stroke-width:3" aria-hidden="true"></i>
                  </div>
                  {item}
                </li>
              ))}
            </ul>
            <a href="/aplikace" class="inline-flex items-center justify-center gap-2 px-8 py-4 text-[15px] font-bold text-zinc-950 transition-all duration-300 ease-out bg-[#81b344] rounded-xl hover:bg-white hover:-translate-y-1">
              Prozkoumat aplikaci
              <i data-lucide="arrow-right" class="w-4 h-4" aria-hidden="true"></i>
            </a>
          </div>
          <div class="w-full sm:max-w-sm md:max-w-md mx-auto lg:w-[45%] relative mt-8 lg:mt-0 z-10">
            <div class="relative aspect-[4/5] rounded-[1.5rem] overflow-hidden bg-zinc-900 border border-zinc-700">
              <img
                src="/aplikace.jpg"
                alt="Ukázka aplikace PrimeClean"
                width="600" height="750"
                class="w-full h-full object-cover object-top"
                loading="lazy"
                decoding="async"
              />
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- 4. STATISTIKY -->
    <section class="py-20 lg:py-28 bg-[#81b344] relative overflow-hidden count-up-container">
      <div class="max-w-[1200px] mx-auto px-5 md:px-8 lg:px-12 relative z-10">
        <div class="scroll-animate opacity-0 text-center mb-14">
          <h2 class="text-2xl sm:text-3xl font-extrabold text-white tracking-tight mb-1.5">Výsledky, které budujeme každý den</h2>
          <p class="text-white/70 font-medium text-[15px]">Čísla, která mluví za sebe</p>
        </div>
        <div class="scroll-animate opacity-0 grid grid-cols-2 md:grid-cols-4 gap-y-10 md:gap-y-0 text-center">
          {stats.map((stat, index) => (
            <div class={`flex flex-col items-center justify-center px-4 ${index < stats.length - 1 ? 'md:border-r md:border-white/20' : ''}`}>
              <div class="w-9 h-9 rounded-lg bg-white/15 flex items-center justify-center text-white mb-4">
                <i data-lucide={stat.icon} class="w-4 h-4" aria-hidden="true"></i>
              </div>
              <div class="flex items-end justify-center text-white mb-2">
                <span class="text-[3rem] md:text-[4rem] lg:text-[4.5rem] font-extrabold tracking-tighter leading-none count-up" data-target={stat.value}>0</span>
                <span class="text-[1.75rem] md:text-[2.25rem] font-bold text-white/70 ml-1 pb-1 md:pb-2">+</span>
              </div>
              <div class="text-[12px] md:text-[13px] font-bold uppercase tracking-[0.1em] text-white/80">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- 5. RECENZE -->
    <section class="py-20 md:py-32 bg-zinc-950 relative overflow-hidden">
      <div class="review-blob review-blob--tl" aria-hidden="true"></div>
      <div class="review-blob review-blob--br" aria-hidden="true"></div>

      <div class="max-w-[1200px] mx-auto px-5 md:px-8 lg:px-12 relative z-10">
        <div class="scroll-animate opacity-0 text-center max-w-2xl mx-auto mb-16">
          <p class="text-[13px] font-bold text-[#81b344] tracking-[0.2em] uppercase mb-4">Co říkají klienti</p>
          <h2 class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-white tracking-tighter leading-[1.1] mb-4">
            Zkušenosti <span class="text-[#81b344]">našich klientů.</span>
          </h2>
          <div class="flex items-center justify-center gap-1.5">
            {[1,2,3,4,5].map(() => (
              <i data-lucide="star" class="w-4 h-4 text-amber-400 fill-amber-400" aria-hidden="true"></i>
            ))}
            <span class="ml-2 text-[15px] font-bold text-white">5,0</span>
            <span class="text-zinc-500 text-[14px] font-medium ml-1">průměrné hodnocení</span>
          </div>
        </div>

        <!-- Mobile slider -->
        <div class="sm:hidden">
          <div
            id="testimonials-track"
